<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <link rel="stylesheet" href="/style.css">
    <title>ALPHA | Gestão Administrativa</title>
    <script src="/socket.io/socket.io.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    
    <style>
        :root { 
            --primary: #ffca2c; 
            --primary-dark: #e5b627;
            --accent: #2ecc71;
            --bg-body: #f4f7fe; 
            --bg-card: #ffffff;
            --sidebar-width: 260px;
            --text-title: #2b3674;
            --text-main: #707eae;
            --border-color: #e0e5f2;
            --shadow: 14px 17px 40px 4px rgba(112, 144, 176, 0.08);
        }

        body.dark-mode {
            --bg-body: #0b1437;
            --bg-card: #111c44;
            --text-title: #ffffff;
            --text-main: #a3aed0;
            --border-color: #1b254b;
            --shadow: none;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', sans-serif; }
        
        body { 
            background: var(--bg-body); 
            color: var(--text-main);
            transition: all 0.3s ease;
        }

        .admin-wrapper { display: flex; min-height: 100vh; }

        /* SIDEBAR MODERNA */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--bg-card);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            z-index: 1001;
            transition: transform 0.3s ease;
        }

        .sidebar-header {
            padding: 40px 20px;
            text-align: center;
            border-bottom: 1px solid var(--border-color);
        }

        .logo-text {
            font-weight: 800;
            font-size: 1.5rem;
            color: var(--text-title);
            letter-spacing: -1px;
        }

        .nav-menu { flex: 1; padding: 20px 10px; }

        .nav-item {
            width: 100%;
            padding: 15px 20px;
            margin-bottom: 8px;
            border: none;
            border-radius: 12px;
            background: transparent;
            color: var(--text-main);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            transition: 0.3s;
            text-align: left;
        }

        .nav-item.active {
            background: var(--primary);
            color: #181818;
            box-shadow: 0px 4px 14px rgba(255, 202, 44, 0.39);
        }

        /* CONTEÚDO PRINCIPAL */
        .main-content {
            flex: 1;
            margin-left: var(--sidebar-width);
            padding: 30px;
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .page-info h1 { color: var(--text-title); font-size: 1.8rem; font-weight: 800; }

        .top-actions { display: flex; gap: 10px; }

        /* CARDS E GRIDS */
        .tab-content { display: none; animation: fadeIn 0.4s ease; }
        .tab-content.active { display: block; }

        .stat-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: var(--bg-card);
            padding: 25px;
            border-radius: 20px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-color);
        }

        .stat-card .label { font-size: 0.85rem; font-weight: 600; margin-bottom: 10px; display: block; }
        .stat-card .value { font-size: 1.8rem; font-weight: 800; color: var(--text-title); }

        .glass-card {
            background: var(--bg-card);
            border-radius: 20px;
            padding: 25px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border-color);
            margin-bottom: 25px;
        }

        /* SUPORTE / CHAT */
        .chat-container {
            display: grid;
            grid-template-columns: 320px 1fr;
            height: 70vh;
            background: var(--bg-card);
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid var(--border-color);
        }

        .chat-sidebar {
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
        }

        .chat-list { overflow-y: auto; padding: 15px; }

        .chat-user {
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 10px;
            background: var(--bg-body);
            cursor: pointer;
            border: 2px solid transparent;
            transition: 0.2s;
        }

        .chat-user.active { border-color: var(--primary); background: var(--bg-card); }
        .chat-user.has-new { border-left: 5px solid var(--accent); }

        .chat-window { display: flex; flex-direction: column; background: var(--bg-body); }
        .chat-messages { flex: 1; padding: 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 15px; }

        .bubble { max-width: 70%; padding: 12px 18px; border-radius: 18px; font-size: 0.9rem; line-height: 1.4; }
        .bubble.cliente { align-self: flex-start; background: var(--bg-card); color: var(--text-title); border-bottom-left-radius: 4px; }
        .bubble.admin { align-self: flex-end; background: var(--primary); color: #181818; font-weight: 600; border-bottom-right-radius: 4px; }

        .chat-input { padding: 20px; background: var(--bg-card); display: flex; gap: 10px; }
        .chat-input input { flex: 1; padding: 12px 20px; border-radius: 30px; border: 1px solid var(--border-color); background: var(--bg-body); color: var(--text-title); outline: none; }

        /* UI ELEMENTS */
        .btn-action {
            background: var(--primary);
            color: #181818;
            padding: 12px 24px;
            border-radius: 12px;
            border: none;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-action:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(255, 202, 44, 0.4); }

        .switch { position: relative; display: inline-block; width: 50px; height: 26px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background: #cbd5e0; transition: .4s; border-radius: 34px; }
        .slider:before { position: absolute; content: ""; height: 18px; width: 18px; left: 4px; bottom: 4px; background: white; transition: .4s; border-radius: 50%; }
        input:checked + .slider { background: var(--accent); }
        input:checked + .slider:before { transform: translateX(24px); }

        /* MODAL */
        .modal { display: none; position: fixed; z-index: 2000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); backdrop-filter: blur(5px); }
        .modal-content { background: var(--bg-card); margin: 5% auto; padding: 30px; border-radius: 24px; width: 90%; max-width: 550px; }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* MOBILE */
        @media (max-width: 1024px) {
            .sidebar { transform: translateX(-100%); }
            .main-content { margin-left: 0; padding: 15px; }
            .sidebar.open { transform: translateX(0); }
            .chat-container { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <div class="admin-wrapper">
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="logo-text">ALPHA<span style="color:var(--primary)">ADMIN</span></div>
            </div>
            <nav class="nav-menu">
                <button class="nav-item active" onclick="openTab(event, 'aba-suporte')"><span>💬</span> Suporte</button>
                <button class="nav-item" onclick="openTab(event, 'aba-pedidos')"><span>🚀</span> Operação</button>
                <button class="nav-item" onclick="openTab(event, 'aba-cardapio')"><span>🍔</span> Cardápio</button>
                <button class="nav-item" onclick="openTab(event, 'aba-financeiro')"><span>💰</span> Financeiro</button>
                <button class="nav-item" onclick="openTab(event, 'aba-configuracao')"><span>⚙️</span> Ajustes</button>
            </nav>
        </aside>

        <main class="main-content">
            <header class="top-bar">
                <div class="page-info">
                    <h1 id="page-title">Painel de Controle</h1>
                    <p id="page-subtitle">Bem-vindo, Guilherme</p>
                </div>
                <div class="top-actions">
                    <button class="btn-action" style="background: var(--bg-card); color: var(--text-title);" onclick="toggleTheme()">🌓 Tema</button>
                    <button class="btn-action" onclick="location.reload()">🔄 Sincronizar</button>
                </div>
            </header>

            <div id="aba-suporte" class="tab-content active">
                <div class="chat-container">
                    <div class="chat-sidebar">
                        <div style="padding: 20px; font-weight: 800; color: var(--text-title); border-bottom: 1px solid var(--border-color);">Chats Ativos</div>
                        <div class="chat-list" id="lista-pedidos-chat">
                            <% let ativosNoChat = pedidos.filter(p => ['Pendente', 'Em Preparo', 'Pronto para Entrega', 'Em Rota'].includes(p.status)); 
                               ativosNoChat.forEach(p => { %>
                                 <div class="chat-user" id="chat-item-<%= p.id %>" onclick="selecionarChat('<%= p.id %>', '<%= p.cliente %>')">
                                    <div style="font-weight: 700; color: var(--text-title);">#<%= p.id %></div>
                                    <div style="font-size: 0.8rem;"><%= p.cliente %></div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                    <div class="chat-window">
                        <div class="chat-messages" id="chat-box">
                            <div style="text-align: center; margin: auto; opacity: 0.5;">
                                <h3>Selecione um atendimento</h3>
                                <p>Clique ao lado para carregar o histórico</p>
                            </div>
                        </div>
                        <div class="chat-input">
                            <input type="text" id="admin-msg" placeholder="Digite uma mensagem para o cliente...">
                            <button class="btn-action" onclick="enviarParaCliente()">Enviar</button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="aba-pedidos" class="tab-content">
                <div class="glass-card" style="background: var(--text-title); color: white;">
                    <h2 style="margin-bottom: 10px;">Monitor de Produção</h2>
                    <p style="opacity: 0.8; margin-bottom: 20px;">Abra a tela de comandas para a cozinha em uma nova guia.</p>
                    <a href="/operacao" target="_blank" class="btn-action" style="text-decoration: none; display: inline-block;">ABRIR KDS ➔</a>
                </div>
            </div>

            <div id="aba-cardapio" class="tab-content">
                <div class="glass-card">
                    <h3 style="color: var(--text-title); margin-bottom: 20px;">Gerenciar Categorias</h3>
                    <div id="container-gerenciador-produtos"></div>
                </div>
                <div class="glass-card">
                    <h3 style="color: var(--text-title); margin-bottom: 20px;">Gerenciar Complementos</h3>
                    <div id="container-gerenciador-adicionais"></div>
                </div>
            </div>

            <div id="aba-financeiro" class="tab-content">
                <% 
                    const dataAtual = new Date();
                    const hojeStr = dataAtual.toLocaleDateString('pt-BR');
                    const nomeMeses = ["Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho", "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"];
                    
                    let pedidosHoje = pedidos.filter(p => p.status === 'Concluído' && new Date(p.data || Date.now()).toLocaleDateString('pt-BR') === hojeStr);
                    let totalDia = pedidosHoje.reduce((acc, p) => acc + p.total, 0);
                    let entregasDia = pedidosHoje.length;
                %>
                <div class="stat-grid">
                    <div class="stat-card">
                        <span class="label">VENDAS HOJE</span>
                        <div class="value">R$ <%= totalDia.toFixed(2) %></div>
                        <small style="color: var(--accent); font-weight: 700;">+ <%= entregasDia %> pedidos</small>
                    </div>
                    <div class="stat-card">
                        <span class="label">ACUMULADO <%= nomeMeses[dataAtual.getMonth()].toUpperCase() %></span>
                        <div class="value">R$ <%= (config.vendasMes || 0).toFixed(2) %></div>
                    </div>
                </div>

                <div class="glass-card">
                    <h3 style="color: var(--text-title); margin-bottom: 20px;">💳 Configuração de Pagamento (PIX)</h3>
                    <form id="form-config-pix" style="max-width: 500px;">
                        <div style="margin-bottom: 15px;">
                            <label style="display:block; font-size: 0.8rem; font-weight: 700; margin-bottom: 5px;">Provedor</label>
                            <select id="conf-pixProvedor" style="width: 100%; padding: 12px; border-radius: 10px; border: 1px solid var(--border-color); background: var(--bg-body); color: var(--text-title);">
                                <option value="mercadopago" <%= config.pixProvedor === 'mercadopago' ? 'selected' : '' %>>Mercado Pago</option>
                                <option value="efi" <%= config.pixProvedor === 'efi' ? 'selected' : '' %>>EFI Bank</option>
                            </select>
                        </div>
                        <div style="margin-bottom: 20px;">
                            <label style="display:block; font-size: 0.8rem; font-weight: 700; margin-bottom: 5px;">Token de Acesso</label>
                            <input type="password" id="conf-pixToken" value="<%= config.pixToken || '' %>" style="width: 100%; padding: 12px; border-radius: 10px; border: 1px solid var(--border-color); background: var(--bg-body); color: var(--text-title);">
                        </div>
                        <button type="button" class="btn-action" style="width: 100%;" onclick="salvarConfigPix()">SALVAR CREDENCIAIS</button>
                    </form>
                </div>
            </div>

            <div id="aba-configuracao" class="tab-content">
                <div class="glass-card">
                    <h3 style="margin-bottom: 25px; color: var(--text-title);">Geral e Funcionamento</h3>
                    
                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 15px 0; border-bottom: 1px solid var(--border-color);">
                        <div>
                            <div style="font-weight: 700; color: var(--text-title);">Modo Manutenção</div>
                            <small>Bloqueia novos pedidos no site imediatamente.</small>
                        </div>
                        <label class="switch">
                            <input type="checkbox" id="conf-manutencao" onchange="salvarConfigSite()" <%= config.manutencao ? 'checked' : '' %>>
                            <span class="slider"></span>
                        </label>
                    </div>

                    <div style="padding: 20px 0; border-bottom: 1px solid var(--border-color);">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                            <div style="font-weight: 700; color: var(--text-title);">Raio de Atuação (Cidade)</div>
                            <label class="switch">
                                <input type="checkbox" id="conf-cidadeAtiva" onchange="toggleCamposCidade(); salvarConfigSite();" <%= config.cidadeAtiva ? 'checked' : '' %>>
                                <span class="slider"></span>
                            </label>
                        </div>
                        <div id="container-campos-cidade" style="display: <%= config.cidadeAtiva ? 'grid' : 'none' %>; grid-template-columns: 1fr 100px; gap: 10px;">
                            <input type="text" id="conf-cidadeNome" placeholder="Cidade" value="<%= config.cidadeNome || '' %>" style="padding: 12px; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-body); color: var(--text-title);">
                            <input type="text" id="conf-cidadeEstado" placeholder="UF" value="<%= config.cidadeEstado || '' %>" style="padding: 12px; border-radius: 8px; border: 1px solid var(--border-color); background: var(--bg-body); color: var(--text-title);">
                        </div>
                    </div>

                    <div style="padding: 20px 0; display: flex; justify-content: space-between; align-items: center;">
                        <div style="font-weight: 700; color: var(--text-title);">Horário de Funcionamento</div>
                        <button onclick="abrirModalHorarios()" class="btn-action" style="background: #edf2f7; color: #4a5568;">⚙️ EDITAR AGENDA</button>
                    </div>
                </div>
            </div>

            <div id="modalHorarios" class="modal">
                <div class="modal-content">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px;">
                        <h2 style="color: var(--text-title);">Definir Horários</h2>
                        <span onclick="fecharModalHorarios()" style="cursor:pointer; font-size: 1.5rem; font-weight: 800;">&times;</span>
                    </div>
                    <div id="lista-dias-funcionamento">
                        <% const diasSemana = ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'];
                           diasSemana.forEach((dia, i) => { 
                           const agendaDia = (config.agenda && config.agenda[i]) || { aberto: false, inicio: '18:00', fim: '23:00' }; %>
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid var(--border-color);">
                                <span style="font-weight: 700; width: 100px;"><%= dia %></span>
                                <div id="box-horario-<%= i %>" style="display: <%= agendaDia.aberto ? 'flex' : 'none' %>; gap: 8px;">
                                    <input type="time" class="input-inicio" value="<%= agendaDia.inicio %>" style="padding: 5px; border-radius: 5px; border: 1px solid var(--border-color);">
                                    <input type="time" class="input-fim" value="<%= agendaDia.fim %>" style="padding: 5px; border-radius: 5px; border: 1px solid var(--border-color);">
                                </div>
                                <label class="switch" style="transform: scale(0.85);">
                                    <input type="checkbox" class="check-dia" onchange="toggleDia(<%= i %>)" <%= agendaDia.aberto ? 'checked' : '' %>>
                                    <span class="slider"></span>
                                </label>
                            </div>
                        <% }) %>
                    </div>
                    <button onclick="salvarHorarios()" class="btn-action" style="width: 100%; margin-top: 25px; background: var(--accent); color: white;">SALVAR ALTERAÇÕES</button>
                </div>
            </div>

        </main>
    </div>

    <script>
        const socket = io();
        let pedidoAtivoId = null;

        function toggleTheme() {
            document.body.classList.toggle('dark-mode');
            const isDark = document.body.classList.contains('dark-mode');
            localStorage.setItem('admin-theme', isDark ? 'dark' : 'light');
        }

        if(localStorage.getItem('admin-theme') === 'dark') document.body.classList.add('dark-mode');

        function openTab(evt, tabName) {
            const contents = document.querySelectorAll(".tab-content");
            contents.forEach(c => c.classList.remove("active"));
            
            const btns = document.querySelectorAll(".nav-item");
            btns.forEach(b => b.classList.remove("active"));
            
            document.getElementById(tabName).classList.add("active");
            evt.currentTarget.classList.add("active");

            // Atualiza título da página dinamicamente
            const labels = {
                'aba-suporte': 'Central de Suporte',
                'aba-pedidos': 'Monitor de Operação',
                'aba-cardapio': 'Gestão de Cardápio',
                'aba-financeiro': 'Relatório Financeiro',
                'aba-configuracao': 'Configurações do Sistema'
            };
            document.getElementById('page-title').innerText = labels[tabName];
        }

        // Funções de Modal e UI
        function abrirModalHorarios() { document.getElementById('modalHorarios').style.display = 'block'; }
        function fecharModalHorarios() { document.getElementById('modalHorarios').style.display = 'none'; }
        function toggleDia(index) {
            const isChecked = document.querySelectorAll('.check-dia')[index].checked;
            document.getElementById(`box-horario-${index}`).style.display = isChecked ? 'flex' : 'none';
        }
        function toggleCamposCidade() {
            const isChecked = document.getElementById('conf-cidadeAtiva').checked;
            document.getElementById('container-campos-cidade').style.display = isChecked ? 'grid' : 'none';
        }

        // --- LÓGICA DE PERSISTÊNCIA (MANTIDA DO ORIGINAL) ---

        async function salvarHorarios() {
            const agenda = [];
            const checks = document.querySelectorAll('.check-dia');
            const incios = document.querySelectorAll('.input-inicio');
            const fins = document.querySelectorAll('.input-fim');
            checks.forEach((check, i) => {
                agenda.push({ aberto: check.checked, inicio: incios[i].value, fim: fins[i].value });
            });
            const res = await fetch('/update-horarios', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ agenda })
            });
            if (res.ok) { alert("✅ Agenda atualizada com sucesso!"); fecharModalHorarios(); }
        }

        async function salvarConfigSite() {
            const dados = {
                manutencao: document.getElementById('conf-manutencao').checked,
                cidadeAtiva: document.getElementById('conf-cidadeAtiva').checked,
                cidadeNome: document.getElementById('conf-cidadeNome').value,
                cidadeEstado: document.getElementById('conf-cidadeEstado').value
            };
            await fetch('/update-config-site', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dados)
            });
        }

        async function salvarConfigPix() {
            const dados = {
                pixProvedor: document.getElementById('conf-pixProvedor').value,
                pixToken: document.getElementById('conf-pixToken').value
            };
            const res = await fetch('/update-config-pix', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dados)
            });
            if (res.ok) alert("✅ Credenciais de pagamento atualizadas!");
        }

        // --- LÓGICA DE CHAT SOCKET.IO (MANTIDA DO ORIGINAL) ---

        function selecionarChat(id, cliente) {
            pedidoAtivoId = id;
            document.querySelectorAll('.chat-user').forEach(el => el.classList.remove('active', 'has-new'));
            const target = document.getElementById(`chat-item-${id}`);
            if(target) target.classList.add('active');
            socket.emit('join', id);
            socket.emit('lerMensagens', id);
        }

        socket.on('historico', (h) => {
            const box = document.getElementById('chat-box');
            box.innerHTML = '';
            h.forEach(renderizarMensagem);
        });

        socket.on('novaMensagem', (msg) => {
            if (msg.pedidoId === pedidoAtivoId) {
                renderizarMensagem(msg);
            } else {
                const item = document.getElementById(`chat-item-${msg.pedidoId}`);
                if(item) item.classList.add('has-new');
            }
        });

        function renderizarMensagem(msg) {
            const div = document.createElement('div');
            div.className = `bubble ${msg.usuario === 'Admin' ? 'admin' : 'cliente'}`;
            div.innerHTML = `<small style="display:block; font-size:10px; opacity:0.6; margin-bottom: 4px;">${msg.usuario}</small>${msg.texto}`;
            const box = document.getElementById('chat-box');
            box.appendChild(div);
            box.scrollTop = box.scrollHeight;
        }

        function enviarParaCliente() {
            const input = document.getElementById('admin-msg');
            if(!input.value || !pedidoAtivoId) return;
            socket.emit('enviarMensagem', { usuario: 'Admin', texto: input.value, pedidoId: pedidoAtivoId });
            input.value = '';
        }

        // Inicialização dos scripts externos
        document.addEventListener('DOMContentLoaded', () => {
            if(typeof renderizarPainelCategorias === "function") renderizarPainelCategorias('container-gerenciador-produtos');
            if(typeof renderizarPainelAdicionais === "function") renderizarPainelAdicionais('container-gerenciador-adicionais');
        });
    </script>

    <script src="/js/gerenciar-produtos.js"></script>
    <script src="/js/gerenciar-adicionais.js"></script>
</body>
</html>