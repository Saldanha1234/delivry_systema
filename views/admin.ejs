<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <title>Admin | Gestão Total</title>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/estrutura-produtos.js"></script>
    <style>
        :root { --primary: #ffca2c; --dark: #181818; --bg: #f0f2f5; --success: #2ecc71; --danger: #ff4757; --info: #1e90ff; }
        
        .admin-layout { display: flex; height: 100vh; overflow: hidden; background: var(--bg); font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .admin-main { flex: 1; overflow-y: auto; display: flex; flex-direction: column; }

        /* Sistema de Abas */
        .tab-container { display: flex; background: #fff; border-bottom: 2px solid #ddd; padding: 0 20px; gap: 10px; overflow-x: auto; white-space: nowrap; }
        .tab-btn { 
            padding: 15px 20px; border: none; background: none; cursor: pointer; 
            font-weight: bold; color: #666; transition: 0.3s; border-bottom: 3px solid transparent;
        }
        .tab-btn.active { color: var(--dark); border-bottom-color: var(--primary); }
        .tab-content { display: none; padding: 20px; animation: fadeIn 0.3s; }
        .tab-content.active { display: block; }

        /* Banner de Operação */
        .banner-operacao {
            background: var(--dark); color: white; padding: 40px; border-radius: 15px; margin-bottom: 20px;
            display: flex; justify-content: space-between; align-items: center; border-left: 10px solid var(--primary);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }
        .btn-abrir-kds {
            background: var(--primary); color: var(--dark); padding: 18px 35px; border-radius: 10px;
            text-decoration: none; font-weight: 900; font-size: 1.1rem; transition: 0.3s; box-shadow: 0 4px 0 #d1a31d;
        }

        /* Estilizações para o Tipo de Produto */
        .tipo-selector {
            grid-column: 1 / -1;
            background: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            border: 1px solid #dee2e6;
            margin-bottom: 10px;
        }

        .preview-montar {
            grid-column: 1 / -1;
            background: #fff3cd;
            border: 1px solid #ffeeba;
            padding: 15px;
            border-radius: 8px;
            display: none;
            color: #856404;
        }

        /* Tabelas */
        .admin-table { width: 100%; border-collapse: collapse; background: white; border-radius: 10px; overflow: hidden; margin-top: 15px; }
        .admin-table th { background: #eee; padding: 12px; text-align: left; font-size: 0.85rem; }
        .admin-table td { padding: 15px; border-bottom: 1px solid #eee; }
        .img-thumb { width: 50px; height: 50px; object-fit: cover; border-radius: 8px; }

        .btn-edit { background: #3498db; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; margin-right: 5px; }
        .btn-del { background: var(--danger); color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; }

        /* CHAT SIDEBAR */
        .admin-chat-sidebar { width: 350px; background: var(--dark); display: flex; flex-direction: column; border-left: 1px solid #333; }
        .chat-selector { background: #222; padding: 10px; border-bottom: 1px solid #444; max-height: 250px; overflow-y: auto; }
        .chat-item { padding: 12px; color: #bbb; cursor: pointer; border-radius: 6px; margin-bottom: 5px; font-size: 0.85rem; border: 1px solid transparent; }
        .chat-item.active { border-color: var(--primary); color: white; background: #333; }
        .chat-messages { flex: 1; overflow-y: auto; padding: 15px; display: flex; flex-direction: column; gap: 10px; background: #1a1a1a; }
        .msg { padding: 10px; border-radius: 8px; font-size: 0.85rem; max-width: 85%; color: white; }
        .msg.cliente { background: #333; align-self: flex-start; border-left: 3px solid var(--primary); }
        .msg.admin { background: var(--primary); color: #000; align-self: flex-end; }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body>

    <div class="admin-layout">
        <div class="admin-main">
            <nav class="admin-nav" style="background:#fff; padding:15px 25px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #ddd;">
                <div class="logo" style="color:var(--dark); font-weight:800; font-size: 1.3rem;">ADMIN<span style="color:var(--primary)">PANEL</span></div>
                <button onclick="location.reload()" style="padding: 8px 15px; cursor: pointer; border-radius: 6px; border: 1px solid #ddd; background: white; font-weight: bold;">🔄 Atualizar Dados</button>
            </nav>

            <div class="tab-container">
                <button class="tab-btn active" onclick="openTab(event, 'aba-pedidos')">📋 Gestão de Pedidos</button>
                <button class="tab-btn" onclick="openTab(event, 'aba-cardapio')">🍔 Cardápio</button>
                <button class="tab-btn" onclick="openTab(event, 'aba-financeiro')">💰 Financeiro & Pix</button>
            </div>

            <div id="aba-pedidos" class="tab-content active">
                <div class="banner-operacao">
                    <div>
                        <h1 style="margin:0; color:var(--primary); font-size: 2rem;">Cozinha e Entregas</h1>
                        <p style="margin:10px 0 0 0; opacity:0.9; font-size: 1.1rem;">O gerenciamento de pedidos é feito no Painel de Operação.</p>
                    </div>
                    <a href="/operacao" target="_blank" class="btn-abrir-kds">ABRIR PAINEL DE COMANDAS ➔</a>
                </div>
            </div>

            <div id="aba-cardapio" class="tab-content">
                <div class="manager-card" style="background:#fff; padding:25px; border-radius:12px;">
                    <h3 id="form-title">➕ Adicionar Novo Item</h3>
                    
                    <form id="form-produto" style="display:grid; grid-template-columns:1fr 1fr; gap:15px; margin-top: 20px;">
                        <input type="hidden" id="p-id"> 
                        
                        <div class="tipo-selector">
                            <label style="font-weight: bold; display: block; margin-bottom: 5px;">Tipo de Venda:</label>
                            <select id="p-tipo" onchange="toggleTipoEstrutura()" style="width: 100%; padding:10px; border-radius:5px; border:1px solid #ccc;">
                                <option value="simples">Produto Simples (Ex: Coca-Cola, Doce pronto)</option>
                                <option value="montar">Produto Montável (Ex: Copo de Açaí c/ Adicionais)</option>
                            </select>
                        </div>

                        <input type="text" id="p-nome" placeholder="Nome do Produto" required style="padding:12px; border-radius:8px; border:1px solid #ddd;">
                        <input type="number" id="p-preco" placeholder="Preço" step="0.01" required style="padding:12px; border-radius:8px; border:1px solid #ddd;">
                        
                        <select id="p-cat" style="padding:12px; border-radius:8px; border:1px solid #ddd;">
                            <option value="Açaí">Açaí</option>
                            <option value="Lanches">Lanches</option>
                            <option value="Promoção">Promoção</option>
                            <option value="Bebidas">Bebidas</option>
                        </select>

                        <div style="display:flex; flex-direction:column; gap:5px;">
                            <label style="font-size: 0.75rem; color: #666;">Foto do Produto:</label>
                            <input type="file" id="p-file" onchange="converterImagem()">
                        </div>
                        
                        <input type="hidden" id="p-img-data">
                        
                        <div id="preview-montar" class="preview-montar">
                            <strong>✨ Modo Personalização Ativado:</strong>
                            <p style="font-size: 0.85rem; margin: 5px 0;">Ao comprar este item, o cliente poderá escolher: 
                            <span id="txt-categorias" style="font-weight: bold;"></span>.</p>
                        </div>

                        <textarea id="p-desc" placeholder="Descrição curta (ingredientes, tamanho, etc)" style="grid-column: 1 / -1; padding:12px; border:1px solid #ddd; height: 80px; border-radius:8px;"></textarea>
                        
                        <div style="grid-column: 1 / -1; display:flex; gap:10px;">
                            <button type="button" onclick="salvarProduto()" id="btn-submit" style="flex:1; background:var(--success); color:#fff; padding:15px; border:none; border-radius:8px; cursor:pointer; font-weight:bold;">SALVAR PRODUTO</button>
                            <button type="button" onclick="limparForm()" id="btn-cancel" style="display:none; background:#888; color:#fff; padding:15px; border:none; border-radius:8px; cursor:pointer;">CANCELAR</button>
                        </div>
                    </form>

                    <table class="admin-table">
                        <thead>
                            <tr><th>Foto</th><th>Produto</th><th>Tipo</th><th>Preço</th><th>Ações</th></tr>
                        </thead>
                        <tbody>
                            <% produtos.forEach(p => { %>
                                <tr>
                                    <td><img src="<%= p.img %>" class="img-thumb"></td>
                                    <td><strong><%= p.nome %></strong><br><small><%= p.categoria %></small></td>
                                    <td>
                                        <span style="background:#eee; padding:4px 10px; border-radius:20px; font-size:10px; font-weight:bold;">
                                            <%= p.tipo === 'montar' ? '🛠️ MONTÁVEL' : '📦 SIMPLES' %>
                                        </span>
                                    </td>
                                    <td>R$ <%= p.preco.toFixed(2) %></td>
                                    <td>
                                        <button class="btn-edit" onclick='prepararEdicao(<%- JSON.stringify(p) %>)'>EDITAR</button>
                                        <button class="btn-del" onclick="excluirProduto('<%= p._id %>')">EXCLUIR</button>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div id="aba-financeiro" class="tab-content">
                <p>Módulo financeiro e configuração de PIX.</p>
            </div>

        </div>

        <aside class="admin-chat-sidebar">
            <div class="chat-header" style="color:white; padding:15px; font-weight:bold; border-bottom:1px solid #333;">💬 SUPORTE AOS CLIENTES</div>
            <div class="chat-selector" id="lista-pedidos-chat">
                <% pedidos.filter(p => p.status !== 'Concluído').forEach(p => { %>
                    <div class="chat-item" id="chat-item-<%= p.id %>" onclick="selecionarChat('<%= p.id %>', '<%= p.cliente %>')">
                        Pedido #<%= p.id %> - <%= p.cliente %>
                    </div>
                <% }) %>
            </div>
            <div class="chat-messages" id="chat-box"></div>
            <div class="chat-input-area" style="padding:15px; display:flex; gap:5px; border-top:1px solid #333;">
                <input type="text" id="admin-msg" placeholder="Responder..." style="flex:1; padding:10px; border-radius:6px; border:none; background:#222; color:#fff;">
                <button onclick="enviarParaCliente()" style="background:var(--primary); border:none; padding:10px 15px; border-radius:6px; cursor:pointer; font-weight:bold;">➤</button>
            </div>
        </aside>
    </div>

    <script>
        const socket = io();
        let imagemBase64 = "";
        let pedidoAtivoId = null;

        // Funções de Aba
        function openTab(evt, tabName) {
            const contents = document.getElementsByClassName("tab-content");
            for (let i = 0; i < contents.length; i++) contents[i].classList.remove("active");
            const btns = document.getElementsByClassName("tab-btn");
            for (let i = 0; i < btns.length; i++) btns[i].classList.remove("active");
            document.getElementById(tabName).classList.add("active");
            if(evt) evt.currentTarget.classList.add("active");
        }

        // ALTERNAR TIPO DE PRODUTO (UI)
        function toggleTipoEstrutura() {
            const tipo = document.getElementById('p-tipo').value;
            const areaPreview = document.getElementById('preview-montar');
            const txtCat = document.getElementById('txt-categorias');

            if(tipo === 'montar') {
                areaPreview.style.display = 'block';
                // Puxa os nomes das categorias do arquivo estrutura-produtos.js injetado no head
                if (typeof ConfigEstrutura !== 'undefined') {
                    txtCat.innerText = ConfigEstrutura.categorias.map(c => c.nome).join(', ');
                } else {
                    txtCat.innerText = "Configurações de montagem";
                }
            } else {
                areaPreview.style.display = 'none';
            }
        }

        function converterImagem() {
            const file = document.getElementById('p-file').files[0];
            const reader = new FileReader();
            reader.onloadend = () => { 
                imagemBase64 = reader.result; 
                document.getElementById('p-img-data').value = reader.result; 
            }
            if (file) reader.readAsDataURL(file);
        }

        async function salvarProduto() {
            const id = document.getElementById('p-id').value;
            const dados = {
                nome: document.getElementById('p-nome').value,
                preco: parseFloat(document.getElementById('p-preco').value),
                categoria: document.getElementById('p-cat').value,
                tipo: document.getElementById('p-tipo').value, 
                desc: document.getElementById('p-desc').value,
                img: imagemBase64 || document.getElementById('p-img-data').value
            };

            if(!dados.nome || isNaN(dados.preco)) return alert("Preencha Nome e Preço corretamente!");

            const res = await fetch(id ? `/edit-produto/${id}` : '/add-produto', {
                method: id ? 'PUT' : 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify(dados)
            });

            if(res.ok) {
                alert("Produto salvo com sucesso!");
                location.reload();
            } else {
                alert("Erro ao salvar produto no servidor.");
            }
        }

        function prepararEdicao(p) {
            openTab(null, 'aba-cardapio');
            document.getElementById('form-title').innerText = "📝 Editando: " + p.nome;
            document.getElementById('p-id').value = p._id;
            document.getElementById('p-nome').value = p.nome;
            document.getElementById('p-preco').value = p.preco;
            document.getElementById('p-cat').value = p.categoria;
            document.getElementById('p-tipo').value = p.tipo || 'simples'; 
            document.getElementById('p-desc').value = p.desc || "";
            document.getElementById('p-img-data').value = p.img;
            
            toggleTipoEstrutura(); 

            document.getElementById('btn-submit').innerText = "ATUALIZAR PRODUTO";
            document.getElementById('btn-submit').style.background = "#3498db";
            document.getElementById('btn-cancel').style.display = "block";
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        async function excluirProduto(id) {
            if(confirm("Deseja realmente excluir este item?")) {
                const res = await fetch(`/delete-produto/${id}`, { method: 'DELETE' });
                if(res.ok) location.reload();
            }
        }

        // LÓGICA DE CHAT
        function selecionarChat(id, cliente) {
            pedidoAtivoId = id;
            document.querySelectorAll('.chat-item').forEach(el => el.classList.remove('active'));
            const item = document.getElementById(`chat-item-${id}`);
            if(item) item.classList.add('active');
            
            socket.emit('join', id);
            socket.emit('lerMensagens', id);
        }

        socket.on('historico', (h) => {
            const box = document.getElementById('chat-box');
            box.innerHTML = '';
            h.forEach(renderizarMensagem);
        });

        socket.on('novaMensagem', (msg) => {
            if (msg.pedidoId === pedidoAtivoId) renderizarMensagem(msg);
        });

        function renderizarMensagem(msg) {
            const div = document.createElement('div');
            div.className = `msg ${msg.usuario === 'Admin' ? 'admin' : 'cliente'}`;
            div.innerHTML = `<span style="font-size:10px; opacity:0.7">${msg.usuario} - ${msg.hora}</span><p style="margin:2px 0">${msg.texto}</p>`;
            const box = document.getElementById('chat-box');
            box.appendChild(div);
            box.scrollTop = box.scrollHeight;
        }

        function enviarParaCliente() {
            const input = document.getElementById('admin-msg');
            if(!input.value || !pedidoAtivoId) return;
            socket.emit('enviarMensagem', { usuario: 'Admin', texto: input.value, pedidoId: pedidoAtivoId });
            input.value = '';
        }

        function limparForm() { location.reload(); }
        
        // Listener para tecla Enter no chat
        document.getElementById('admin-msg').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') enviarParaCliente();
        });
    </script>
</body>
</html>