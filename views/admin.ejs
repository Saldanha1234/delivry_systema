<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    
    <link rel="stylesheet" href="/admin.personalizacao.css/admin.css">
    
    <title>Admin | Gestão Total Alpha</title>
    <script src="/socket.io/socket.io.js"></script>
</head>
<body class="dark-mode">

    <div class="admin-layout">
        <div class="admin-main">
            <nav class="admin-nav">
                <div class="logo" style="font-weight:900; font-size: 1.3rem;">Açai<span style="color:var(--primary)">Roxinho</span></div>
                <div style="display: flex; gap: 5px;">
                    <button id="theme-toggle" class="btn-theme" onclick="toggleTheme()">☀️ Claro</button>
                    <button onclick="location.reload()" class="btn-theme">🔄 Sync</button>
                </div>
            </nav>

            <div id="aba-suporte" class="tab-content active">
                <div class="suporte-container">
                    <div class="chat-sidebar-list">
                        <div class="chat-header-title">
                            <svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-1.99.9-1.99 2L2 22l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 9h12v2H6V9zm8 5H6v-2h8v2zm4-6H6V6h12v2z"/></svg>
                            Suporte em tempo real
                        </div>
                        <div class="chat-selector" id="lista-pedidos-chat">
                            <% let ativosNoChat = pedidos.filter(p => ['Pendente', 'Em Preparo', 'Pronto para Entrega', 'Em Rota'].includes(p.status)); 
                               ativosNoChat.forEach(p => { 
                               let inicial = p.cliente ? p.cliente.charAt(0).toUpperCase() : '?'; %>
                                 <div class="chat-item" id="chat-item-<%= p.id %>" onclick="selecionarChat('<%= p.id %>', '<%= p.cliente %>')">
                                    <div class="avatar-circle"><%= inicial %></div>
                                    <span class="cliente-nome-label"><%= p.cliente %></span>
                                    <span class="cliente-pedido-label">#<%= p.id %></span>
                                 </div>
                            <% }) %>
                        </div>
                    </div>
                    <div class="chat-main-area">
                        <div class="chat-messages" id="chat-box">
                            <div style="text-align:center; margin-top:50px; color:#444;">
                                <h3>Selecione um cliente para conversar</h3>
                            </div>
                        </div>
                        <div class="chat-input-area">
                            <input type="text" id="admin-msg" placeholder="Sua resposta...">
                            <button onclick="enviarParaCliente()">➤</button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="aba-pedidos" class="tab-content">
                <div class="banner-operacao">
                    <div>
                        <h2 style="margin:0; font-size: 1.2rem;">Painel de Produção</h2>
                        <p style="margin:5px 0 0 0; opacity:0.8; font-size: 0.8rem;">Gerencie a cozinha em tempo real.</p>
                    </div>
                    <a href="/operacao" target="_blank" class="btn-abrir-kds">ABRIR COMANDAS (KDS) ➔</a>
                </div>
            </div>

            <div id="aba-cardapio" class="tab-content">
                <div class="card-box">
                    <div id="container-gerenciador-produtos"></div>
                </div>
                <div class="card-box">
                    <div id="container-gerenciador-adicionais"></div>
                </div>
            </div>

            <div id="aba-financeiro" class="tab-content">
                <% 
                    const dataAtual = new Date();
                    const hojeStr = dataAtual.toLocaleDateString('pt-BR');
                    const nomeMeses = ["Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho", "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"];
                    
                    let pedidosHoje = pedidos.filter(p => p.status === 'Concluído' && new Date(p.data || Date.now()).toLocaleDateString('pt-BR') === hojeStr);
                    let totalDia = pedidosHoje.reduce((acc, p) => acc + p.total, 0);
                    let entregasDia = pedidosHoje.length;
                %>
                <div class="finance-grid">
                    <div class="stat-card" style="border-left-color: #2ecc71;">
                        <h4>💰 Vendas de Hoje</h4>
                        <div class="value">R$ <%= totalDia.toFixed(2) %></div>
                        <span class="date-label"><%= hojeStr %></span>
                    </div>
                    <div class="stat-card" style="border-left-color: #3498db;">
                        <h4>📦 Concluídos</h4>
                        <div class="value"><%= entregasDia %></div>
                        <span class="date-label">Hoje</span>
                    </div>
                    <div class="stat-card" style="border-left-color: #8a2be2;">
                        <h4>📊 Acumulado (<%= nomeMeses[dataAtual.getMonth()] %>)</h4>
                        <div class="value">R$ <%= (config.vendasMes || 0).toFixed(2) %></div>
                        <span class="date-label">Total do mês</span>
                    </div>
                </div>

                <div class="card-box">
                    <h3 style="margin-top:0; font-size: 1rem;">⚡ Configuração de Pix</h3>
                    <form id="form-config-pix" style="display:grid; gap:15px; max-width: 500px;">
                        <div>
                            <label style="display:block; font-size:0.75rem; font-weight:bold; margin-bottom:5px;">Provedor</label>
                            <select id="conf-pixProvedor" style="width:100%; padding:10px; border-radius:6px; background: #1a1a1a; color: #fff; border: 1px solid #333;">
                                <option value="mercadopago" <%= config.pixProvedor === 'mercadopago' ? 'selected' : '' %>>Mercado Pago</option>
                                <option value="efi" <%= config.pixProvedor === 'efi' ? 'selected' : '' %>>EFI Bank</option>
                            </select>
                        </div>
                        <div>
                            <label style="display:block; font-size:0.75rem; font-weight:bold; margin-bottom:5px;">Chave de API / Token</label>
                            <input type="password" id="conf-pixToken" value="<%= config.pixToken || '' %>" style="width:100%; padding:10px; border-radius:6px; background: #1a1a1a; color: #fff; border: 1px solid #333;">
                        </div>
                        <button type="button" onclick="salvarConfigPix()" style="background:#8a2be2; color:white; padding:12px; border:none; border-radius:8px; cursor:pointer; font-weight:bold;">ATUALIZAR CREDENCIAIS</button>
                    </form>
                </div>
            </div>

            <div id="aba-configuracao" class="tab-content">
                <div class="card-box">
                    <h3 style="margin-top:0; font-size: 1rem;">⚙️ Configurações Gerais</h3>
                    
                    <div style="display:flex; justify-content:space-between; align-items:center; padding:15px 0; border-bottom:1px solid #222;">
                        <div>
                            <strong style="font-size: 0.9rem;">Modo Manutenção</strong><br>
                            <small style="color:#888;">Forçar fechamento do site.</small>
                        </div>
                        <label class="switch">
                            <input type="checkbox" id="conf-manutencao" onchange="salvarConfigSite()" <%= config.manutencao ? 'checked' : '' %>>
                            <span class="slider"></span>
                        </label>
                    </div>

                    <div style="padding:15px 0; border-bottom:1px solid #222;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                            <strong style="font-size: 0.9rem;">Limitar por Cidade</strong>
                            <label class="switch">
                                <input type="checkbox" id="conf-cidadeAtiva" onchange="toggleCamposCidade(); salvarConfigSite();" <%= config.cidadeAtiva ? 'checked' : '' %>>
                                <span class="slider"></span>
                            </label>
                        </div>
                        <div id="container-campos-cidade" style="display: <%= config.cidadeAtiva ? 'grid' : 'none' %>; grid-template-columns: 1fr 80px; gap:10px;">
                            <input type="text" id="conf-cidadeNome" placeholder="Cidade" value="<%= config.cidadeNome || '' %>" style="padding:8px; background: #1a1a1a; color: #fff; border: 1px solid #333;">
                            <input type="text" id="conf-cidadeEstado" placeholder="UF" value="<%= config.cidadeEstado || '' %>" style="padding:8px; background: #1a1a1a; color: #fff; border: 1px solid #333;">
                        </div>
                    </div>

                    <div style="padding:15px 0; display:flex; justify-content:space-between; align-items:center;">
                        <strong style="font-size: 0.9rem;">Horários de Funcionamento</strong>
                        <button onclick="abrirModalHorarios()" style="background:#8a2be2; color:white; padding:8px 12px; border:none; border-radius:6px; cursor:pointer; font-weight:bold;">DEFINIR AGENDA</button>
                    </div>
                </div>
            </div>

            <div id="modalHorarios" class="modal">
                <div class="modal-content">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                        <h2 style="margin:0; font-size: 1.2rem;">Horários</h2>
                        <span onclick="fecharModalHorarios()" style="cursor:pointer; font-size: 2rem;">&times;</span>
                    </div>
                    <div id="lista-dias-funcionamento">
                        <% const diasSemana = ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'];
                           diasSemana.forEach((dia, i) => { 
                           const agendaDia = (config.agenda && config.agenda[i]) || { aberto: false, inicio: '18:00', fim: '23:00' }; %>
                             <div class="dia-config" style="display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid #222;">
                                <span style="font-weight: bold; width: 80px; font-size: 0.85rem;"><%= dia %></span>
                                <div class="horarios-inputs" id="box-horario-<%= i %>" style="display: <%= agendaDia.aberto ? 'flex' : 'none' %>; gap: 5px;">
                                    <input type="time" class="input-inicio" value="<%= agendaDia.inicio %>" style="padding: 5px; background: #1a1a1a; color: #fff; border: 1px solid #333;">
                                    <input type="time" class="input-fim" value="<%= agendaDia.fim %>" style="padding: 5px; background: #1a1a1a; color: #fff; border: 1px solid #333;">
                                </div>
                                <label class="switch" style="transform: scale(0.8);">
                                    <input type="checkbox" class="check-dia" onchange="toggleDia(<%= i %>)" <%= agendaDia.aberto ? 'checked' : '' %>>
                                    <span class="slider"></span>
                                </label>
                            </div>
                        <% }) %>
                    </div>
                    <button onclick="salvarHorarios()" style="width: 100%; background: #2ecc71; color: white; border: none; padding: 15px; border-radius: 10px; font-weight: bold; margin-top: 20px; cursor:pointer;">SALVAR ALTERAÇÕES</button>
                </div>
            </div>
        </div>

        <div class="tab-container">
            <button class="tab-btn active" onclick="openTab(event, 'aba-suporte')">
                <svg viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/></svg>
                Chat
            </button>
            <button class="tab-btn" onclick="openTab(event, 'aba-pedidos')">
                <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14h-4v-4h4v4zm0-6h-4V7h4v4z"/></svg>
                Produção
            </button>
            <button class="tab-btn" onclick="openTab(event, 'aba-cardapio')">
                <svg viewBox="0 0 24 24"><path d="M11 9H9V2H7v7H5V2H3v7c0 2.12 1.66 3.84 3.75 3.97V22h2.5v-9.03C11.34 12.84 13 11.12 13 9V2h-2v7zm5-3v8h2.5v8H21V2c-2.76 0-5 2.24-5 4z"/></svg>
                Cardápio
            </button>
            <button class="tab-btn" onclick="openTab(event, 'aba-financeiro')">
                <svg viewBox="0 0 24 24"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
                Grana
            </button>
            <button class="tab-btn" onclick="openTab(event, 'aba-configuracao')">
                <svg viewBox="0 0 24 24"><path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58z"/></svg>
                Ajustes
            </button>
        </div>
    </div>

    <script>
        const socket = io();
        let pedidoAtivoId = null;

        // Controle de Tema
        function toggleTheme() {
            const body = document.body;
            const btn = document.getElementById('theme-toggle');
            body.classList.toggle('dark-mode');
            if(body.classList.contains('dark-mode')) {
                btn.innerText = "☀️ Claro";
                localStorage.setItem('admin-theme', 'dark');
            } else {
                btn.innerText = "🌙 Noturno";
                localStorage.setItem('admin-theme', 'light');
            }
        }

        if(localStorage.getItem('admin-theme') === 'dark' || !localStorage.getItem('admin-theme')) {
            document.body.classList.add('dark-mode');
            const btn = document.getElementById('theme-toggle');
            if(btn) btn.innerText = "☀️ Claro";
        }

        // Inicialização de scripts externos de gerenciamento
        document.addEventListener('DOMContentLoaded', () => {
            if(typeof renderizarPainelCategorias === "function") renderizarPainelCategorias('container-gerenciador-produtos');
            if(typeof renderizarPainelAdicionais === "function") renderizarPainelAdicionais('container-gerenciador-adicionais');
        });

        // Alternância de Abas (Tabs)
        function openTab(evt, tabName) {
            const contents = document.getElementsByClassName("tab-content");
            for (let i = 0; i < contents.length; i++) contents[i].classList.remove("active");
            const btns = document.getElementsByClassName("tab-btn");
            for (let i = 0; i < btns.length; i++) btns[i].classList.remove("active");
            document.getElementById(tabName).classList.add("active");
            if(evt) evt.currentTarget.classList.add("active");
        }

        // Funções do Modal de Horários
        function abrirModalHorarios() { document.getElementById('modalHorarios').style.display = 'block'; }
        function fecharModalHorarios() { document.getElementById('modalHorarios').style.display = 'none'; }
        function toggleDia(index) {
            const isChecked = document.querySelectorAll('.check-dia')[index].checked;
            document.getElementById(`box-horario-${index}`).style.display = isChecked ? 'flex' : 'none';
        }
        function toggleCamposCidade() {
            const isChecked = document.getElementById('conf-cidadeAtiva').checked;
            document.getElementById('container-campos-cidade').style.display = isChecked ? 'grid' : 'none';
        }

        async function salvarHorarios() {
            const agenda = [];
            const checks = document.querySelectorAll('.check-dia');
            const incios = document.querySelectorAll('.input-inicio');
            const fins = document.querySelectorAll('.input-fim');
            checks.forEach((check, i) => {
                agenda.push({ aberto: check.checked, inicio: incios[i].value, fim: fins[i].value });
            });
            const res = await fetch('/update-horarios', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ agenda })
            });
            if (res.ok) { alert("✅ Horários atualizados!"); fecharModalHorarios(); }
        }

        // Salvamento de Configurações Gerais
        async function salvarConfigSite() {
            const dados = {
                manutencao: document.getElementById('conf-manutencao').checked,
                cidadeAtiva: document.getElementById('conf-cidadeAtiva').checked,
                cidadeNome: document.getElementById('conf-cidadeNome').value,
                cidadeEstado: document.getElementById('conf-cidadeEstado').value
            };
            await fetch('/update-config-site', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dados)
            });
        }

        async function salvarConfigPix() {
            const dados = {
                pixProvedor: document.getElementById('conf-pixProvedor').value,
                pixToken: document.getElementById('conf-pixToken').value
            };
            const res = await fetch('/update-config-pix', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dados)
            });
            if (res.ok) alert("✅ Pix configurado com sucesso!");
        }

        // Lógica de Chat via Socket.io
        function selecionarChat(id, cliente) {
            pedidoAtivoId = id;
            document.querySelectorAll('.chat-item').forEach(el => el.classList.remove('active', 'has-new'));
            const target = document.getElementById(`chat-item-${id}`);
            if(target) target.classList.add('active');
            socket.emit('join', id);
            socket.emit('lerMensagens', id);
        }

        socket.on('historico', (h) => {
            const box = document.getElementById('chat-box');
            box.innerHTML = '';
            h.forEach(renderizarMensagem);
        });

        socket.on('novaMensagem', (msg) => {
            if (msg.pedidoId === pedidoAtivoId) {
                renderizarMensagem(msg);
            } else {
                const item = document.getElementById(`chat-item-${msg.pedidoId}`);
                if(item) item.classList.add('has-new');
            }
        });

        function renderizarMensagem(msg) {
            const div = document.createElement('div');
            div.className = `msg ${msg.usuario === 'Admin' ? 'admin' : 'cliente'}`;
            const agora = new Date();
            const horaFormatada = agora.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });

            div.innerHTML = `
                <small style="display:block; font-size:10px; opacity:0.6;">${msg.usuario}</small>
                ${msg.texto}
                <span class="msg-time">${horaFormatada}</span>
            `;
            
            const box = document.getElementById('chat-box');
            box.appendChild(div);
            box.scrollTop = box.scrollHeight;
        }

        function enviarParaCliente() {
            const input = document.getElementById('admin-msg');
            if(!input.value || !pedidoAtivoId) return;
            socket.emit('enviarMensagem', { usuario: 'Admin', texto: input.value, pedidoId: pedidoAtivoId });
            input.value = '';
        }
    </script>

    <script src="/js/gerenciar-produtos.js"></script>
    <script src="/js/gerenciar-adicionais.js"></script>
</body>
</html>