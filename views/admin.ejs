<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <title>Admin | Gestão Total</title>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        :root { 
            --primary: #ffca2c; 
            --dark: #181818; 
            --bg: #f0f2f5; 
            --success: #2ecc71; 
            --danger: #ff4757; 
            --info: #1e90ff;
            --bank-card: #252525;
            --text-muted: #888;
        }
        
        * { box-sizing: border-box; }
        body, html { margin: 0; padding: 0; }

        .admin-layout { display: flex; flex-direction: column; height: 100vh; background: var(--bg); font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .admin-main { flex: 1; overflow-y: auto; display: flex; flex-direction: column; }

        /* --- Sistema de Abas --- */
        .tab-container { 
            display: flex; 
            background: #fff; 
            border-bottom: 2px solid #ddd; 
            padding: 0 10px; 
            gap: 5px; 
            overflow-x: auto; 
            white-space: nowrap; 
            position: sticky; 
            top: 0; 
            z-index: 100;
            scrollbar-width: none; 
        }
        .tab-container::-webkit-scrollbar { display: none; }

        .tab-btn { 
            padding: 15px 18px; 
            border: none; 
            background: none; 
            cursor: pointer; 
            font-weight: bold; 
            color: #666; 
            transition: 0.3s; 
            border-bottom: 3px solid transparent;
            font-size: 0.9rem;
            flex-shrink: 0; 
        }
        .tab-btn.active { color: var(--dark); border-bottom-color: var(--primary); }

        .tab-content { display: none; padding: 15px; animation: fadeIn 0.3s; }
        .tab-content.active { display: block; }

        /* --- Interface de Banco (Aba Financeiro) --- */
        .bank-container { max-width: 1000px; margin: 0 auto; color: #fff; background: #1a1a1a; border-radius: 20px; padding: 25px; box-shadow: 0 10px 30px rgba(0,0,0,0.2); }
        .bank-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
        
        .balance-card { background: var(--bank-card); padding: 30px; border-radius: 20px; border-left: 5px solid var(--primary); margin-bottom: 25px; }
        .balance-label { color: var(--text-muted); font-size: 0.9rem; text-transform: uppercase; }
        .balance-value { font-size: 2.5rem; font-weight: 800; margin: 10px 0; color: #fff; }
        
        .bank-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 20px; }
        .transaction-list { background: var(--bank-card); padding: 20px; border-radius: 20px; }
        .transaction-item { display: flex; justify-content: space-between; align-items: center; padding: 15px; border-bottom: 1px solid #333; }
        .transaction-info strong { display: block; color: #fff; }
        .transaction-info small { color: var(--text-muted); }
        .transaction-amount { font-weight: bold; color: var(--success); }

        .pix-config-box { background: #333; padding: 20px; border-radius: 20px; height: fit-content; }
        .pix-config-box h3 { margin-top: 0; font-size: 1rem; color: var(--primary); }
        .bank-input { width: 100%; background: #222; border: 1px solid #444; color: #fff; padding: 12px; border-radius: 8px; margin-bottom: 15px; }
        .btn-bank-save { width: 100%; background: var(--primary); color: #000; border: none; padding: 12px; border-radius: 8px; font-weight: 900; cursor: pointer; }

        /* --- Suporte & Outros --- */
        .banner-operacao { background: var(--dark); color: white; padding: 25px; border-radius: 12px; margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; border-left: 10px solid var(--primary); }
        .suporte-container { display: flex; height: 75vh; background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        .chat-sidebar-list { width: 280px; background: #f8f9fa; border-right: 1px solid #ddd; display: flex; flex-direction: column; }
        .chat-main-area { flex: 1; display: flex; flex-direction: column; background: #fff; }
        .chat-messages { flex: 1; overflow-y: auto; padding: 15px; display: flex; flex-direction: column; gap: 10px; background: #f0f2f5; }
        .msg.admin { background: var(--primary); color: #000; align-self: flex-end; }
        .msg.cliente { background: white; align-self: flex-start; }
        
        /* Modal e Switches */
        .switch { position: relative; display: inline-block; width: 50px; height: 24px; }
        .switch input { opacity: 0; }
        .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #ccc; transition: .4s; border-radius: 24px; }
        .slider:before { position: absolute; content: ""; height: 18px; width: 18px; left: 3px; bottom: 3px; background-color: white; transition: .4s; border-radius: 50%; }
        input:checked + .slider { background-color: var(--success); }
        input:checked + .slider:before { transform: translateX(26px); }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        @media (max-width: 768px) {
            .bank-grid { grid-template-columns: 1fr; }
            .suporte-container { flex-direction: column; }
            .chat-sidebar-list { width: 100%; height: 150px; }
        }
    </style>
</head>
<body>

    <div class="admin-layout">
        <div class="admin-main">
            <nav class="admin-nav" style="background:#fff; padding:15px 25px; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #ddd;">
                <div class="logo" style="color:var(--dark); font-weight:800; font-size: 1.2rem;">ADMIN<span style="color:var(--primary)">PANEL</span></div>
                <button onclick="location.reload()" style="padding: 6px 12px; cursor: pointer; border-radius: 6px; border: 1px solid #ddd; background: white; font-weight: bold;">🔄 Atualizar</button>
            </nav>

            <div class="tab-container">
                <button class="tab-btn active" onclick="openTab(event, 'aba-suporte')">💬 Suporte</button>
                <button class="tab-btn" onclick="openTab(event, 'aba-pedidos')">📋 Pedidos</button>
                <button class="tab-btn" onclick="openTab(event, 'aba-cardapio')">🍔 Cardápio</button>
                <button class="tab-btn" onclick="openTab(event, 'aba-financeiro')">💰 Banco & Pix</button>
                <button class="tab-btn" onclick="openTab(event, 'aba-configuracao')">⚙️ Config</button>
            </div>

            <div id="aba-financeiro" class="tab-content">
                <div class="bank-container">
                    <div class="bank-header">
                        <div>
                            <h2 style="margin:0">Meu Banco</h2>
                            <small style="color:var(--text-muted)">Gestão financeira do seu delivery</small>
                        </div>
                        <div style="text-align: right">
                            <span style="display:block; font-size:0.8rem; color:var(--primary)">STATUS DA CONTA</span>
                            <strong>OPERACIONAL</strong>
                        </div>
                    </div>

                    <% 
                        let totalMesAcumulado = config.vendasMes || 0;
                        let ultimosPedidos = pedidos.filter(p => p.status === 'Concluído').slice(-5).reverse();
                    %>

                    <div class="balance-card">
                        <div class="balance-label">Saldo Acumulado (Mês)</div>
                        <div class="balance-value">R$ <%= totalMesAcumulado.toFixed(2) %></div>
                        <div style="font-size: 0.8rem; color: var(--success)">● Recebimentos processados via PIX/Cartão</div>
                    </div>

                    <div class="bank-grid">
                        <div class="transaction-list">
                            <h3 style="font-size: 1rem; margin-bottom: 20px;">Extrato Recente</h3>
                            <% if(ultimosPedidos.length > 0) { %>
                                <% ultimosPedidos.forEach(p => { %>
                                    <div class="transaction-item">
                                        <div class="transaction-info">
                                            <strong>Pedido #<%= p.id %></strong>
                                            <small><%= p.cliente %></small>
                                        </div>
                                        <div class="transaction-amount">+ R$ <%= p.total.toFixed(2) %></div>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <p style="color: #666; text-align: center; padding: 20px;">Nenhuma transação recente.</p>
                            <% } %>
                        </div>

                        <div class="pix-config-box">
                            <h3>Configuração de Recebimento</h3>
                            <form id="form-config-pix">
                                <label style="font-size: 0.7rem; color: #999;">PROVEDOR</label>
                                <select id="conf-pixProvedor" class="bank-input">
                                    <option value="mercadopago" <%= config.pixProvedor === 'mercadopago' ? 'selected' : '' %>>Mercado Pago</option>
                                    <option value="efi" <%= config.pixProvedor === 'efi' ? 'selected' : '' %>>EFI Bank</option>
                                </select>

                                <label style="font-size: 0.7rem; color: #999;">ACCESS TOKEN</label>
                                <input type="password" id="conf-pixToken" class="bank-input" value="<%= config.pixToken || '' %>" placeholder="Chave Privada">
                                
                                <button type="button" onclick="salvarConfigPix()" class="btn-bank-save">ATUALIZAR CHAVES</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <div id="aba-suporte" class="tab-content active">
                <div class="suporte-container">
                    <div class="chat-sidebar-list">
                        <div style="padding:12px; font-weight:bold; background:#eee; font-size:0.75rem;">PEDIDOS ATIVOS</div>
                        <div class="chat-selector" id="lista-pedidos-chat">
                            <% let ativosNoChat = pedidos.filter(p => ['Pendente', 'Em Preparo', 'Pronto para Entrega', 'Em Rota'].includes(p.status)); 
                               ativosNoChat.forEach(p => { %>
                                 <div class="chat-item" id="chat-item-<%= p.id %>" onclick="selecionarChat('<%= p.id %>', '<%= p.cliente %>')" style="padding:10px; border-bottom:1px solid #eee; cursor:pointer;">
                                    <strong>#<%= p.id %></strong> - <small><%= p.cliente %></small>
                                 </div>
                            <% }) %>
                        </div>
                    </div>
                    <div class="chat-main-area">
                        <div class="chat-messages" id="chat-box"></div>
                        <div class="chat-input-area" style="padding:10px; display:flex; gap:5px;">
                            <input type="text" id="admin-msg" style="flex:1; padding:8px;" placeholder="Mensagem...">
                            <button onclick="enviarParaCliente()" style="background:var(--dark); color:#fff; border:none; padding:10px;">Enviar</button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="aba-configuracao" class="tab-content">
                <div style="background:#fff; padding:20px; border-radius:12px;">
                    <h3>Configurações Gerais</h3>
                    <div style="display:flex; justify-content:space-between; margin-bottom:15px;">
                        <span>Modo Manutenção</span>
                        <label class="switch">
                            <input type="checkbox" id="conf-manutencao" onchange="salvarConfigSite()" <%= config.manutencao ? 'checked' : '' %>>
                            <span class="slider"></span>
                        </label>
                    </div>
                    <input type="text" id="conf-nomeSite" value="<%= config.nomeSite %>" style="width:100%; padding:10px; margin-bottom:10px;">
                    <button onclick="salvarConfigSite()" class="btn-bank-save" style="background:var(--dark); color:#fff;">Salvar Site</button>
                </div>
            </div>

            <div id="aba-pedidos" class="tab-content">
                <div class="banner-operacao">
                    <div>
                        <h2>Painel de Operação</h2>
                        <p>Acompanhe os pedidos em tempo real.</p>
                    </div>
                    <a href="/operacao" target="_blank" style="background:var(--primary); color:#000; padding:15px; border-radius:8px; text-decoration:none; font-weight:bold;">ABRIR COMANDAS</a>
                </div>
            </div>

            <div id="aba-cardapio" class="tab-content">
                <div id="container-gerenciador-produtos"></div>
            </div>

        </div>
    </div>

    <script>
        const socket = io();
        let pedidoAtivoId = null;

        function openTab(evt, tabName) {
            const contents = document.getElementsByClassName("tab-content");
            for (let i = 0; i < contents.length; i++) contents[i].classList.remove("active");
            const btns = document.getElementsByClassName("tab-btn");
            for (let i = 0; i < btns.length; i++) btns[i].classList.remove("active");
            document.getElementById(tabName).classList.add("active");
            if(evt) evt.currentTarget.classList.add("active");
        }

        async function salvarConfigPix() {
            const dados = {
                pixProvedor: document.getElementById('conf-pixProvedor').value,
                pixToken: document.getElementById('conf-pixToken').value
            };
            const res = await fetch('/update-config-pix', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dados)
            });
            if (res.ok) alert("✅ Banco atualizado!");
        }

        async function salvarConfigSite() {
            const dados = {
                manutencao: document.getElementById('conf-manutencao').checked,
                nomeSite: document.getElementById('conf-nomeSite').value
            };
            await fetch('/update-config-site', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dados)
            });
        }

        function selecionarChat(id, cliente) {
            pedidoAtivoId = id;
            socket.emit('join', id);
        }

        function enviarParaCliente() {
            const input = document.getElementById('admin-msg');
            if(!input.value || !pedidoAtivoId) return;
            socket.emit('enviarMensagem', { usuario: 'Admin', texto: input.value, pedidoId: pedidoAtivoId });
            input.value = '';
        }

        socket.on('novaMensagem', (msg) => {
            if (msg.pedidoId === pedidoAtivoId) {
                const box = document.getElementById('chat-box');
                const div = document.createElement('div');
                div.innerHTML = `<b>${msg.usuario}:</b> ${msg.texto}`;
                box.appendChild(div);
            }
        });
    </script>
    <script src="/js/gerenciar-produtos.js"></script>
</body>
</html>