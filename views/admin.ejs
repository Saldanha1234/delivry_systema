<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>ALPHA GROUP | PREMIUM ADMIN PANEL</title>
    
    <script src="/socket.io/socket.io.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        /* SISTEMA DE CORES ALPHA - BLACK & PURPLE */
        :root {
            --bg-deep: #050505;
            --bg-surface: #0f0f12;
            --bg-card: #16161d;
            --purple-primary: #8B5CF6;
            --purple-dark: #6D28D9;
            --purple-glow: rgba(139, 92, 246, 0.15);
            --border-subtle: #26262e;
            --text-high: #ffffff;
            --text-mid: #94a3b8;
            --text-low: #64748b;
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --safe-area-bottom: env(safe-area-inset-bottom);
        }

        /* RESET E ESTRUTURA BASE */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            font-family: 'Plus Jakarta Sans', sans-serif;
            scrollbar-width: none;
        }

        *::-webkit-scrollbar { display: none; }

        body {
            background-color: var(--bg-deep);
            color: var(--text-high);
            overflow: hidden;
            height: 100vh;
            width: 100vw;
            line-height: 1.5;
        }

        .app-container {
            display: flex;
            flex-direction: column;
            height: 100vh;
            width: 100vw;
            position: relative;
        }

        header {
            height: 70px;
            padding: 0 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(5, 5, 5, 0.8);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border-subtle);
            z-index: 1000;
        }

        .header-brand {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-box {
            width: 32px;
            height: 32px;
            background: var(--purple-primary);
            border-radius: 8px;
            display: grid;
            place-items: center;
            font-weight: 800;
            color: #fff;
        }

        .brand-name {
            font-weight: 800;
            font-size: 1.1rem;
            letter-spacing: -0.5px;
            color: var(--text-high);
        }

        .brand-name span { color: var(--purple-primary); }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .status-badge {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            background: var(--bg-surface);
            border: 1px solid var(--border-subtle);
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .dot-pulse {
            width: 8px;
            height: 8px;
            background: var(--success);
            border-radius: 50%;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
            70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(16, 185, 129, 0); }
            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
        }

        main {
            flex: 1;
            overflow-y: auto;
            padding: 24px 20px 120px 20px;
        }

        .section-header {
            margin: 32px 0 16px 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .section-header:first-child { margin-top: 0; }

        .section-title {
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-low);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .section-title i { color: var(--purple-primary); width: 16px; }

        .cards-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 16px;
        }

        .card-alpha {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: 24px;
            padding: 24px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }

        .card-alpha:active { transform: scale(0.98); border-color: var(--purple-primary); }

        .card-icon-wrapper {
            width: 48px;
            height: 48px;
            background: var(--bg-surface);
            border: 1px solid var(--border-subtle);
            border-radius: 14px;
            display: grid;
            place-items: center;
            margin-bottom: 20px;
            color: var(--purple-primary);
        }

        .card-title {
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 8px;
            color: var(--text-high);
        }

        .card-desc {
            font-size: 0.85rem;
            color: var(--text-mid);
            margin-bottom: 20px;
            line-height: 1.6;
        }

        .input-group { margin-bottom: 16px; }

        .label-premium {
            display: block;
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--purple-primary);
            margin-bottom: 8px;
            text-transform: uppercase;
        }

        .input-alpha {
            width: 100%;
            background: var(--bg-surface);
            border: 1px solid var(--border-subtle);
            border-radius: 12px;
            padding: 14px 16px;
            color: var(--text-high);
            font-size: 0.9rem;
            outline: none;
            transition: all 0.2s;
        }

        .input-alpha:focus {
            border-color: var(--purple-primary);
            box-shadow: 0 0 0 4px var(--purple-glow);
        }

        .btn-premium {
            width: 100%;
            padding: 16px;
            border-radius: 14px;
            border: none;
            background: var(--purple-primary);
            color: #fff;
            font-weight: 800;
            font-size: 0.9rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: all 0.3s;
        }

        .btn-premium.outline {
            background: transparent;
            border: 1px solid var(--border-subtle);
            color: var(--text-high);
        }

        /* CHAT SYSTEM - LÓGICA DE INTERFACE */
        .chat-view {
            height: 450px;
            background: var(--bg-surface);
            border-radius: 24px;
            border: 1px solid var(--border-subtle);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .chat-header-info {
            padding: 15px 20px;
            background: var(--bg-card);
            border-bottom: 1px solid var(--border-subtle);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .chat-header-info .client-meta h4 {
            font-size: 0.9rem;
            font-weight: 700;
            color: var(--text-high);
        }

        .chat-header-info .client-meta span {
            font-size: 0.7rem;
            color: var(--purple-primary);
            font-weight: 600;
        }

        .messages-area {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .msg-bubble {
            max-width: 85%;
            padding: 12px 16px;
            border-radius: 18px;
            font-size: 0.85rem;
        }

        .msg-client {
            align-self: flex-start;
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            color: var(--text-high);
            border-bottom-left-radius: 4px;
        }

        .msg-admin {
            align-self: flex-end;
            background: var(--purple-primary);
            color: white;
            border-bottom-right-radius: 4px;
        }

        /* NAVIGATION FOOTER */
        .mobile-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            height: calc(80px + var(--safe-area-bottom));
            background: rgba(15, 15, 18, 0.95);
            backdrop-filter: blur(25px);
            border-top: 1px solid var(--border-subtle);
            display: flex;
            justify-content: space-around;
            align-items: center;
            padding-bottom: var(--safe-area-bottom);
            z-index: 1000;
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            color: var(--text-low);
            text-decoration: none;
            font-size: 0.65rem;
            font-weight: 700;
            gap: 4px;
        }

        .nav-item.active { color: var(--purple-primary); }

        .tab-panel { display: none; }
        .tab-panel.active { display: block; }
        .fade-in { animation: fadeIn 0.3s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* LISTA DE CHATS ATIVOS */
        .chat-list {
            display: flex;
            gap: 15px;
            overflow-x: auto;
            padding-bottom: 15px;
            margin-bottom: 10px;
        }

        .chat-user-thumb {
            display: flex;
            flex-direction: column;
            align-items: center;
            min-width: 60px;
            cursor: pointer;
        }

        .avatar {
            width: 50px;
            height: 50px;
            background: var(--bg-card);
            border: 2px solid var(--border-subtle);
            border-radius: 15px;
            display: grid;
            place-items: center;
            font-weight: 700;
            position: relative;
        }

        .chat-user-thumb.active .avatar { border-color: var(--purple-primary); box-shadow: 0 0 10px var(--purple-glow); }
        .avatar-online {
            position: absolute;
            bottom: -2px;
            right: -2px;
            width: 12px;
            height: 12px;
            background: var(--success);
            border: 2px solid var(--bg-deep);
            border-radius: 50%;
        }
    </style>
</head>
<body>

<div class="app-container">
    
    <header>
        <div class="header-brand">
            <div class="logo-box">A</div>
            <div class="brand-name">ALPHA<span>GROUP</span></div>
        </div>
        <div class="header-actions">
            <div class="status-badge"><div class="dot-pulse"></div> LIVE</div>
            <i data-lucide="user-circle" style="color: var(--text-low)"></i>
        </div>
    </header>

    <main id="main-scroll">
        
        <div id="tab-home" class="tab-panel active fade-in">
            <div class="section-header">
                <div class="section-title"><i data-lucide="trending-up"></i> Performance Hoje</div>
            </div>
            <div class="cards-grid" style="grid-template-columns: 1fr 1fr;">
                <div class="card-alpha">
                    <span class="label-premium">Vendas</span>
                    <h2 id="total-vendas">R$ 0,00</h2>
                </div>
                <div class="card-alpha">
                    <span class="label-premium">Pedidos</span>
                    <h2 id="total-pedidos">0</h2>
                </div>
            </div>

            <div class="section-header">
                <div class="section-title"><i data-lucide="shield-check"></i> Gateway</div>
            </div>
            <div class="card-alpha">
                <div class="input-group">
                    <label class="label-premium">Token de Acesso</label>
                    <input type="password" class="input-alpha" id="pix-token" placeholder="••••••••">
                </div>
                <button class="btn-premium" onclick="salvarConfig('pix')"><i data-lucide="save"></i> ATUALIZAR</button>
            </div>
        </div>

        <div id="tab-chat" class="tab-panel fade-in">
            <div class="section-header">
                <div class="section-title"><i data-lucide="messages-square"></i> Atendimento</div>
            </div>

            <div class="chat-list" id="active-chats">
                <div class="chat-user-thumb active" onclick="selecionarChat('Guilherme', '#4582')">
                    <div class="avatar">G<div class="avatar-online"></div></div>
                    <span style="font-size: 0.6rem; margin-top: 5px;">Guilherme</span>
                </div>
                <div class="chat-user-thumb" onclick="selecionarChat('Marcos', '#4583')">
                    <div class="avatar">M</div>
                    <span style="font-size: 0.6rem; margin-top: 5px;">Marcos</span>
                </div>
            </div>

            <div class="chat-view">
                <div class="chat-header-info">
                    <div class="client-meta">
                        <h4 id="chat-client-name">Guilherme</h4>
                        <span id="chat-order-id">Pedido: #4582</span>
                    </div>
                    <i data-lucide="info" style="width: 18px; color: var(--text-low)"></i>
                </div>

                <div class="messages-area" id="chat-messages">
                    <div class="msg-bubble msg-client">Olá, meu pedido ainda não chegou. Poderia verificar?</div>
                    <div class="msg-bubble msg-admin">Claro! O entregador já saiu da loja e está a caminho.</div>
                </div>

                <div style="padding: 15px; background: var(--bg-card); display: flex; gap: 10px;">
                    <input type="text" class="input-alpha" placeholder="Digite sua mensagem...">
                    <button class="btn-premium" style="width: 50px; padding: 0;"><i data-lucide="send"></i></button>
                </div>
            </div>
        </div>

    </main>

    <nav class="mobile-nav">
        <a href="javascript:void(0)" class="nav-item active" onclick="switchTab('home', this)">
            <i data-lucide="layout-grid"></i><span>Painel</span>
        </a>
        <a href="javascript:void(0)" class="nav-item" onclick="switchTab('chat', this)">
            <i data-lucide="message-circle"></i><span>Chat</span>
        </a>
        <a href="javascript:void(0)" class="nav-item">
            <i data-lucide="settings"></i><span>Config</span>
        </a>
    </nav>
</div>

<script>
    lucide.createIcons();

    function switchTab(targetId, element) {
        document.querySelectorAll('.nav-item').forEach(nav => nav.classList.remove('active'));
        element.classList.add('active');
        document.querySelectorAll('.tab-panel').forEach(panel => panel.classList.remove('active'));
        document.getElementById('tab-' + targetId).classList.add('active');
    }

    // Lógica para trocar o contexto do chat dinamicamente
    function selecionarChat(nome, pedido) {
        document.getElementById('chat-client-name').innerText = nome;
        document.getElementById('chat-order-id').innerText = `Pedido: ${pedido}`;
        
        // Simulação de troca de mensagens
        const area = document.getElementById('chat-messages');
        area.innerHTML = `<div class="msg-bubble msg-client">Olá, sou o ${nome}. Preciso de ajuda com o pedido ${pedido}.</div>`;
    }

    async function salvarConfig(categoria) {
        console.log("Salvando:", categoria);
        alert("Configuração Alpha atualizada com sucesso!");
    }
</script>

</body>
</html>