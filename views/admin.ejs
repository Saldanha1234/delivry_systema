<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Admin | Gestão Premium</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/socket.io/socket.io.js"></script>
    <style>
        :root {
            --bg: #f5f5f5; --card: white; --text: #333; --sub: #999; --header: white;
            --green: #11c76f; --red: #ff4444; --border: #eee; --primary: #11c76f;
        }
        .dark-mode {
            --bg: #121212; --card: #1e1e1e; --text: #f5f5f5; --sub: #aaa; --header: #1e1e1e;
            --border: #333;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Arial', sans-serif; transition: background 0.3s; }
        body { background-color: var(--bg); color: var(--text); height: 100vh; overflow: hidden; }

        /* Layout Admin */
        .admin-layout { display: flex; flex-direction: column; height: 100vh; }
        
        header { 
            background: var(--header); 
            padding: 20px; 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            border-bottom: 1px solid var(--border);
            z-index: 100;
        }

        /* Sistema de Abas Estilo Banco */
        .tabs { display: flex; gap: 20px; overflow-x: auto; scrollbar-width: none; }
        .tabs::-webkit-scrollbar { display: none; }
        .tab { 
            cursor: pointer; 
            padding-bottom: 5px; 
            font-weight: bold; 
            color: var(--sub); 
            white-space: nowrap;
            font-size: 14px;
            border-bottom: 2px solid transparent;
        }
        .tab.active { color: var(--green); border-bottom: 2px solid var(--green); }

        .content-area { flex: 1; overflow-y: auto; padding: 20px; padding-bottom: 80px; }
        .tab-content { display: none; animation: fadeIn 0.3s; }
        .tab-content.active { display: block; }

        /* Cards e Botões */
        .premium-card { background: var(--card); border-radius: 15px; padding: 20px; border: 1px solid var(--border); margin-bottom: 20px; }
        .btn-green { background: var(--green); color: white; border: none; padding: 12px 20px; border-radius: 25px; font-weight: bold; cursor: pointer; width: 100%; }
        
        /* Chat Estilo Mensagens */
        .suporte-container { display: flex; flex-direction: column; height: 70vh; background: var(--card); border-radius: 15px; border: 1px solid var(--border); overflow: hidden; }
        .chat-selector { display: flex; gap: 10px; padding: 10px; overflow-x: auto; border-bottom: 1px solid var(--border); background: var(--bg); }
        .chat-item { padding: 8px 15px; background: var(--card); border-radius: 20px; border: 1px solid var(--border); font-size: 12px; cursor: pointer; white-space: nowrap; }
        .chat-item.active { background: var(--green); color: white; border-color: var(--green); }
        .chat-messages { flex: 1; overflow-y: auto; padding: 15px; background: var(--bg); display: flex; flex-direction: column; gap: 10px; }
        .msg { padding: 10px 15px; border-radius: 15px; font-size: 13px; max-width: 80%; }
        .msg.cliente { background: white; align-self: flex-start; color: #333; }
        .msg.admin { background: var(--green); color: white; align-self: flex-end; }
        .chat-input { padding: 15px; display: flex; gap: 10px; background: var(--card); }
        .chat-input input { flex: 1; padding: 10px; border-radius: 20px; border: 1px solid var(--border); outline: none; background: var(--bg); color: var(--text); }

        /* FINANCEIRO FULL SCREEN - Ocupa tudo quando ativo */
        #aba-financeiro.active {
            position: fixed; inset: 0; z-index: 5000; background: var(--bg); 
            display: flex; flex-direction: column; padding: 0;
        }
        .bank-full-header { padding: 25px 20px; background: var(--header); display: flex; align-items: center; justify-content: space-between; }
        .balance-card { background: var(--green); border-radius: 20px; padding: 25px; color: white; margin: 20px; box-shadow: 0 10px 20px rgba(17,199,111,0.2); }
        
        .actions-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; padding: 0 20px; margin-bottom: 30px; }
        .action-item { display: flex; flex-direction: column; align-items: center; text-align: center; cursor: pointer; }
        .icon-box { background: var(--card); width: 60px; height: 60px; border-radius: 15px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--border); font-size: 22px; color: var(--green); }
        .action-item p { font-size: 11px; font-weight: bold; margin-top: 8px; }

        /* Lista de Transações */
        .t-list { padding: 0 20px; }
        .t-card { background: var(--card); padding: 15px; border-radius: 12px; margin-bottom: 10px; border: 1px solid var(--border); border-left: 5px solid; display: flex; justify-content: space-between; align-items: center; }
        .t-card.in { border-left-color: var(--green); }
        .t-card.out { border-left-color: var(--red); }

        /* Modais Estilo Banco */
        .modal-full { display: none; position: fixed; inset: 0; background: var(--bg); z-index: 6000; padding: 25px; overflow-y: auto; }
        .input-group { margin-bottom: 20px; }
        .input-group label { display: block; font-size: 12px; color: var(--sub); margin-bottom: 8px; font-weight: bold; }
        .premium-input { width: 100%; padding: 15px; border-radius: 12px; border: 1px solid var(--border); background: var(--card); color: var(--text); outline: none; }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        /* Banner Operação */
        .op-banner { background: #1e1e1e; border-radius: 15px; padding: 20px; color: white; display: flex; justify-content: space-between; align-items: center; border-left: 5px solid var(--green); }
    </style>
</head>
<body class="<%= config.darkMode ? 'dark-mode' : '' %>">

    <div class="admin-layout">
        <header>
            <div style="font-weight: 900; color: var(--green); font-size: 18px;">ADMIN</div>
            <div class="tabs" id="main-tabs">
                <span class="tab active" onclick="openTab(event, 'aba-suporte')">Suporte</span>
                <span class="tab" onclick="openTab(event, 'aba-pedidos')">Operação</span>
                <span class="tab" onclick="openTab(event, 'aba-cardapio')">Cardápio</span>
                <span class="tab" onclick="openTab(event, 'aba-financeiro')">Financeiro</span>
                <span class="tab" onclick="openTab(event, 'aba-configuracao')">Ajustes</span>
            </div>
            <div style="display: flex; gap: 15px; color: var(--green);">
                <i class="fa-solid fa-rotate" onclick="location.reload()" style="cursor:pointer"></i>
                <i class="fa-solid fa-moon" onclick="toggleTheme()" style="cursor:pointer"></i>
            </div>
        </header>

        <div class="content-area">
            
            <div id="aba-suporte" class="tab-content active">
                <div class="suporte-container">
                    <div class="chat-selector" id="lista-pedidos-chat">
                        <% let ativosNoChat = pedidos.filter(p => ['Pendente', 'Em Preparo', 'Pronto para Entrega', 'Em Rota'].includes(p.status)); 
                           ativosNoChat.forEach(p => { %>
                             <div class="chat-item" id="chat-item-<%= p.id %>" onclick="selecionarChat('<%= p.id %>', '<%= p.cliente %>')">
                                <b>#<%= p.id %></b> <%= p.cliente %>
                             </div>
                        <% }) %>
                    </div>
                    <div class="chat-messages" id="chat-box">
                        <div style="text-align:center; color:var(--sub); margin-top:50px;">
                            <i class="fa-solid fa-comments" style="font-size: 40px; margin-bottom: 10px;"></i>
                            <p>Selecione um pedido para conversar</p>
                        </div>
                    </div>
                    <div class="chat-input">
                        <input type="text" id="admin-msg" placeholder="Enviar mensagem...">
                        <button class="btn-green" style="width:50px; border-radius:50%;" onclick="enviarParaCliente()"><i class="fa-solid fa-paper-plane"></i></button>
                    </div>
                </div>
            </div>

            <div id="aba-pedidos" class="tab-content">
                <div class="op-banner">
                    <div>
                        <h3 style="margin:0">Painel de Comandas</h3>
                        <p style="font-size: 12px; color: #888;">Gerencie a cozinha em tempo real</p>
                    </div>
                    <a href="/operacao" target="_blank" class="btn-green" style="width:auto; text-decoration:none;">ABRIR KDS</a>
                </div>
            </div>

            <div id="aba-cardapio" class="tab-content">
                <div id="container-gerenciador-produtos"></div>
            </div>

            <div id="aba-configuracao" class="tab-content">
                <div class="premium-card">
                    <h3 style="margin-bottom:20px">Configurações Gerais</h3>
                    <div class="input-group">
                        <label>MODO MANUTENÇÃO</label>
                        <input type="checkbox" id="conf-manutencao" onchange="salvarConfigSite()" <%= config.manutencao ? 'checked' : '' %>>
                    </div>
                    <div class="input-group">
                        <label>NOME DO ESTABELECIMENTO</label>
                        <input type="text" id="conf-nomeSite" class="premium-input" value="<%= config.nomeSite || '' %>">
                    </div>
                    <button class="btn-green" onclick="salvarConfigSite()">SALVAR ALTERAÇÕES</button>
                </div>
            </div>

            <div id="aba-financeiro" class="tab-content">
                <% 
                    const dataAtual = new Date();
                    const hojeStr = dataAtual.toLocaleDateString('pt-BR');
                    let pedidosHoje = pedidos.filter(p => p.status === 'Concluído' && new Date(p.data || Date.now()).toLocaleDateString('pt-BR') === hojeStr);
                    let totalDia = pedidosHoje.reduce((acc, p) => acc + p.total, 0);
                %>
                <div class="bank-full-header">
                    <i class="fa-solid fa-chevron-left" onclick="closeFinanceiro()" style="font-size: 20px; cursor: pointer;"></i>
                    <b style="font-size: 16px;">Financeiro Premium</b>
                    <i class="fa-solid fa-circle-user" style="font-size: 24px; color: var(--green);"></i>
                </div>

                <div class="balance-card">
                    <span style="font-size: 12px; opacity: 0.9;">Saldo em conta (Hoje)</span>
                    <div style="font-size: 32px; font-weight: bold; margin: 10px 0;">R$ <%= totalDia.toFixed(2) %></div>
                    <div style="font-size: 12px; opacity: 0.8;">Atualizado agora: <b id="bank-clock"></b></div>
                </div>

                <div class="actions-grid">
                    <div class="action-item" onclick="abrirModalBank('modal-mes-full')">
                        <div class="icon-box"><i class="fa-solid fa-calendar-days"></i></div>
                        <p>Mês</p>
                    </div>
                    <div class="action-item" onclick="abrirModalBank('modal-reembolso-full')">
                        <div class="icon-box"><i class="fa-solid fa-hand-holding-dollar"></i></div>
                        <p>Reembolsar</p>
                    </div>
                    <div class="action-item" onclick="abrirModalBank('modal-cadastrar-pix-full')">
                        <div class="icon-box"><i class="fa-solid fa-key"></i></div>
                        <p>Chaves Pix</p>
                    </div>
                </div>

                <div class="t-list">
                    <h4 style="margin-bottom: 15px; padding-left: 5px;">Últimas Movimentações</h4>
                    <% 
                        let logs = pedidos.filter(p => p.status === 'Concluído' || p.reembolsado === true).slice(-10).reverse();
                        logs.forEach(log => {
                    %>
                        <div class="t-card <%= log.reembolsado ? 'out' : 'in' %>">
                            <div>
                                <b><%= log.reembolsado ? 'Reembolso' : 'Pedido Recebido' %></b><br>
                                <small style="color:var(--sub)">#<%= log.id %> • <%= log.cliente %></small>
                            </div>
                            <b style="color:var(--<%= log.reembolsado ? 'red' : 'green' %>)">
                                <%= log.reembolsado ? '-' : '+' %> R$ <%= log.total.toFixed(2) %>
                            </b>
                        </div>
                    <% }) %>
                </div>
            </div>

        </div>
    </div>

    <div id="modal-mes-full" class="modal-full">
        <div class="bank-full-header">
            <i class="fa-solid fa-xmark" onclick="fecharModalBank('modal-mes-full')" style="font-size: 24px;"></i>
            <b>Faturamento Mensal</b>
            <span></span>
        </div>
        <div class="balance-card" style="background: var(--card); color: var(--text); border: 1px solid var(--border);">
            <span style="color:var(--sub)">Total Acumulado</span>
            <h1 style="font-size: 35px; color: var(--green);">R$ <%= config.vendasMes ? config.vendasMes.toFixed(2) : '0.00' %></h1>
            <hr style="margin: 20px 0; border: 0; border-top: 1px solid var(--border);">
            <p>Pedidos concluídos: <b><%= config.entregasMes || 0 %></b></p>
        </div>
    </div>

    <div id="modal-reembolso-full" class="modal-full">
        <div class="bank-full-header"><i class="fa-solid fa-xmark" onclick="fecharModalBank('modal-reembolso-full')"></i><b>Registrar Saída</b><span></span></div>
        <div class="input-group">
            <label>ID DO PEDIDO</label>
            <input type="text" id="reembolso-id" class="premium-input" placeholder="Ex: 102">
        </div>
        <div class="input-group">
            <label>VALOR DO ESTORNO</label>
            <input type="number" id="reembolso-valor" class="premium-input" placeholder="0.00">
        </div>
        <button class="btn-green" onclick="processarReembolso()">EFETUAR REEMBOLSO</button>
    </div>

    <div id="modal-cadastrar-pix-full" class="modal-full">
        <div class="bank-full-header"><i class="fa-solid fa-xmark" onclick="fecharModalBank('modal-cadastrar-pix-full')"></i><b>API de Pagamentos</b><span></span></div>
        <div class="input-group">
            <label>GATEWAY</label>
            <select id="conf-pixProvedor" class="premium-input">
                <option value="mercadopago" <%= config.pixProvedor === 'mercadopago' ? 'selected' : '' %>>Mercado Pago</option>
                <option value="efi" <%= config.pixProvedor === 'efi' ? 'selected' : '' %>>EFI Bank</option>
            </select>
        </div>
        <div class="input-group">
            <label>CHAVE DE ACESSO (TOKEN)</label>
            <input type="password" id="conf-pixToken" class="premium-input" value="<%= config.pixToken || '' %>">
        </div>
        <button class="btn-green" onclick="salvarConfigPix()">ATUALIZAR CREDENCIAIS</button>
    </div>

    <script>
        const socket = io();
        let pedidoAtivoId = null;

        // Relógio
        function updateClock() {
            const el = document.getElementById('bank-clock');
            if(el) el.innerText = new Date().toLocaleTimeString('pt-BR');
        }
        setInterval(updateClock, 1000);

        function openTab(evt, tabName) {
            document.querySelectorAll(".tab-content").forEach(c => c.classList.remove("active"));
            document.querySelectorAll(".tab").forEach(t => t.classList.remove("active"));
            document.getElementById(tabName).classList.add("active");
            if(evt) evt.currentTarget.classList.add("active");
        }

        function closeFinanceiro() {
            document.getElementById('aba-financeiro').classList.remove('active');
            document.querySelector('.tab[onclick*="aba-suporte"]').click();
        }

        function abrirModalBank(id) { document.getElementById(id).style.display = 'block'; }
        function fecharModalBank(id) { document.getElementById(id).style.display = 'none'; }

        function toggleTheme() {
            document.body.classList.toggle('dark-mode');
            const isDark = document.body.classList.contains('dark-mode');
            // Opcional: Salvar preferência via fetch para o banco
        }

        // Lógicas Originais Mantidas
        async function salvarConfigSite() {
            const dados = {
                manutencao: document.getElementById('conf-manutencao').checked,
                nomeSite: document.getElementById('conf-nomeSite').value
            };
            await fetch('/update-config-site', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dados)
            });
            alert("Configurações salvas!");
        }

        async function processarReembolso() {
            const id = document.getElementById('reembolso-id').value;
            const valor = document.getElementById('reembolso-valor').value;
            const res = await fetch('/registrar-reembolso', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ pedidoId: id, valor: valor })
            });
            if(res.ok) { alert("Reembolso concluído!"); location.reload(); }
        }

        function selecionarChat(id, cliente) {
            pedidoAtivoId = id;
            document.querySelectorAll('.chat-item').forEach(el => el.classList.remove('active'));
            document.getElementById(`chat-item-${id}`).classList.add('active');
            document.getElementById('chat-box').innerHTML = `<p style="text-align:center; color:var(--sub)">Conectado ao pedido #${id}</p>`;
            socket.emit('join', id);
        }

        socket.on('novaMensagem', (msg) => {
            if (msg.pedidoId === pedidoAtivoId) {
                const div = document.createElement('div');
                div.className = `msg ${msg.usuario === 'Admin' ? 'admin' : 'cliente'}`;
                div.innerHTML = `<span>${msg.texto}</span>`;
                const box = document.getElementById('chat-box');
                box.appendChild(div);
                box.scrollTop = box.scrollHeight;
            }
        });

        function enviarParaCliente() {
            const input = document.getElementById('admin-msg');
            if(!input.value || !pedidoAtivoId) return;
            socket.emit('enviarMensagem', { usuario: 'Admin', texto: input.value, pedidoId: pedidoAtivoId });
            input.value = '';
        }
    </script>
    <script src="/js/gerenciar-produtos.js"></script>
</body>
</html>