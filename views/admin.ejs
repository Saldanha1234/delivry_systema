<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>ALPHA ADMIN | EXCLUSIVE</title>
    
    <script src="/socket.io/socket.io.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        :root {
            --bg: #050505;
            --surface: #0f0f13;
            --card: #16161d;
            --primary: #8B5CF6;
            --primary-glow: rgba(139, 92, 246, 0.2);
            --text: #ffffff;
            --text-dim: #94a3b8;
            --border: rgba(255, 255, 255, 0.06);
            --success: #10b981;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; -webkit-tap-highlight-color: transparent; }
        
        body { background: var(--bg); color: var(--text); height: 100vh; overflow: hidden; }

        /* HEADER PREMIUM */
        header {
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(5, 5, 5, 0.7);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            position: sticky; top: 0; z-index: 100;
        }

        .logo { font-weight: 800; font-size: 1.1rem; letter-spacing: -0.5px; }
        .logo span { color: var(--primary); text-shadow: 0 0 15px var(--primary-glow); }

        .status-pill {
            background: var(--surface);
            padding: 6px 12px;
            border-radius: 20px;
            border: 1px solid var(--border);
            font-size: 0.7rem;
            font-weight: 700;
            display: flex;
            align-items: center; gap: 8px;
        }

        .pulse { width: 8px; height: 8px; background: var(--success); border-radius: 50%; box-shadow: 0 0 10px var(--success); animation: blink 2s infinite; }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }

        /* NAVEGAÇÃO EM GRID (ORGANIZAÇÃO NOVA) */
        .nav-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            padding: 15px;
        }

        .nav-item {
            background: var(--card);
            border: 1px solid var(--border);
            padding: 15px 10px;
            border-radius: 18px;
            text-align: center;
            cursor: pointer;
            transition: 0.3s;
        }

        .nav-item i { display: block; margin-bottom: 8px; color: var(--primary); }
        .nav-item span { font-size: 0.65rem; font-weight: 800; text-transform: uppercase; color: var(--text-dim); }
        .nav-item.active { background: var(--primary-glow); border-color: var(--primary); }
        .nav-item.active span { color: white; }

        /* ÁREA DE CONTEÚDO SCROLLABLE */
        main { height: calc(100vh - 180px); overflow-y: auto; padding: 0 15px 100px 15px; }
        .tab-content { display: none; animation: slideUp 0.4s ease; }
        .tab-content.active { display: block; }

        @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        /* CARDS E INPUTS */
        .alpha-card {
            background: var(--card);
            border-radius: 24px;
            padding: 20px;
            margin-bottom: 15px;
            border: 1px solid var(--border);
        }

        .section-title { font-size: 0.9rem; font-weight: 800; margin-bottom: 15px; display: flex; align-items: center; gap: 10px; }

        .alpha-input {
            width: 100%; background: var(--surface); border: 1px solid var(--border);
            padding: 14px; border-radius: 14px; color: white; margin-bottom: 15px; outline: none;
        }

        .alpha-btn {
            width: 100%; background: var(--primary); color: white; border: none;
            padding: 15px; border-radius: 16px; font-weight: 800; cursor: pointer;
            box-shadow: 0 10px 20px rgba(139, 92, 246, 0.2);
        }

        /* CHAT FLOATING SYSTEM (O QUE VOCÊ PEDIU) */
        .chat-layout { display: flex; flex-direction: column; height: 60vh; }
        
        .chat-users {
            display: flex; overflow-x: auto; gap: 10px; padding-bottom: 15px;
            scrollbar-width: none;
        }
        .chat-users::-webkit-scrollbar { display: none; }

        .user-bubble {
            flex-shrink: 0; width: 60px; height: 60px; border-radius: 50%;
            background: var(--card); border: 2px solid var(--border);
            display: flex; align-items: center; justify-content: center;
            font-weight: 800; font-size: 0.7rem; position: relative;
        }
        .user-bubble.active { border-color: var(--primary); box-shadow: 0 0 15px var(--primary-glow); }
        .user-bubble.has-new::after {
            content: ''; position: absolute; top: 0; right: 0;
            width: 15px; height: 15px; background: #ef4444; border-radius: 50%; border: 2px solid var(--bg);
        }

        .chat-window {
            flex: 1; background: var(--surface); border-radius: 20px;
            display: flex; flex-direction: column; overflow: hidden; border: 1px solid var(--border);
        }
        .messages-area { flex: 1; overflow-y: auto; padding: 15px; display: flex; flex-direction: column; gap: 10px; }
        
        .m-msg { padding: 10px 15px; border-radius: 18px; font-size: 0.8rem; max-width: 80%; line-height: 1.4; }
        .m-msg.cliente { background: var(--card); align-self: flex-start; border-bottom-left-radius: 4px; }
        .m-msg.admin { background: var(--primary); align-self: flex-end; border-bottom-right-radius: 4px; font-weight: 600; }

        .chat-controls { padding: 10px; display: flex; gap: 8px; background: var(--card); }
        .chat-controls input { flex: 1; background: var(--bg); border: none; padding: 12px; border-radius: 12px; color: white; outline: none; }
        
        /* FINANCEIRO STYLE */
        .stat-row { display: flex; gap: 10px; margin-bottom: 15px; }
        .stat-box { flex: 1; background: var(--card); padding: 15px; border-radius: 20px; border-left: 4px solid var(--primary); }
        .stat-box small { color: var(--text-dim); font-size: 0.6rem; text-transform: uppercase; font-weight: 800; }
        .stat-box div { font-size: 1.1rem; font-weight: 800; margin-top: 5px; }

        /* SWITCHES */
        .switch { position: relative; display: inline-block; width: 44px; height: 22px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background: #222; transition: .4s; border-radius: 20px; }
        .slider:before { position: absolute; content: ""; height: 16px; width: 16px; left: 3px; bottom: 3px; background: white; transition: .4s; border-radius: 50%; }
        input:checked + .slider { background: var(--primary); }
        input:checked + .slider:before { transform: translateX(22px); }

    </style>
</head>
<body>

    <header>
        <div class="logo">ALPHA<span>GROUP</span></div>
        <div class="status-pill">
            <div class="pulse"></div> OPERACIONAL
        </div>
    </header>

    <nav class="nav-grid">
        <div class="nav-item active" onclick="openTab(event, 'aba-suporte')">
            <i data-lucide="message-circle"></i>
            <span>Chat</span>
        </div>
        <div class="nav-item" onclick="openTab(event, 'aba-cardapio')">
            <i data-lucide="utensils"></i>
            <span>Cardápio</span>
        </div>
        <div class="nav-item" onclick="openTab(event, 'aba-financeiro')">
            <i data-lucide="wallet"></i>
            <span>Grana</span>
        </div>
        <div class="nav-item" onclick="openTab(event, 'aba-pedidos')">
            <i data-lucide="chef-hat"></i>
            <span>KDS</span>
        </div>
        <div class="nav-item" onclick="openTab(event, 'aba-configuracao')">
            <i data-lucide="settings"></i>
            <span>Ajustes</span>
        </div>
        <div class="nav-item" onclick="location.reload()">
            <i data-lucide="rotate-cw"></i>
            <span>Sync</span>
        </div>
    </nav>

    <main>
        <div id="aba-suporte" class="tab-content active">
            <div class="chat-layout">
                <div class="chat-users" id="lista-pedidos-chat">
                    <% let ativosNoChat = pedidos.filter(p => ['Pendente', 'Em Preparo', 'Pronto para Entrega', 'Em Rota'].includes(p.status)); 
                       ativosNoChat.forEach(p => { %>
                         <div class="user-bubble" id="chat-item-<%= p.id %>" onclick="selecionarChat('<%= p.id %>', '<%= p.cliente %>')">
                            <%= p.cliente.substring(0,2).toUpperCase() %>
                        </div>
                    <% }) %>
                </div>
                <div class="chat-window">
                    <div class="messages-area" id="chat-box">
                        <div style="text-align:center; padding-top:40px; color:var(--text-dim);">
                            <p style="font-size: 0.7rem; font-weight: 800;">SELECIONE UM CLIENTE ACIMA</p>
                        </div>
                    </div>
                    <div class="chat-controls">
                        <input type="text" id="admin-msg" placeholder="Mandar resposta...">
                        <button onclick="enviarParaCliente()" style="background:var(--primary); color:white; border:none; padding:8px 12px; border-radius:10px;">
                            <i data-lucide="send" style="width:18px;"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div id="aba-cardapio" class="tab-content">
            <div class="alpha-card">
                <div class="section-title"><i data-lucide="package"></i> PRODUTOS</div>
                <div id="container-gerenciador-produtos"></div>
            </div>
            <div class="alpha-card">
                <div class="section-title"><i data-lucide="plus-circle"></i> ADICIONAIS</div>
                <div id="container-gerenciador-adicionais"></div>
            </div>
        </div>

        <div id="aba-financeiro" class="tab-content">
            <% 
                const hojeStr = new Date().toLocaleDateString('pt-BR');
                let pedidosHoje = pedidos.filter(p => p.status === 'Concluído' && new Date(p.data || Date.now()).toLocaleDateString('pt-BR') === hojeStr);
                let totalDia = pedidosHoje.reduce((acc, p) => acc + p.total, 0);
            %>
            <div class="stat-row">
                <div class="stat-box">
                    <small>Hoje</small>
                    <div>R$ <%= totalDia.toFixed(2) %></div>
                </div>
                <div class="stat-box" style="border-color: #3b82f6;">
                    <small>Pedidos</small>
                    <div><%= pedidosHoje.length %></div>
                </div>
            </div>
            
            <div class="alpha-card">
                <div class="section-title"><i data-lucide="credit-card"></i> CONFIG PIX</div>
                <form id="form-config-pix">
                    <select id="conf-pixProvedor" class="alpha-input">
                        <option value="mercadopago" <%= config.pixProvedor === 'mercadopago' ? 'selected' : '' %>>Mercado Pago</option>
                        <option value="efi" <%= config.pixProvedor === 'efi' ? 'selected' : '' %>>EFI Bank</option>
                    </select>
                    <input type="password" id="conf-pixToken" class="alpha-input" value="<%= config.pixToken || '' %>" placeholder="Token de Acesso">
                    <button type="button" onclick="salvarConfigPix()" class="alpha-btn">ATUALIZAR CHAVES</button>
                </form>
            </div>
        </div>

        <div id="aba-configuracao" class="tab-content">
            <div class="alpha-card">
                <div style="display:flex; justify-content:space-between; align-items:center;">
                    <div>
                        <div style="font-weight:800; font-size:0.8rem;">MANUTENÇÃO</div>
                        <small style="color:var(--text-dim)">Fecha o site imediatamente</small>
                    </div>
                    <label class="switch">
                        <input type="checkbox" id="conf-manutencao" onchange="salvarConfigSite()" <%= config.manutencao ? 'checked' : '' %>>
                        <span class="slider"></span>
                    </label>
                </div>
            </div>

            <div class="alpha-card">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;">
                    <div style="font-weight:800; font-size:0.8rem;">FILTRAR CIDADE</div>
                    <label class="switch">
                        <input type="checkbox" id="conf-cidadeAtiva" onchange="toggleCamposCidade(); salvarConfigSite();" <%= config.cidadeAtiva ? 'checked' : '' %>>
                        <span class="slider"></span>
                    </label>
                </div>
                <div id="container-campos-cidade" style="display: <%= config.cidadeAtiva ? 'grid' : 'none' %>; grid-template-columns: 1fr 80px; gap:10px;">
                    <input type="text" id="conf-cidadeNome" placeholder="Cidade" value="<%= config.cidadeNome || '' %>" class="alpha-input">
                    <input type="text" id="conf-cidadeEstado" placeholder="UF" value="<%= config.cidadeEstado || '' %>" class="alpha-input">
                </div>
            </div>

            <button onclick="abrirModalHorarios()" class="alpha-btn" style="background:var(--surface); border:1px solid var(--border);">CONFIGURAR HORÁRIOS</button>
        </div>

        <div id="aba-pedidos" class="tab-content">
            <div class="alpha-card" style="text-align:center;">
                <i data-lucide="monitor" style="width:40px; height:40px; color:var(--primary); margin-bottom:15px;"></i>
                <h3 style="margin-bottom:10px;">KDS Administrativo</h3>
                <p style="font-size:0.7rem; color:var(--text-dim); margin-bottom:20px;">Gerencie os pedidos que estão na cozinha.</p>
                <a href="/operacao" target="_blank" class="alpha-btn" style="text-decoration:none; display:block;">ABRIR COMANDAS</a>
            </div>
        </div>
    </main>

    <div id="modalHorarios" class="modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.9); z-index:2000; padding:20px;">
        <div style="background:var(--card); padding:20px; border-radius:24px; max-width:500px; margin:auto;">
            <div style="display:flex; justify-content:space-between; margin-bottom:20px;">
                <h2 style="font-size:1rem;">HORÁRIOS</h2>
                <span onclick="fecharModalHorarios()" style="cursor:pointer;">X</span>
            </div>
            <div id="lista-dias-funcionamento">
                <% const diasSemana = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'];
                   diasSemana.forEach((dia, i) => { 
                   const agendaDia = (config.agenda && config.agenda[i]) || { aberto: false, inicio: '18:00', fim: '23:00' }; %>
                    <div style="display:flex; justify-content:space-between; align-items:center; padding:10px 0; border-bottom:1px solid var(--border);">
                        <span style="font-weight:800; font-size:0.7rem;"><%= dia %></span>
                        <div id="box-horario-<%= i %>" style="display: <%= agendaDia.aberto ? 'flex' : 'none' %>; gap:5px;">
                            <input type="time" class="input-inicio alpha-input" style="margin:0; padding:5px; font-size:0.7rem;" value="<%= agendaDia.inicio %>">
                            <input type="time" class="input-fim alpha-input" style="margin:0; padding:5px; font-size:0.7rem;" value="<%= agendaDia.fim %>">
                        </div>
                        <label class="switch">
                            <input type="checkbox" class="check-dia" onchange="toggleDia(<%= i %>)" <%= agendaDia.aberto ? 'checked' : '' %>>
                            <span class="slider"></span>
                        </label>
                    </div>
                <% }) %>
            </div>
            <button onclick="salvarHorarios()" class="alpha-btn" style="margin-top:20px;">SALVAR AGENDA</button>
        </div>
    </div>

    <script>
        const socket = io();
        let pedidoAtivoId = null;
        lucide.createIcons();

        function openTab(evt, tabName) {
            const contents = document.getElementsByClassName("tab-content");
            for (let i = 0; i < contents.length; i++) contents[i].classList.remove("active");
            const btns = document.getElementsByClassName("nav-item");
            for (let i = 0; i < btns.length; i++) btns[i].classList.remove("active");
            document.getElementById(tabName).classList.add("active");
            evt.currentTarget.classList.add("active");
        }

        // --- TODAS AS LÓGICAS ORIGINAIS PRESERVADAS (Mesmos caminhos, mesmas rotas) ---

        function abrirModalHorarios() { document.getElementById('modalHorarios').style.display = 'block'; }
        function fecharModalHorarios() { document.getElementById('modalHorarios').style.display = 'none'; }
        function toggleDia(index) {
            const isChecked = document.querySelectorAll('.check-dia')[index].checked;
            document.getElementById(`box-horario-${index}`).style.display = isChecked ? 'flex' : 'none';
        }
        function toggleCamposCidade() {
            const isChecked = document.getElementById('conf-cidadeAtiva').checked;
            document.getElementById('container-campos-cidade').style.display = isChecked ? 'grid' : 'none';
        }

        async function salvarHorarios() {
            const agenda = [];
            const checks = document.querySelectorAll('.check-dia');
            const incios = document.querySelectorAll('.input-inicio');
            const fins = document.querySelectorAll('.input-fim');
            checks.forEach((check, i) => {
                agenda.push({ aberto: check.checked, inicio: incios[i].value, fim: fins[i].value });
            });
            const res = await fetch('/update-horarios', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ agenda })
            });
            if (res.ok) { alert("Agenda salva!"); fecharModalHorarios(); }
        }

        async function salvarConfigSite() {
            const dados = {
                manutencao: document.getElementById('conf-manutencao').checked,
                cidadeAtiva: document.getElementById('conf-cidadeAtiva').checked,
                cidadeNome: document.getElementById('conf-cidadeNome').value,
                cidadeEstado: document.getElementById('conf-cidadeEstado').value
            };
            await fetch('/update-config-site', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dados)
            });
        }

        async function salvarConfigPix() {
            const dados = {
                pixProvedor: document.getElementById('conf-pixProvedor').value,
                pixToken: document.getElementById('conf-pixToken').value
            };
            const res = await fetch('/update-config-pix', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dados)
            });
            if (res.ok) alert("PIX Atualizado!");
        }

        // --- LÓGICA DE CHAT MANTIDA INTEGRALMENTE ---

        function selecionarChat(id, cliente) {
            pedidoAtivoId = id;
            document.querySelectorAll('.user-bubble').forEach(el => el.classList.remove('active', 'has-new'));
            const target = document.getElementById(`chat-item-${id}`);
            if(target) target.classList.add('active');
            socket.emit('join', id);
            socket.emit('lerMensagens', id);
        }

        socket.on('historico', (h) => {
            const box = document.getElementById('chat-box');
            box.innerHTML = '';
            h.forEach(renderizarMensagem);
        });

        socket.on('novaMensagem', (msg) => {
            if (msg.pedidoId === pedidoAtivoId) {
                renderizarMensagem(msg);
            } else {
                const item = document.getElementById(`chat-item-${msg.pedidoId}`);
                if(item) item.classList.add('has-new');
            }
        });

        function renderizarMensagem(msg) {
            const div = document.createElement('div');
            div.className = `m-msg ${msg.usuario === 'Admin' ? 'admin' : 'cliente'}`;
            div.innerHTML = `<small style="display:block; font-size:8px; opacity:0.6; margin-bottom:2px;">${msg.usuario}</small>${msg.texto}`;
            const box = document.getElementById('chat-box');
            box.appendChild(div);
            box.scrollTop = box.scrollHeight;
        }

        function enviarParaCliente() {
            const input = document.getElementById('admin-msg');
            if(!input.value || !pedidoAtivoId) return;
            socket.emit('enviarMensagem', { usuario: 'Admin', texto: input.value, pedidoId: pedidoAtivoId });
            input.value = '';
        }

        document.addEventListener('DOMContentLoaded', () => {
            if(typeof renderizarPainelCategorias === "function") renderizarPainelCategorias('container-gerenciador-produtos');
            if(typeof renderizarPainelAdicionais === "function") renderizarPainelAdicionais('container-gerenciador-adicionais');
        });
    </script>

    <script src="/js/gerenciar-produtos.js"></script>
    <script src="/js/gerenciar-adicionais.js"></script>
</body>
</html>