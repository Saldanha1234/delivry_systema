<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>ALPHA ADMIN | GESTÃO TOTAL</title>
    
    <script src="/socket.io/socket.io.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        :root {
            --bg-deep: #050505;
            --bg-surface: #0c0c10;
            --bg-card: #14141c;
            --purple-main: #8B5CF6;
            --purple-dim: #6D28D9;
            --purple-glow: rgba(139, 92, 246, 0.15);
            --border: #1f1f27;
            --text-high: #ffffff;
            --text-mid: #94a3b8;
            --text-low: #64748b;
            --success: #10b981;
            --danger: #ef4444;
            --info: #3b82f6;
        }

        /* MODO ESCURO FORÇADO / DESIGN BASE */
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Plus Jakarta Sans', sans-serif; }
        
        body { 
            background: var(--bg-deep); 
            color: var(--text-high); 
            height: 100vh; 
            overflow: hidden; 
        }

        .app-shell { display: flex; flex-direction: column; height: 100vh; }

        /* HEADER */
        header {
            height: 70px;
            padding: 0 20px;
            background: rgba(5, 5, 5, 0.8);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            z-index: 100;
        }

        .brand { font-weight: 800; font-size: 1.2rem; }
        .brand span { color: var(--purple-main); }

        .header-actions { display: flex; gap: 10px; }

        .btn-icon {
            background: var(--bg-card);
            border: 1px solid var(--border);
            color: white;
            padding: 8px 12px;
            border-radius: 10px;
            cursor: pointer;
            font-size: 0.8rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* TABS NAVEGAÇÃO */
        .tab-nav {
            display: flex;
            background: var(--bg-surface);
            border-bottom: 1px solid var(--border);
            overflow-x: auto;
            white-space: nowrap;
            scrollbar-width: none;
        }
        .tab-nav::-webkit-scrollbar { display: none; }

        .tab-btn {
            padding: 15px 20px;
            background: none;
            border: none;
            color: var(--text-low);
            font-weight: 700;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            border-bottom: 2px solid transparent;
            transition: 0.3s;
        }
        .tab-btn.active {
            color: var(--purple-main);
            border-bottom-color: var(--purple-main);
            background: var(--purple-glow);
        }

        /* CONTEÚDO */
        main { flex: 1; overflow-y: auto; padding: 20px; padding-bottom: 100px; }
        .tab-content { display: none; animation: fadeIn 0.3s ease; }
        .tab-content.active { display: block; }

        .alpha-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 20px;
        }

        /* FINANCEIRO GRID */
        .finance-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 20px; }
        .stat-card {
            background: var(--bg-card);
            padding: 20px;
            border-radius: 18px;
            border-top: 4px solid var(--purple-main);
        }
        .stat-card h4 { font-size: 0.65rem; text-transform: uppercase; color: var(--text-low); margin-bottom: 10px; }
        .stat-card .value { font-size: 1.5rem; font-weight: 800; }
        .stat-card .date-label { font-size: 0.7rem; color: var(--purple-main); font-weight: 600; }

        /* CHAT SYSTEM ALPHA */
        .suporte-container {
            display: flex;
            height: 70vh;
            background: var(--bg-card);
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid var(--border);
        }
        .chat-sidebar { width: 300px; border-right: 1px solid var(--border); background: var(--bg-surface); display: flex; flex-direction: column; }
        .chat-list { flex: 1; overflow-y: auto; padding: 10px; }
        .chat-item {
            padding: 15px;
            border-radius: 12px;
            background: var(--bg-card);
            margin-bottom: 10px;
            border: 1px solid var(--border);
            cursor: pointer;
        }
        .chat-item.active { border-color: var(--purple-main); background: var(--purple-glow); }
        .chat-item.has-new { border-left: 4px solid var(--danger); }

        .chat-main { flex: 1; display: flex; flex-direction: column; background: #08080a; }
        .chat-messages { flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 12px; }
        .msg { padding: 12px 16px; border-radius: 15px; font-size: 0.85rem; max-width: 80%; }
        .msg.cliente { background: var(--bg-card); align-self: flex-start; border: 1px solid var(--border); }
        .msg.admin { background: var(--purple-main); color: white; align-self: flex-end; font-weight: 600; }

        .chat-input { padding: 15px; display: flex; gap: 10px; background: var(--bg-card); border-top: 1px solid var(--border); }
        .chat-input input {
            flex: 1; background: var(--bg-deep); border: 1px solid var(--border);
            padding: 12px 18px; border-radius: 30px; color: white; outline: none;
        }
        .chat-input button {
            background: var(--purple-main); color: white; border: none;
            width: 45px; height: 45px; border-radius: 50%; cursor: pointer;
        }

        /* INPUTS ALPHA */
        .alpha-input {
            width: 100%; background: var(--bg-deep); border: 1px solid var(--border);
            padding: 12px; border-radius: 10px; color: white; margin-top: 5px;
        }
        .alpha-btn {
            background: var(--purple-main); color: white; border: none;
            padding: 12px 20px; border-radius: 10px; font-weight: 700; cursor: pointer; width: 100%;
        }

        /* SWITCH DESIGN */
        .switch { position: relative; display: inline-block; width: 50px; height: 26px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background: #222; transition: .4s; border-radius: 34px; }
        .slider:before { position: absolute; content: ""; height: 18px; width: 18px; left: 4px; bottom: 4px; background: white; transition: .4s; border-radius: 50%; }
        input:checked + .slider { background: var(--purple-main); }
        input:checked + .slider:before { transform: translateX(24px); }

        /* MODAL */
        .modal { display: none; position: fixed; z-index: 2000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); backdrop-filter: blur(8px); overflow-y: auto; }
        .modal-content { background: var(--bg-card); margin: 5% auto; padding: 25px; border-radius: 25px; width: 90%; max-width: 500px; border: 1px solid var(--border); }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        @media (max-width: 768px) {
            .suporte-container { flex-direction: column; }
            .chat-sidebar { width: 100%; height: 200px; }
        }
    </style>
</head>
<body>

    <div class="app-shell">
        <header>
            <div class="brand">ALPHA<span>ADMIN</span></div>
            <div class="header-actions">
                <button onclick="location.reload()" class="btn-icon"><i data-lucide="refresh-cw"></i> Sync</button>
            </div>
        </header>

        <nav class="tab-nav">
            <button class="tab-btn active" onclick="openTab(event, 'aba-suporte')">💬 Suporte</button>
            <button class="tab-btn" onclick="openTab(event, 'aba-pedidos')">📋 Operação</button>
            <button class="tab-btn" onclick="openTab(event, 'aba-cardapio')">🍔 Cardápio</button>
            <button class="tab-btn" onclick="openTab(event, 'aba-financeiro')">💰 Financeiro</button>
            <button class="tab-btn" onclick="openTab(event, 'aba-configuracao')">⚙️ Ajustes</button>
        </nav>

        <main>
            <div id="aba-suporte" class="tab-content active">
                <div class="suporte-container">
                    <div class="chat-sidebar">
                        <div style="padding:15px; font-size:0.6rem; font-weight:800; letter-spacing:1px; color:var(--text-low); text-align:center;">CHATS ATIVOS</div>
                        <div class="chat-list" id="lista-pedidos-chat">
                            <% let ativosNoChat = pedidos.filter(p => ['Pendente', 'Em Preparo', 'Pronto para Entrega', 'Em Rota'].includes(p.status)); 
                               ativosNoChat.forEach(p => { %>
                                 <div class="chat-item" id="chat-item-<%= p.id %>" onclick="selecionarChat('<%= p.id %>', '<%= p.cliente %>')">
                                    <div style="font-weight: 800; font-size: 0.8rem; margin-bottom: 4px;">#<%= p.id %></div>
                                    <div style="font-size: 0.75rem; color: var(--text-mid);"><%= p.cliente %></div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                    <div class="chat-main">
                        <div class="chat-messages" id="chat-box">
                            <div style="text-align:center; margin-top:100px; color:var(--text-low);">
                                <i data-lucide="message-circle" style="width:40px; height:40px; margin-bottom:10px;"></i>
                                <h3>Selecione um cliente para conversar</h3>
                            </div>
                        </div>
                        <div class="chat-input">
                            <input type="text" id="admin-msg" placeholder="Digite sua mensagem...">
                            <button onclick="enviarParaCliente()"><i data-lucide="send"></i></button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="aba-pedidos" class="tab-content">
                <div class="alpha-card" style="border-left: 6px solid var(--purple-main);">
                    <h2 style="font-size: 1.2rem; margin-bottom: 5px;">Painel de Produção</h2>
                    <p style="color: var(--text-mid); font-size: 0.8rem; margin-bottom: 20px;">Gerencie a cozinha e entregas em tempo real.</p>
                    <a href="/operacao" target="_blank" class="alpha-btn" style="text-decoration:none; display:block; text-align:center;">ABRIR KDS COMPLETO</a>
                </div>
            </div>

            <div id="aba-cardapio" class="tab-content">
                <div class="alpha-card">
                    <h3 style="font-size: 1rem; margin-bottom: 20px;"><i data-lucide="package" style="vertical-align: middle;"></i> Gerenciar Produtos</h3>
                    <div id="container-gerenciador-produtos"></div>
                </div>
                <div class="alpha-card">
                    <h3 style="font-size: 1rem; margin-bottom: 20px;"><i data-lucide="layers" style="vertical-align: middle;"></i> Gerenciar Adicionais</h3>
                    <div id="container-gerenciador-adicionais"></div>
                </div>
            </div>

            <div id="aba-financeiro" class="tab-content">
                <% 
                    const dataAtual = new Date();
                    const hojeStr = dataAtual.toLocaleDateString('pt-BR');
                    const nomeMeses = ["Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho", "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"];
                    let pedidosHoje = pedidos.filter(p => p.status === 'Concluído' && new Date(p.data || Date.now()).toLocaleDateString('pt-BR') === hojeStr);
                    let totalDia = pedidosHoje.reduce((acc, p) => acc + p.total, 0);
                %>
                <div class="finance-grid">
                    <div class="stat-card">
                        <h4>Vendas de Hoje</h4>
                        <div class="value">R$ <%= totalDia.toFixed(2) %></div>
                        <span class="date-label"><%= hojeStr %></span>
                    </div>
                    <div class="stat-card" style="border-color: var(--info);">
                        <h4>Concluídos Hoje</h4>
                        <div class="value"><%= pedidosHoje.length %></div>
                        <span class="date-label">Pedidos</span>
                    </div>
                    <div class="stat-card" style="border-color: var(--success);">
                        <h4>Faturamento <%= nomeMeses[dataAtual.getMonth()] %></h4>
                        <div class="value">R$ <%= (config.vendasMes || 0).toFixed(2) %></div>
                        <span class="date-label">Acumulado</span>
                    </div>
                </div>

                <div class="alpha-card">
                    <h3 style="font-size: 1rem; margin-bottom: 20px;">Configurações de Pagamento (PIX)</h3>
                    <form id="form-config-pix" style="display:grid; gap:15px;">
                        <label class="input-label">Provedor</label>
                        <select id="conf-pixProvedor" class="alpha-input">
                            <option value="mercadopago" <%= config.pixProvedor === 'mercadopago' ? 'selected' : '' %>>Mercado Pago</option>
                            <option value="efi" <%= config.pixProvedor === 'efi' ? 'selected' : '' %>>EFI Bank</option>
                        </select>
                        <label class="input-label">Token / Chave API</label>
                        <input type="password" id="conf-pixToken" class="alpha-input" value="<%= config.pixToken || '' %>">
                        <button type="button" onclick="salvarConfigPix()" class="alpha-btn">SALVAR CREDENCIAIS</button>
                    </form>
                </div>
            </div>

            <div id="aba-configuracao" class="tab-content">
                <div class="alpha-card">
                    <h3 style="font-size: 1rem; margin-bottom: 25px;">Geral e Disponibilidade</h3>
                    
                    <div style="display:flex; justify-content:space-between; align-items:center; padding-bottom:15px; border-bottom:1px solid var(--border);">
                        <div>
                            <div style="font-weight:700; font-size:0.9rem;">Modo Manutenção</div>
                            <div style="color:var(--text-low); font-size:0.75rem;">Oculta o site para clientes</div>
                        </div>
                        <label class="switch">
                            <input type="checkbox" id="conf-manutencao" onchange="salvarConfigSite()" <%= config.manutencao ? 'checked' : '' %>>
                            <span class="slider"></span>
                        </label>
                    </div>

                    <div style="padding:20px 0; border-bottom:1px solid var(--border);">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;">
                            <div style="font-weight:700; font-size:0.9rem;">Limitar por Cidade</div>
                            <label class="switch">
                                <input type="checkbox" id="conf-cidadeAtiva" onchange="toggleCamposCidade(); salvarConfigSite();" <%= config.cidadeAtiva ? 'checked' : '' %>>
                                <span class="slider"></span>
                            </label>
                        </div>
                        <div id="container-campos-cidade" style="display: <%= config.cidadeAtiva ? 'grid' : 'none' %>; grid-template-columns: 1fr 80px; gap:10px;">
                            <input type="text" id="conf-cidadeNome" placeholder="Cidade" value="<%= config.cidadeNome || '' %>" class="alpha-input">
                            <input type="text" id="conf-cidadeEstado" placeholder="UF" value="<%= config.cidadeEstado || '' %>" class="alpha-input">
                        </div>
                    </div>

                    <div style="padding-top:20px; display:flex; justify-content:space-between; align-items:center;">
                        <div style="font-weight:700; font-size:0.9rem;">Horários de Funcionamento</div>
                        <button onclick="abrirModalHorarios()" class="btn-icon" style="background:var(--purple-glow); border-color:var(--purple-main); color:var(--purple-main);">CONFIGURAR</button>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="modalHorarios" class="modal">
        <div class="modal-content">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
                <h2 style="font-size:1.1rem;">Agenda Semanal</h2>
                <span onclick="fecharModalHorarios()" style="cursor:pointer; font-size:1.5rem;">&times;</span>
            </div>
            <div id="lista-dias-funcionamento">
                <% const diasSemana = ['Domingo', 'Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado'];
                   diasSemana.forEach((dia, i) => { 
                   const agendaDia = (config.agenda && config.agenda[i]) || { aberto: false, inicio: '18:00', fim: '23:00' }; %>
                    <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid var(--border);">
                        <span style="font-weight:700; font-size:0.8rem; width:80px;"><%= dia %></span>
                        <div id="box-horario-<%= i %>" style="display: <%= agendaDia.aberto ? 'flex' : 'none' %>; gap:5px;">
                            <input type="time" class="input-inicio alpha-input" style="margin:0; padding:5px;" value="<%= agendaDia.inicio %>">
                            <input type="time" class="input-fim alpha-input" style="margin:0; padding:5px;" value="<%= agendaDia.fim %>">
                        </div>
                        <label class="switch" style="transform: scale(0.75);">
                            <input type="checkbox" class="check-dia" onchange="toggleDia(<%= i %>)" <%= agendaDia.aberto ? 'checked' : '' %>>
                            <span class="slider"></span>
                        </label>
                    </div>
                <% }) %>
            </div>
            <button onclick="salvarHorarios()" class="alpha-btn" style="margin-top:20px; background:var(--success);">SALVAR ALTERAÇÕES</button>
        </div>
    </div>

    <script>
        const socket = io();
        let pedidoAtivoId = null;

        // INICIALIZAÇÃO DE ÍCONES
        lucide.createIcons();

        // NAVEGAÇÃO
        function openTab(evt, tabName) {
            const contents = document.getElementsByClassName("tab-content");
            for (let i = 0; i < contents.length; i++) contents[i].classList.remove("active");
            const btns = document.getElementsByClassName("tab-btn");
            for (let i = 0; i < btns.length; i++) btns[i].classList.remove("active");
            document.getElementById(tabName).classList.add("active");
            if(evt) evt.currentTarget.classList.add("active");
        }

        // LÓGICAS DE UI (MANTIDAS)
        function abrirModalHorarios() { document.getElementById('modalHorarios').style.display = 'block'; }
        function fecharModalHorarios() { document.getElementById('modalHorarios').style.display = 'none'; }
        function toggleDia(index) {
            const isChecked = document.querySelectorAll('.check-dia')[index].checked;
            document.getElementById(`box-horario-${index}`).style.display = isChecked ? 'flex' : 'none';
        }
        function toggleCamposCidade() {
            const isChecked = document.getElementById('conf-cidadeAtiva').checked;
            document.getElementById('container-campos-cidade').style.display = isChecked ? 'grid' : 'none';
        }

        // --- TODAS AS ROTAS ORIGINAIS PRESERVADAS ---

        async function salvarHorarios() {
            const agenda = [];
            const checks = document.querySelectorAll('.check-dia');
            const incios = document.querySelectorAll('.input-inicio');
            const fins = document.querySelectorAll('.input-fim');
            checks.forEach((check, i) => {
                agenda.push({ aberto: check.checked, inicio: incios[i].value, fim: fins[i].value });
            });
            const res = await fetch('/update-horarios', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ agenda })
            });
            if (res.ok) { alert("✅ Agenda atualizada!"); fecharModalHorarios(); }
        }

        async function salvarConfigSite() {
            const dados = {
                manutencao: document.getElementById('conf-manutencao').checked,
                cidadeAtiva: document.getElementById('conf-cidadeAtiva').checked,
                cidadeNome: document.getElementById('conf-cidadeNome').value,
                cidadeEstado: document.getElementById('conf-cidadeEstado').value
            };
            await fetch('/update-config-site', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dados)
            });
        }

        async function salvarConfigPix() {
            const dados = {
                pixProvedor: document.getElementById('conf-pixProvedor').value,
                pixToken: document.getElementById('conf-pixToken').value
            };
            const res = await fetch('/update-config-pix', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(dados)
            });
            if (res.ok) alert("✅ Credenciais de pagamento atualizadas!");
        }

        // --- LÓGICA DE CHAT MANTIDA ---

        function selecionarChat(id, cliente) {
            pedidoAtivoId = id;
            document.querySelectorAll('.chat-item').forEach(el => el.classList.remove('active', 'has-new'));
            const target = document.getElementById(`chat-item-${id}`);
            if(target) target.classList.add('active');
            socket.emit('join', id);
            socket.emit('lerMensagens', id);
        }

        socket.on('historico', (h) => {
            const box = document.getElementById('chat-box');
            box.innerHTML = '';
            h.forEach(renderizarMensagem);
        });

        socket.on('novaMensagem', (msg) => {
            if (msg.pedidoId === pedidoAtivoId) {
                renderizarMensagem(msg);
            } else {
                const item = document.getElementById(`chat-item-${msg.pedidoId}`);
                if(item) item.classList.add('has-new');
            }
        });

        function renderizarMensagem(msg) {
            const div = document.createElement('div');
            div.className = `msg ${msg.usuario === 'Admin' ? 'admin' : 'cliente'}`;
            div.innerHTML = `<small style="display:block; font-size:9px; opacity:0.5; margin-bottom:4px;">${msg.usuario}</small>${msg.texto}`;
            const box = document.getElementById('chat-box');
            box.appendChild(div);
            box.scrollTop = box.scrollHeight;
        }

        function enviarParaCliente() {
            const input = document.getElementById('admin-msg');
            if(!input.value || !pedidoAtivoId) return;
            socket.emit('enviarMensagem', { usuario: 'Admin', texto: input.value, pedidoId: pedidoAtivoId });
            input.value = '';
        }

        // CARREGAMENTO DOS COMPONENTES EXTERNOS
        document.addEventListener('DOMContentLoaded', () => {
            if(typeof renderizarPainelCategorias === "function") renderizarPainelCategorias('container-gerenciador-produtos');
            if(typeof renderizarPainelAdicionais === "function") renderizarPainelAdicionais('container-gerenciador-adicionais');
        });
    </script>

    <script src="/js/gerenciar-produtos.js"></script>
    <script src="/js/gerenciar-adicionais.js"></script>
</body>
</html>