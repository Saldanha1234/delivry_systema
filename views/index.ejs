<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <title>Premium Delivery</title>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/estrutura-produtos.js"></script> 
    <style>
        /* --- ESTILOS DE CATEGORIAS E FILTROS --- */
        .category-nav {
            display: flex; gap: 10px; padding: 10px 20px; overflow-x: auto;
            background: white; position: sticky; top: 0; z-index: 900; border-bottom: 1px solid #eee;
        }
        .category-nav::-webkit-scrollbar { display: none; }
        .cat-btn {
            padding: 8px 20px; border-radius: 20px; border: 1px solid #ddd;
            background: white; color: #666; cursor: pointer; white-space: nowrap;
            font-weight: 600; transition: 0.3s;
        }
        .cat-btn.active { background: var(--primary); color: white; border-color: var(--primary); }

        .events-area { display: flex; gap: 15px; padding: 20px; overflow-x: auto; }
        .events-area::-webkit-scrollbar { display: none; }
        .event-card { min-width: 280px; padding: 20px; border-radius: 15px; color: white; cursor: pointer; transition: transform 0.2s; }
        .event-card:active { transform: scale(0.95); }
        .promo { background: linear-gradient(135deg, #ff4757, #ff6b81); }
        .top-seller { background: linear-gradient(135deg, #2f3542, #57606f); }

        .card.hidden { display: none; }

        /* --- ESTILOS DO STATUS DE FUNCIONAMENTO --- */
        .status-badge {
            display: inline-block; padding: 6px 15px; border-radius: 20px;
            font-size: 0.8rem; font-weight: 800; margin-bottom: 15px; text-transform: uppercase;
        }
        .status-aberto { background: #e7f9ee; color: #2ecc71; border: 1px solid #2ecc71; }
        .status-fechado { background: #feecef; color: #ff4757; border: 1px solid #ff4757; }
        .btn-disabled { background: #ccc !important; cursor: not-allowed !important; opacity: 0.6; }

        /* ESTILO NOVO SISTEMA DE MONTAGEM */
        .modal-body-scroll { max-height: 65vh; overflow-y: auto; padding-right: 5px; }
        .cat-secao { margin-bottom: 20px; border-bottom: 1px solid #f0f0f0; padding-bottom: 10px; }
        .cat-secao h4 { font-size: 1rem; margin-bottom: 10px; color: var(--dark); display: flex; justify-content: space-between; }
        .cat-secao small { font-weight: normal; color: #777; font-size: 0.75rem; }
        
        .opcao-item {
            display: flex; align-items: center; justify-content: space-between;
            background: #fff; padding: 12px; border-radius: 10px; margin-bottom: 8px;
            cursor: pointer; border: 1px solid #eee; transition: 0.2s;
        }
        .opcao-item:hover { border-color: var(--primary); background: #fffcf0; }
        .opcao-item input { width: 20px; height: 20px; accent-color: var(--primary); }
        .opcao-info { display: flex; flex-direction: column; flex: 1; margin-left: 10px; }
        .opcao-info span { font-weight: 600; font-size: 0.9rem; }
        .opcao-info small { color: var(--success); font-weight: bold; }

        .modal-footer-sticky {
            border-top: 1px solid #eee; padding-top: 15px; margin-top: 10px;
            display: flex; flex-direction: column; gap: 10px;
        }
        .total-preview { display: flex; justify-content: space-between; font-weight: 800; font-size: 1.1rem; }

        /* RODAPÉ E SOCIAL */
        .social-footer { margin-top: 50px; padding: 40px 20px; background: #fdfdfd; border-top: 1px solid #eee; text-align: center; }
        .social-buttons { display: flex; justify-content: center; gap: 25px; margin-bottom: 20px; }
        .social-icon { color: #888; font-size: 1.8rem; transition: 0.3s; text-decoration: none; }
        .social-icon:hover { color: var(--primary); transform: translateY(-3px); }

        @media (max-width: 600px) {
            .event-card { min-width: 240px; padding: 15px; }
            .category-nav { padding: 10px; }
        }
    </style>
</head>
<body>

<div id="status-alerta" style="display:none; background: #ffca2c; color: #181818; padding: 12px; text-align: center; font-weight: 800; cursor: pointer;" onclick="irParaStatus()">
    ⏳ PEDIDO EM ANDAMENTO! CLIQUE PARA ACOMPANHAR.
</div>

<nav>
    <div class="logo">Premium<span>Delivery</span></div>
    <div class="cart-btn" onclick="toggleCart()">
        <span>🛒 Carrinho</span>
        <span id="cart-count">0</span>
    </div>
</nav>

<section class="events-area">
    <div class="event-card promo" onclick="filtrarCategoria('Promoção')">
        <div style="font-size: 0.7rem; font-weight: 800;">CLIQUE PARA VER</div>
        <h3>Ofertas do Dia 🏷️</h3>
        <p>Produtos com preços especiais.</p>
    </div>
    <div class="event-card top-seller" onclick="filtrarCategoria('Destaques')">
        <div style="font-size: 0.7rem; font-weight: 800;">CLIQUE PARA VER</div>
        <h3>Mais Pedidos ⭐</h3>
        <p>Os favoritos da nossa cozinha.</p>
    </div>
</section>

<div class="category-nav">
    <button class="cat-btn active" onclick="filtrarCategoria('todos')">Todos</button>
    <button class="cat-btn" onclick="filtrarCategoria('Promoção')">Promoções</button>
    <button class="cat-btn" onclick="filtrarCategoria('Destaques')">Mais Vendidos</button>
    <button class="cat-btn" onclick="filtrarCategoria('Lanches')">Lanches</button>
    <button class="cat-btn" onclick="filtrarCategoria('Bebidas')">Bebidas</button>
</div>

<div class="container" id="produtos-container">
    <% produtos.forEach(p => { %>
        <div class="card" data-categoria="<%= p.categoria || 'todos' %>">
            <img src="<%= p.img %>">
            <div class="card-content">
                <h3><%= p.nome %></h3>
                <p class="desc"><%= p.desc %></p>
                <span class="price-tag">R$ <%= p.preco.toFixed(2) %></span>
                
                <% if (estaAberto) { %>
                    <button class="btn-add" 
                            data-nome="<%= p.nome %>" 
                            data-preco="<%= p.preco %>" 
                            data-tipo="<%= p.tipo || 'simples' %>"
                            onclick="adicionar(this)">
                        Adicionar
                    </button>
                <% } else { %>
                    <button class="btn-add btn-disabled" disabled>Fechado</button>
                <% } %>
            </div>
        </div>
    <% }) %>
</div>

<div id="modal-montar" class="modal" style="display:none; z-index: 1500;">
    <div class="modal-content" style="max-width: 500px; width: 95%; border-radius: 20px;">
        <h2 id="montar-titulo" style="margin-bottom: 5px;">Personalizar</h2>
        <p id="montar-preco-base" style="color: #666; font-size: 0.9rem; margin-bottom: 15px;"></p>
        
        <div id="montar-opcoes" class="modal-body-scroll">
            </div>

        <div class="modal-footer-sticky">
            <div class="total-preview">
                <span>Total do Item:</span>
                <span id="montar-total-exibicao">R$ 0,00</span>
            </div>
            <button class="btn-confirm" onclick="confirmarPersonalizacao()">Confirmar e Adicionar</button>
            <button class="btn-close" onclick="fecharModalMontar()" style="background: #eee; color: #666;">Cancelar</button>
        </div>
    </div>
</div>

<div id="cart-modal" class="modal">
    <div class="modal-content">
        <h2>Seu Carrinho</h2>
        <div id="cart-items" style="max-height: 250px; overflow-y: auto; margin-bottom: 20px;"></div>
        <div class="form-group"><label>NOME</label><input type="text" id="cliente-nome"></div>
        <div class="form-group"><label>ENDEREÇO</label><input type="text" id="cliente-end"></div>
        <div class="form-group">
            <label>PAGAMENTO</label>
            <select id="cliente-pagto">
                <option value="Pix">Pix</option>
                <option value="Cartão">Cartão</option>
                <option value="Dinheiro">Dinheiro</option>
            </select>
        </div>
        <div style="display: flex; justify-content: space-between; margin: 20px 0;">
            <span>Total:</span><span id="cart-total" style="font-weight: 800; color: var(--primary);">R$ 0,00</span>
        </div>
        <% if (estaAberto) { %>
            <button class="btn-confirm" onclick="finalizar()">Confirmar Pedido</button>
        <% } else { %>
            <button class="btn-confirm btn-disabled" disabled>Estamos Fechados</button>
        <% } %>
        <button class="btn-close" onclick="toggleCart()">Voltar</button>
    </div>
</div>

<footer class="social-footer">
    <div class="status-container">
        <% if (estaAberto) { %>
            <div class="status-badge status-aberto">● Aberto Agora</div>
        <% } else { %>
            <div class="status-badge status-fechado">● Fechado no Momento</div>
        <% } %>
        <p style="font-size: 0.85rem; color: #666;">Horário: 08:00 às 20:00</p>
    </div>
    <div class="social-buttons" style="margin-top: 20px;">
        <a href="https://instagram.com/seu_perfil" target="_blank" class="social-icon"><i class="fa-brands fa-instagram"></i></a>
        <a href="#" target="_blank" class="social-icon"><i class="fa-brands fa-whatsapp"></i></a>
    </div>
    <span style="display:block; margin-top:20px; font-size:0.7rem; color:#bbb;">© 2026 Premium Delivery</span>
</footer>

<script>
    const socket = io();
    let carrinho = [];
    let itemEmMontagem = null;
    let precoTotalItem = 0;

    // Lógica de categorias
    function filtrarCategoria(categoria) {
        document.querySelectorAll('.cat-btn').forEach(btn => {
            btn.classList.remove('active');
            if(btn.innerText.includes(categoria) || (categoria === 'todos' && btn.innerText === 'Todos')) {
                btn.classList.add('active');
            }
        });
        const cards = document.querySelectorAll('.card');
        cards.forEach(card => {
            const catProduto = card.getAttribute('data-categoria');
            if (categoria === 'todos' || catProduto === categoria) {
                card.classList.remove('hidden');
            } else {
                card.classList.add('hidden');
            }
        });
    }

    window.onload = function() {
        const idSalvo = localStorage.getItem('ultimoPedidoId');
        if (idSalvo) {
            document.getElementById('status-alerta').style.display = 'block';
            socket.emit('join', idSalvo);
        }
    }

    function irParaStatus() {
        const id = localStorage.getItem('ultimoPedidoId');
        if (id) window.location.href = '/status/' + id;
    }

    // LOGICA DE ADICIONAR
    function adicionar(btn) {
        const nome = btn.getAttribute('data-nome');
        const preco = parseFloat(btn.getAttribute('data-preco'));
        const tipo = btn.getAttribute('data-tipo');

        if (tipo === 'montar') {
            abrirModalMontar(nome, preco);
        } else {
            carrinho.push({ nome, preco, detalhes: "Produto Simples" });
            atualizarUI();
            btn.innerText = "✓";
            setTimeout(() => btn.innerText = "Adicionar", 1000);
        }
    }

    function abrirModalMontar(nome, precoBase) {
        itemEmMontagem = { nome, precoBase };
        precoTotalItem = precoBase;
        
        document.getElementById('montar-titulo').innerText = nome;
        document.getElementById('montar-preco-base').innerText = `Preço base: R$ ${precoBase.toFixed(2)}`;
        
        const container = document.getElementById('montar-opcoes');
        
        container.innerHTML = ConfigEstrutura.categorias.map(cat => `
            <div class="cat-secao">
                <h4>${cat.nome} <small>${cat.obrigatorio ? '(Obrigatório)' : '(Opcional)'}</small></h4>
                <div class="lista-opcoes">
                    ${cat.itens.map(opt => `
                        <label class="opcao-item">
                            <input type="${cat.limite === 1 ? 'radio' : 'checkbox'}" 
                                   name="${cat.id}" 
                                   data-item-nome="${opt.nome}" 
                                   data-item-preco="${opt.preco}"
                                   onchange="calcularTotalItem('${cat.id}', ${cat.limite})">
                            <div class="opcao-info">
                                <span>${opt.nome}</span>
                                <small>${opt.preco > 0 ? '+ R$ '+opt.preco.toFixed(2) : 'Grátis'}</small>
                            </div>
                        </label>
                    `).join('')}
                </div>
            </div>
        `).join('');

        atualizarLabelTotal();
        document.getElementById('modal-montar').style.display = 'flex';
    }

    function calcularTotalItem(catId, limite) {
        // Validar limites
        const selecionados = document.querySelectorAll(`input[name="${catId}"]:checked`);
        if (selecionados.length > limite) {
            event.target.checked = false;
            alert(`Limite de ${limite} opções para esta categoria.`);
        }

        // Somar Tudo
        let novoTotal = itemEmMontagem.precoBase;
        const todosChecked = document.querySelectorAll('#montar-opcoes input:checked');
        todosChecked.forEach(input => {
            novoTotal += parseFloat(input.getAttribute('data-item-preco'));
        });

        precoTotalItem = novoTotal;
        atualizarLabelTotal();
    }

    function atualizarLabelTotal() {
        document.getElementById('montar-total-exibicao').innerText = `R$ ${precoTotalItem.toFixed(2)}`;
    }

    function confirmarPersonalizacao() {
        // Validação de obrigatórios
        const catsObrigatorias = ConfigEstrutura.categorias.filter(c => c.obrigatorio);
        for(let cat of catsObrigatorias) {
            const check = document.querySelector(`input[name="${cat.id}"]:checked`);
            if(!check) return alert(`Por favor, selecione: ${cat.nome}`);
        }

        const selecionados = [];
        document.querySelectorAll('#montar-opcoes input:checked').forEach(el => {
            selecionados.push(el.getAttribute('data-item-nome'));
        });

        carrinho.push({
            nome: itemEmMontagem.nome,
            preco: precoTotalItem,
            detalhes: selecionados.length > 0 ? "Adicionais: " + selecionados.join(', ') : "Original"
        });

        atualizarUI();
        fecharModalMontar();
    }

    function fecharModalMontar() {
        document.getElementById('modal-montar').style.display = 'none';
    }

    function atualizarUI() {
        document.getElementById('cart-count').innerText = carrinho.length;
        const lista = document.getElementById('cart-items');
        lista.innerHTML = carrinho.map((i, index) => `
            <div style="border-bottom: 1px solid #eee; padding: 10px 0;">
                <div style="display:flex; justify-content:space-between; font-weight: bold;">
                    <span>${i.nome}</span>
                    <b>R$ ${i.preco.toFixed(2)}</b>
                </div>
                <div style="font-size: 0.75rem; color: #777; margin: 3px 0;">${i.detalhes}</div>
                <button onclick="removerItem(${index})" style="background:none; border:none; color:red; font-size:0.7rem; cursor:pointer;">Remover</button>
            </div>
        `).join('');
        const total = carrinho.reduce((acc, i) => acc + i.preco, 0);
        document.getElementById('cart-total').innerText = `R$ ${total.toFixed(2)}`;
    }

    function removerItem(index) {
        carrinho.splice(index, 1);
        atualizarUI();
    }

    function toggleCart() {
        const m = document.getElementById('cart-modal');
        m.style.display = (m.style.display === 'flex') ? 'none' : 'flex';
    }

    async function finalizar() {
        const nome = document.getElementById('cliente-nome').value;
        const endereco = document.getElementById('cliente-end').value;
        const pagto = document.getElementById('cliente-pagto').value;
        if(!nome || !endereco || carrinho.length === 0) return alert("Preencha os dados e adicione itens!");

        const res = await fetch('/enviar-pedido', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
                cliente: nome, endereco, pagamento: pagto,
                itens: JSON.stringify(carrinho), 
                total: carrinho.reduce((acc, i) => acc + i.preco, 0)
            })
        });

        if(res.ok) {
            const data = await res.json();
            localStorage.setItem('ultimoPedidoId', data.id);
            location.href = '/status/' + data.id;
        }
    }
</script>
</body>
</html>