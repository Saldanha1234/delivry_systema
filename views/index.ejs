<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <title>Premium Delivery</title>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        :root { --primary: #FF385C; --dark: #2f3542; --warning: #f1c40f; }

        /* --- ESTILOS DE CATEGORIAS E FILTROS --- */
        .category-nav {
            display: flex; gap: 10px; padding: 10px 20px; overflow-x: auto;
            background: white; position: sticky; top: 0; z-index: 900; border-bottom: 1px solid #eee;
        }
        .category-nav::-webkit-scrollbar { display: none; }
        .cat-btn {
            padding: 8px 20px; border-radius: 20px; border: 1px solid #ddd;
            background: white; color: #666; cursor: pointer; white-space: nowrap;
            font-weight: 600; transition: 0.3s;
        }
        .cat-btn.active { background: var(--primary); color: white; border-color: var(--primary); }

        .events-area { display: flex; gap: 15px; padding: 20px; overflow-x: auto; }
        .events-area::-webkit-scrollbar { display: none; }
        .event-card { min-width: 280px; padding: 20px; border-radius: 15px; color: white; cursor: pointer; transition: transform 0.2s; }
        .event-card:active { transform: scale(0.95); }
        .promo { background: linear-gradient(135deg, #ff4757, #ff6b81); }
        .top-seller { background: linear-gradient(135deg, #2f3542, #57606f); }

        /* CARD CLICÁVEL */
        .card { cursor: pointer; transition: 0.2s; position: relative; overflow: hidden; }
        .card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .card.hidden { display: none; }
        
        /* Estilo Indisponível */
        .card.indisponivel { opacity: 0.6; filter: grayscale(1); }

        /* ESTILOS DO MODAL DE MONTAGEM */
        .modal-montagem-content { width: 95%; max-width: 500px; max-height: 90vh; overflow-y: auto; border-radius: 20px; padding: 0 !important; }
        .modal-body { padding: 20px; }
        .search-box { width: 100%; padding: 12px; border: 1px solid #eee; border-radius: 10px; margin: 15px 0; outline: none; font-size: 1rem; }
        .cat-section { margin-bottom: 20px; }
        .cat-header { background: #f8f8f8; padding: 10px 15px; border-radius: 8px; margin-bottom: 10px; border-left: 4px solid var(--primary); }
        .item-add { display: flex; justify-content: space-between; align-items: center; padding: 12px; border-bottom: 1px solid #f5f5f5; }
        .item-controls { display: flex; align-items: center; gap: 12px; }
        .btn-qty { width: 32px; height: 32px; border-radius: 50%; border: 1px solid var(--primary); background: white; color: var(--primary); font-weight: bold; cursor: pointer; transition: 0.2s; display: flex; align-items: center; justify-content: center; }
        .btn-qty:active { background: var(--primary); color: white; }
        .obs-box { width: 100%; height: 80px; border: 1px solid #ddd; border-radius: 10px; padding: 10px; margin: 10px 0; resize: none; font-family: inherit; }

        /* CARRINHO */
        .cart-item-row { border-bottom: 1px solid #eee; padding: 15px 0; position: relative; }
        .remove-product { color: #ff4757; cursor: pointer; font-size: 1.2rem; margin-left: 10px; }
        
        .social-footer { margin-top: 50px; padding: 40px 20px; background: #fdfdfd; border-top: 1px solid #eee; text-align: center; }
        .social-buttons { display: flex; justify-content: center; gap: 25px; margin-bottom: 20px; }
        .social-icon { color: #888; font-size: 1.8rem; transition: 0.3s; text-decoration: none; }
        .social-icon:hover { color: var(--primary); transform: translateY(-3px); }

        .status-badge { display: inline-block; padding: 6px 15px; border-radius: 20px; font-size: 0.8rem; font-weight: 800; margin-bottom: 15px; text-transform: uppercase; }
        .status-aberto { background: #e7f9ee; color: #2ecc71; border: 1px solid #2ecc71; }
        .status-fechado { background: #feecef; color: #ff4757; border: 1px solid #ff4757; }
        .btn-disabled { background: #ccc !important; cursor: not-allowed !important; opacity: 0.6; }

        /* MODAL HORÁRIOS ESTILO CLEAN */
        .horario-link { color: var(--primary); text-decoration: underline; cursor: pointer; font-weight: 600; font-size: 0.85rem; }
        .modal-horarios-content { width: 90%; max-width: 400px; border-radius: 15px; padding: 25px; text-align: left; }
        .lista-horarios { list-style: none; padding: 0; margin-top: 15px; }
        .item-horario { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid #f0f0f0; font-size: 0.95rem; }
        .item-horario:last-child { border-bottom: none; }
        .dia-nome { font-weight: 600; color: #333; }
        .dia-valor { color: #666; }

        @media (max-width: 600px) {
            .event-card { min-width: 240px; padding: 15px; }
            .category-nav { padding: 10px; }
        }
    </style>
</head>
<body>

<div id="status-alerta" style="display:none; background: var(--warning); color: var(--dark); padding: 12px; text-align: center; font-weight: 800; cursor: pointer;" onclick="irParaStatus()">
    ⏳ PEDIDO EM ANDAMENTO! CLIQUE PARA ACOMPANHAR.
</div>

<nav>
    <div class="logo">Premium<span>Delivery</span></div>
    <div class="cart-btn" onclick="toggleCart()">
        <span>🛒 Carrinho</span>
        <span id="cart-count">0</span>
    </div>
</nav>

<section class="events-area">
    <div class="event-card promo" onclick="filtrarCategoria('Promoção')">
        <div style="font-size: 0.7rem; font-weight: 800;">CLIQUE PARA VER</div>
        <h3>Ofertas do Dia 🏷️</h3>
        <p>Produtos com preços especiais.</p>
    </div>
    <div class="event-card top-seller" onclick="filtrarCategoria('Destaques')">
        <div style="font-size: 0.7rem; font-weight: 800;">CLIQUE PARA VER</div>
        <h3>Mais Pedidos ⭐</h3>
        <p>Os favoritos da nossa cozinha.</p>
    </div>
</section>

<div class="category-nav">
    <button class="cat-btn active" onclick="filtrarCategoria('Todos')">Todos</button>

    <% if (locals.categorias) { %>
        <% categorias.forEach((cat, index) => { 
            if(cat.nome !== 'Todos' && cat.nome !== 'Defina um nome' && cat.nome !== 'Defina um nome ') { %>
            <button class="cat-btn" onclick="filtrarCategoria('<%= cat.nome %>')">
                <%= cat.nome %>
            </button>
        <% } }) %>
    <% } %>
</div>

<div class="container" id="produtos-container">
    <% produtos.forEach(p => { %>
        <% 
           const temDesconto = p.desconto && Number(p.desconto) > 0;
           const valorVenda = temDesconto ? Number(p.desconto) : Number(p.preco);
           const isIndisponivel = p.status === 'indisponivel';
        %>
        <div class="card <%= isIndisponivel ? 'indisponivel' : '' %>" data-categoria="<%= p.categoria %>" 
             onclick="gerenciarCliqueProduto('<%= p.status %>', '<%= p.modificadoresAtivos %>', '<%= p.nome %>', '<%= valorVenda %>', '<%= p.desc %>', '<%= p.img %>', '<%= p.preco %>')">
            
            <% if(temDesconto) { %>
                <div style="position: absolute; top: 10px; right: 10px; color: #28a745; font-weight: bold; font-size: 0.7rem; background: rgba(255,255,255,0.8); padding: 4px 8px; border-radius: 5px; z-index: 10;">
                    🏷️ <span style="background: transparent;">Desconto Aplicado</span>
                </div>
            <% } %>

            <img src="<%= p.img %>" alt="<%= p.nome %>">
            <div class="card-content">
                <h3><%= p.nome %></h3>
                <p class="desc"><%= p.desc %></p>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
                    <div class="price-container">
                        <% if(temDesconto) { %>
                            <span style="text-decoration: line-through; color: #bbb; font-size: 0.8rem; margin-right: 5px;">R$ <%= Number(p.preco).toFixed(2) %></span>
                            <span class="price-tag">R$ <%= Number(p.desconto).toFixed(2) %></span>
                        <% } else { %>
                            <span class="price-tag">R$ <%= (p.preco ? Number(p.preco).toFixed(2) : "0.00") %></span>
                        <% } %>
                    </div>
                    <span style="color: var(--primary); font-weight: bold; font-size: 0.8rem;">Ver detalhes +</span>
                </div>
            </div>
        </div>
    <% }) %>
</div>

<div id="modal-montagem" class="modal">
    <div class="modal-content modal-montagem-content">
        <div style="position: relative;">
            <img id="m-img" style="width:100%; height:220px; object-fit:cover;">
            <button onclick="fecharModalMontagem()" style="position: absolute; top: 15px; right: 15px; background: rgba(0,0,0,0.5); color: white; border: none; width: 35px; height: 35px; border-radius: 50%; cursor: pointer; font-weight: bold;">X</button>
        </div>
        
        <div class="modal-body">
            <h2 id="m-nome"></h2>
            <p id="m-desc" style="color:#666; font-size:0.9rem; margin-bottom: 10px;"></p>
            
            <div id="container-adicionais-logic">
                <input type="text" class="search-box" placeholder="🔎 Pesquisar adicional..." oninput="filtrarAdicionais(this.value)">
                <div id="categorias-container"></div>
            </div>

            <label style="font-weight:bold; font-size:0.9rem; margin-top: 10px; display: block;">Alguma observação?</label>
            <textarea id="m-obs" class="obs-box" placeholder="Ex: tirar cebola, sem gelo..."></textarea>

            <div style="display:flex; justify-content:space-between; align-items:center; margin-top:20px; padding:15px; background:#f9f9f9; border-radius:12px; position: sticky; bottom: 0;">
                <div>
                    <div style="font-size:0.8rem; color:#666;">Total do item</div>
                    <div id="m-total" style="font-size:1.3rem; font-weight:800; color:var(--primary);">R$ 0,00</div>
                </div>
                <button class="btn-confirm" id="btn-confirm-acao" onclick="confirmarMontagem()" style="margin:0; width:auto; padding:12px 30px;">Adicionar</button>
            </div>
        </div>
    </div>
</div>

<div id="cart-modal" class="modal">
    <div class="modal-content">
        <h2>Seu Carrinho</h2>
        <div id="cart-items" style="max-height: 350px; overflow-y: auto; margin-bottom: 20px;"></div>
        
        <div class="form-group"><label>NOME</label><input type="text" id="cliente-nome" placeholder="Seu nome completo"></div>
        <div class="form-group"><label>ENDEREÇO</label><input type="text" id="cliente-end" placeholder="Rua, número, bairro"></div>
        <div class="form-group">
            <label>PAGAMENTO</label>
            <select id="cliente-pagto">
                <option value="Pix">Pix</option>
                <option value="Cartão">Cartão de Crédito/Débito</option>
                <option value="Dinheiro">Dinheiro</option>
            </select>
        </div>
        
        <div style="display: flex; justify-content: space-between; margin: 20px 0; font-size: 1.2rem; border-top: 2px solid #eee; padding-top: 15px;">
            <span style="font-weight: bold;">Total Geral:</span>
            <span id="cart-total" style="font-weight: 800; color: var(--primary);">R$ 0,00</span>
        </div>
        
        <% if (locals.estaAberto) { %>
            <button id="btn-finalizar" class="btn-confirm" onclick="finalizar()">Finalizar Pedido</button>
        <% } else { %>
            <button class="btn-confirm btn-disabled" disabled>Loja Fechada</button>
        <% } %>
        <button class="btn-close" onclick="toggleCart()">Continuar Comprando</button>
    </div>
</div>

<div id="modal-horarios" class="modal">
    <div class="modal-content modal-horarios-content">
        <h2 style="font-size: 1.2rem; margin-bottom: 10px;">Horário de atendimento</h2>
        <div class="lista-horarios">
            <% 
            const diasNomes = ['Domingo', 'Segunda-feira', 'Terça-feira', 'Quarta-feira', 'Quinta-feira', 'Sexta-feira', 'Sábado'];
            diasNomes.forEach((dia, i) => { 
                const cfg = locals.config || {};
                const agendaDia = (cfg.agenda && cfg.agenda[i]) ? cfg.agenda[i] : { aberto: false, inicio: '--:--', fim: '--:--' };
            %>
            <div class="item-horario">
                <span class="dia-nome"><%= dia %>:</span>
                <span class="dia-valor">
                    <%= agendaDia.aberto ? `${agendaDia.inicio.replace(':','h')} às ${agendaDia.fim.replace(':','h')}` : 'Fechado' %>
                </span>
            </div>
            <% }) %>
        </div>
        <button class="btn-close" onclick="document.getElementById('modal-horarios').style.display='none'" style="margin-top: 20px; width: 100%;">Fechar</button>
    </div>
</div>

<footer class="social-footer">
    <div class="status-container">
        <% if (locals.estaAberto) { %>
            <div class="status-badge status-aberto">● Aberto Agora</div>
        <% } else { %>
            <div class="status-badge status-fechado">● Fechado no Momento</div>
        <% } %>
        <p style="margin-bottom: 20px;">
            <span class="horario-link" onclick="document.getElementById('modal-horarios').style.display='flex'">
                Ver Horários de Funcionamento
            </span>
        </p>
    </div>
    <div class="social-buttons">
        <a href="https://www.instagram.com/guilherme_giuliani" target="_blank" class="social-icon"><i class="fa-brands fa-instagram"></i></a>
        <a href="https://wa.link/3s32fj" target="_blank" class="social-icon"><i class="fa-brands fa-whatsapp"></i></a>
    </div>
    <a href="#" class="btn-location"><i class="fa-solid fa-location-dot"></i> Ver localização</a>
    <span style="display:block; margin-top:20px; font-size:0.7rem; color:#bbb;">© 2026 Premium Delivery</span>
</footer>

<script>
    const socket = io();
    let carrinho = [];
    let produtoAtual = null;

    let configLocal = <%- JSON.stringify(estruturaAdicionais) %>;

    // --- NOVA LÓGICA DE CLIQUE E SISTEMA DUPLO ---
    function gerenciarCliqueProduto(status, temModificadores, nome, preco, desc, img, precoOriginal) {
        // Trava de Indisponível
        if (status === 'indisponivel') {
            alert("Este produto está indisponível no momento.");
            return;
        }

        if ("<%= locals.estaAberto %>" === "false") return alert("Estamos fechados no momento!");
        
        const idAtivo = localStorage.getItem('ultimoPedidoId');
        if (idAtivo) {
            alert("Você já possui um pedido em andamento! Finalize-o ou aguarde a conclusão para fazer um novo.");
            irParaStatus();
            return;
        }

        // Define o produto atual (preco já vem como o valor de venda/desconto)
        produtoAtual = { 
            nome, 
            precoBase: parseFloat(preco) || 0, 
            desc, 
            img, 
            temModificadores: temModificadores === 'true' 
        };

        abrirModalMontagem(nome, preco, desc, img, temModificadores === 'true');
    }

    function abrirModalMontagem(nome, preco, desc, img, temModificadores) {
        if(configLocal) {
            configLocal.categorias.forEach(cat => cat.opcoes.forEach(opt => opt.qtd = 0));
        }
        
        document.getElementById('m-img').src = img;
        document.getElementById('m-nome').innerText = nome;
        document.getElementById('m-desc').innerText = desc;
        document.getElementById('m-obs').value = "";
        
        const containerLógica = document.getElementById('container-adicionais-logic');
        
        if (temModificadores) {
            containerLógica.style.display = 'block';
            renderizarCategorias();
        } else {
            containerLógica.style.display = 'none';
        }

        atualizarTotalModal();
        document.getElementById('modal-montagem').style.display = 'flex';
    }

    function renderizarCategorias(filtro = "") {
        const container = document.getElementById('categorias-container');
        container.innerHTML = "";
        if(!configLocal) return;

        configLocal.categorias.forEach(cat => {
            let htmlOpcoes = "";
            cat.opcoes.forEach(opt => {
                if (filtro === "" || opt.nome.toLowerCase().includes(filtro.toLowerCase())) {
                    htmlOpcoes += `
                        <div class="item-add">
                            <div>
                                <div style="font-weight: 500;">${opt.nome}</div>
                                <div style="font-size:0.75rem; color:var(--primary);">${opt.preco > 0 ? '+ R$ '+opt.preco.toFixed(2) : 'Incluso'}</div>
                            </div>
                            <div class="item-controls">
                                <button class="btn-qty" onclick="alterarQtd('${cat.id}', '${opt.id}', -1)">-</button>
                                <span id="qtd-${opt.id}" style="font-weight: bold; min-width: 20px; text-align: center;">${opt.qtd}</span>
                                <button class="btn-qty" onclick="alterarQtd('${cat.id}', '${opt.id}', 1)">+</button>
                            </div>
                        </div>`;
                }
            });

            if (htmlOpcoes !== "") {
                container.innerHTML += `
                    <div class="cat-section">
                        <div class="cat-header">
                            <div style="font-weight:bold; color: var(--dark);">${cat.nome}</div>
                            <div style="font-size:0.7rem; color:#888;">${cat.descricao}</div>
                        </div>
                        ${htmlOpcoes}
                    </div>`;
            }
        });
    }

    function alterarQtd(catId, optId, delta) {
        const categoria = configLocal.categorias.find(c => c.id === catId);
        const opcao = categoria.opcoes.find(o => o.id === optId);
        const totalNaCategoria = categoria.opcoes.reduce((acc, curr) => acc + curr.qtd, 0);

        if (delta > 0 && totalNaCategoria >= categoria.limite) {
            return alert(`Limite máximo atingido para ${categoria.nome} (${categoria.limite} itens).`);
        }

        if (opcao.qtd + delta >= 0) {
            opcao.qtd += delta;
            document.getElementById(`qtd-${optId}`).innerText = opcao.qtd;
            atualizarTotalModal();
        }
    }

    function atualizarTotalModal() {
        let extra = 0;
        if (produtoAtual.temModificadores && configLocal) {
            configLocal.categorias.forEach(cat => {
                cat.opcoes.forEach(opt => { extra += (opt.preco * opt.qtd); });
            });
        }
        const total = (produtoAtual.precoBase || 0) + extra;
        document.getElementById('m-total').innerText = `R$ ${total.toFixed(2)}`;
    }

    function filtrarAdicionais(val) { renderizarCategorias(val); }

    function fecharModalMontagem() { document.getElementById('modal-montagem').style.display = 'none'; }

    function confirmarMontagem() {
        let selecionados = [];
        let precoFinal = produtoAtual.precoBase || 0;

        if (produtoAtual.temModificadores && configLocal) {
            configLocal.categorias.forEach(cat => {
                cat.opcoes.forEach(opt => {
                    if(opt.qtd > 0) {
                        selecionados.push({ nome: opt.nome, qtd: opt.qtd, preco: opt.preco });
                        precoFinal += (opt.preco * opt.qtd);
                    }
                });
            });
        }

        const obs = document.getElementById('m-obs').value;
        carrinho.push({
            id_temp: Date.now(),
            nome: produtoAtual.nome,
            preco: precoFinal,
            adicionais: selecionados,
            obs: obs
        });

        atualizarUI();
        fecharModalMontagem();
    }

    function removerDoCarrinho(id_temp) {
        carrinho = carrinho.filter(item => item.id_temp !== id_temp);
        atualizarUI();
    }

    function atualizarUI() {
        const cartCount = document.getElementById('cart-count');
        const btnFinalizar = document.getElementById('btn-finalizar');
        const idAtivo = localStorage.getItem('ultimoPedidoId');

        cartCount.innerText = carrinho.length;
        const lista = document.getElementById('cart-items');
        
        if(carrinho.length === 0) {
            lista.innerHTML = "<p style='text-align:center; color:#888; padding:20px;'>Seu carrinho está vazio.</p>";
        } else {
            lista.innerHTML = carrinho.map(i => `
                <div class="cart-item-row">
                    <div style="display:flex; justify-content:space-between; align-items: flex-start;">
                        <div>
                            <strong style="color: var(--dark);">${i.nome}</strong>
                            <div style="font-size:0.75rem; color:#666; margin-top:4px;">
                                ${i.adicionais.length > 0 ? i.adicionais.map(a => `${a.qtd}x ${a.nome}`).join(', ') : 'Sem adicionais'}
                            </div>
                            ${i.obs ? `<div style="font-size:0.75rem; color:var(--primary); font-style: italic;">Obs: ${i.obs}</div>` : ''}
                        </div>
                        <div style="display:flex; align-items:center;">
                            <b style="color: var(--dark);">R$ ${i.preco.toFixed(2)}</b>
                            <i class="fa-solid fa-trash-can remove-product" onclick="removerDoCarrinho(${i.id_temp})"></i>
                        </div>
                    </div>
                </div>
            `).join('');
        }
        
        const total = carrinho.reduce((acc, i) => acc + i.preco, 0);
        document.getElementById('cart-total').innerText = `R$ ${total.toFixed(2)}`;

        if (idAtivo && btnFinalizar) {
            btnFinalizar.disabled = true;
            btnFinalizar.innerText = "Você tem um pedido ativo";
            btnFinalizar.classList.add('btn-disabled');
            document.getElementById('status-alerta').style.display = 'block';
        } else if (btnFinalizar) {
            btnFinalizar.disabled = false;
            btnFinalizar.innerText = "Finalizar Pedido";
            btnFinalizar.classList.remove('btn-disabled');
            document.getElementById('status-alerta').style.display = 'none';
        }
    }

    function filtrarCategoria(categoria) {
        document.querySelectorAll('.cat-btn').forEach(btn => {
            btn.classList.remove('active');
            if(btn.innerText.trim() === categoria) btn.classList.add('active');
        });
        document.querySelectorAll('.card').forEach(card => {
            const catProduto = card.getAttribute('data-categoria');
            if (categoria === 'Todos' || catProduto === categoria) card.classList.remove('hidden');
            else card.classList.add('hidden');
        });
    }

    function toggleCart() {
        const m = document.getElementById('cart-modal');
        m.style.display = (m.style.display === 'flex') ? 'none' : 'flex';
        if (m.style.display === 'flex') atualizarUI();
    }

    async function finalizar() {
        const nome = document.getElementById('cliente-nome').value;
        const endereco = document.getElementById('cliente-end').value;
        const pagto = document.getElementById('cliente-pagto').value;
        const btnFinalizar = document.getElementById('btn-finalizar');
        
        if (localStorage.getItem('ultimoPedidoId')) return alert("Ação bloqueada: Você já possui um pedido ativo.");
        if(!nome || !endereco) return alert("Por favor, informe seu nome e endereço!");
        if(carrinho.length === 0) return alert("Seu carrinho está vazio!");

        btnFinalizar.disabled = true;
        btnFinalizar.innerText = "Processando...";
        btnFinalizar.classList.add('btn-disabled');

        try {
            const res = await fetch('/enviar-pedido', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    cliente: nome, 
                    endereco: endereco, 
                    pagamento: pagto,
                    itens: carrinho, 
                    total: carrinho.reduce((acc, i) => acc + i.preco, 0)
                })
            });
            
            if(res.ok) {
                const data = await res.json();
                localStorage.setItem('ultimoPedidoId', data.id);
                location.href = '/status/' + data.id;
            } else {
                alert("Ocorreu um erro ao processar seu pedido.");
                btnFinalizar.disabled = false;
                btnFinalizar.innerText = "Finalizar Pedido";
                btnFinalizar.classList.remove('btn-disabled');
            }
        } catch (error) {
            console.error(error);
            btnFinalizar.disabled = false;
            btnFinalizar.innerText = "Finalizar Pedido";
            btnFinalizar.classList.remove('btn-disabled');
        }
    }

    async function forcarLimpezaTravados() {
        const idSalvo = localStorage.getItem('ultimoPedidoId');
        if (idSalvo) {
            try {
                const res = await fetch('/api/pedido/' + idSalvo);
                const data = await res.json();
                
                if (!data.status || data.status === 'Finalizado' || data.status === 'Concluído' || data.status === 'Cancelado') {
                    localStorage.removeItem('ultimoPedidoId');
                    atualizarUI();
                } else {
                    document.getElementById('status-alerta').style.display = 'block';
                    socket.emit('join', idSalvo);
                }
            } catch (e) {
                console.log("Erro ao verificar status.");
            }
        }
    }

    function irParaStatus() {
        const id = localStorage.getItem('ultimoPedidoId');
        if (id) window.location.href = '/status/' + id;
    }

    socket.on('statusAtualizado', (data) => {
        const idSalvo = localStorage.getItem('ultimoPedidoId');
        if (data.id == idSalvo && (data.novoStatus === 'Finalizado' || data.novoStatus === 'Cancelado' || data.novoStatus === 'Concluído')) {
            localStorage.removeItem('ultimoPedidoId');
            atualizarUI();
        }
    });

    window.onload = function() {
        forcarLimpezaTravados();
        atualizarUI();
        filtrarCategoria('Todos');
    };
</script>
</body>
</html>