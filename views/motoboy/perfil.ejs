<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Meu Perfil | Motoboy</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #1a1a1a; color: white; margin: 0; padding: 20px; }
        .header { display: flex; align-items: center; gap: 15px; margin-bottom: 30px; }
        .btn-voltar { text-decoration: none; color: #FFD700; font-size: 1.5rem; }
        
        .perfil-container { background: #2d2d2d; padding: 20px; border-radius: 20px; }
        
        .foto-section { text-align: center; margin-bottom: 25px; position: relative; }
        .foto-preview {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 3px solid #FFD700;
            object-fit: cover;
            margin-bottom: 10px;
        }
        .upload-input { display: none; }
        .upload-label {
            background: #FFD700;
            color: #1a1a1a;
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: bold;
            cursor: pointer;
        }

        .form-group { margin-bottom: 20px; }
        label { display: block; color: #aaa; font-size: 0.9rem; margin-bottom: 5px; }
        input {
            width: 100%;
            padding: 12px;
            background: #444;
            border: 1px solid #555;
            border-radius: 10px;
            color: white;
            box-sizing: border-box;
        }
        .btn-salvar {
            width: 100%;
            padding: 15px;
            background: #27ae60;
            border: none;
            border-radius: 10px;
            color: white;
            font-weight: bold;
            cursor: pointer;
            margin-top: 10px;
        }
    </style>
</head>
<body>

    <div class="header">
        <a href="/motoboy/dashboard" class="btn-voltar">&#8592;</a>
        <h2>Configurações de Perfil</h2>
    </div>

    <div class="perfil-container">
        <form action="/motoboy/update-perfil" method="POST" enctype="multipart/form-data">
            
            <div class="foto-section">
                <img src="<%= motoboy.foto || '/img/default-user.png' %>" id="preview" class="foto-preview">
                <br>
                <label for="foto" class="upload-label">ALTERAR FOTO</label>
                <input type="file" id="foto" name="foto" class="upload-input" accept="image/*" onchange="readURL(this);">
            </div>

            <div class="form-group">
                <label>Nome Completo</label>
                <input type="text" name="nome" value="<%= motoboy.nome %>">
            </div>

            <div class="form-group">
                <label>E-mail de Acesso</label>
                <input type="email" name="email" value="<%= motoboy.email %>">
            </div>

            <div class="form-group">
                <label>Nova Senha (deixe em branco para não alterar)</label>
                <input type="password" name="nova_senha" placeholder="********">
            </div>

            <button type="submit" class="btn-salvar">SALVAR ALTERAÇÕES</button>
        </form>
    </div>

    <script>
        // Função para mostrar a foto na hora que selecionar o arquivo
        function readURL(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('preview').src = e.target.result;
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
</body>
</html>