<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="default-src 'self' https://*.gstatic.com https://*.googleapis.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://*.gstatic.com; style-src 'self' 'unsafe-inline' https://unpkg.com https://fonts.googleapis.com; img-src 'self' data: https://*.tile.openstreetmap.org https://unpkg.com https://*.gstatic.com; connect-src 'self' ws: wss:;">
    
    <title>Motoboy Dash | Entrega Ativa</title>
    
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="/socket.io/socket.io.js"></script>
    
    <style>
        :root {
            --primary: #FFD700;
            --dark: #1a1a1a;
            --card: #2d2d2d;
            --text: #ffffff;
            --success: #27ae60;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: var(--dark);
            color: var(--text);
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        /* Menu Lateral (Drawer) */
        .sidebar {
            height: 100%;
            width: 0;
            position: fixed;
            z-index: 2000;
            top: 0;
            left: 0;
            background-color: var(--card);
            overflow-x: hidden;
            transition: 0.5s;
            padding-top: 60px;
            box-shadow: 2px 0 10px rgba(0,0,0,0.5);
        }

        .sidebar a {
            padding: 15px 25px;
            text-decoration: none;
            font-size: 1.1rem;
            color: #ccc;
            display: block;
            transition: 0.3s;
        }

        .sidebar a:hover { color: var(--primary); }

        /* Header */
        header {
            background: var(--card);
            padding: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .perfil-topo {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
        }

        .foto-perfil {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid var(--primary);
            object-fit: cover;
        }

        #map {
            width: 100%;
            height: 300px;
            background: #333;
            margin-bottom: 10px;
            border-bottom: 3px solid var(--primary);
        }

        .container { padding: 15px; }

        .card-pedido {
            background: var(--card);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 15px;
            border-left: 5px solid var(--primary);
        }

        .btn-acao {
            width: 100%;
            padding: 15px;
            border: none;
            border-radius: 10px;
            font-weight: bold;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
        }

        .btn-aceitar { background: var(--primary); color: var(--dark); }
        .btn-finalizar { background: var(--success); color: white; display: none; }
        .btn-finalizar:disabled { background: #555; cursor: not-allowed; }

        .status-badge {
            font-size: 0.8rem;
            padding: 5px 10px;
            border-radius: 20px;
            background: rgba(255,215,0,0.2);
            color: var(--primary);
        }

        .detalhes-entrega {
            margin-top: 15px;
            border-top: 1px solid #444;
            padding-top: 15px;
        }

        .empty-state {
            text-align: center;
            padding: 40px;
            color: #888;
        }
    </style>
</head>
<body>

    <div id="mySidebar" class="sidebar">
        <a href="javascript:void(0)" onclick="closeNav()" style="font-size: 30px;">&times;</a>
        <div style="text-align: center; padding: 20px;">
            <img src="<%= motoboy.foto || '/img/default-user.png' %>" class="foto-perfil" style="width: 80px; height: 80px;">
            <h4><%= motoboy.nome %></h4>
        </div>
        <a href="/motoboy/dashboard">🛵 Entregas Disponíveis</a>
        <a href="/motoboy/perfil">⚙️ Meu Perfil</a>
        <a href="/logout" style="color: #ff4444;">🚪 Sair</a>
    </div>

    <header>
        <div onclick="openNav()" style="font-size: 24px; cursor: pointer;">&#9776;</div>
        <div class="perfil-topo" onclick="window.location.href='/motoboy/perfil'">
            <div style="text-align: right;">
                <div style="font-weight: bold; font-size: 0.9rem;"><%= motoboy.nome %></div>
                <div style="font-size: 0.7rem; color: var(--success);">Online</div>
            </div>
            <img src="<%= motoboy.foto || '/img/default-user.png' %>" class="foto-perfil">
        </div>
    </header>

    <div id="map"></div>

    <div class="container" id="app-content">
        <% if (typeof pedidos !== 'undefined' && pedidos.length > 0) { %>
            <% pedidos.forEach(pedido => { %>
                <div class="card-pedido" id="pedido-<%= pedido.id %>">
                    <div style="display: flex; justify-content: space-between;">
                        <span class="status-badge"><%= pedido.status.toUpperCase() %></span>
                        <strong>#<%= pedido.id %></strong>
                    </div>
                    <h3><%= pedido.cliente %></h3>
                    <p>📍 <%= pedido.endereco %></p>
                    
                    <div class="detalhes-entrega">
                        <strong>Itens:</strong>
                        <ul style="padding-left: 20px; font-size: 0.9rem; color: #ccc;">
                            <% pedido.itens.forEach(item => { %>
                                <li><%= item.quantidade %>x <%= item.nome %></li>
                            <% }) %>
                        </ul>
                        <hr style="border: 0.5px solid #444;">
                        <p><strong>Total: R$ <%= pedido.total.toFixed(2) %></strong></p>
                    </div>

                    <% if (pedido.status === 'Pronto para Entrega') { %>
                        <button class="btn-acao btn-aceitar" onclick="iniciarRota('<%= pedido.id %>')">ACEITAR E INICIAR ROTA</button>
                    <% } else if (pedido.status === 'Em Rota') { %>
                        <button class="btn-acao btn-finalizar" style="display: block;" onclick="finalizarEntrega('<%= pedido.id %>')">FINALIZAR ENTREGA</button>
                    <% } %>
                </div>
            <% }) %>
        <% } else { %>
            <div class="empty-state">
                <p>Nenhum pedido disponível para entrega no momento.</p>
            </div>
        <% } %>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        let map, markerMotoboy, markerDestino;
        const socket = io();

        function initMap() {
            // Inicia o mapa centralizado no Brasil caso não haja posição
            map = L.map('map').setView([-23.5505, -46.6333], 13);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
        }

        function iniciarRota(pedidoId) {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(position => {
                    const { latitude, longitude } = position.coords;
                    
                    socket.emit('update-status', { id: pedidoId, novoStatus: 'Em Rota' });
                    
                    // Envia localização em tempo real
                    setInterval(() => {
                        navigator.geolocation.getCurrentPosition(pos => {
                            socket.emit('atualizarLocalizacao', {
                                motoboyId: '<%= motoboy._id %>',
                                lat: pos.coords.latitude,
                                lng: pos.coords.longitude
                            });
                        });
                    }, 5000);

                    location.reload();
                });
            }
        }

        function finalizarEntrega(pedidoId) {
            if(confirm("Deseja finalizar esta entrega?")) {
                socket.emit('update-status', { id: pedidoId, novoStatus: 'Concluído' });
                alert("Entrega finalizada com sucesso!");
                location.reload();
            }
        }

        function openNav() { document.getElementById("mySidebar").style.width = "250px"; }
        function closeNav() { document.getElementById("mySidebar").style.width = "0"; }

        window.onload = initMap;
    </script>
</body>
</html>