<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="Content-Security-Policy" content="default-src 'self' https://*.gstatic.com https://*.googleapis.com https://*.tile.openstreetmap.org https://unpkg.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://*.gstatic.com; style-src 'self' 'unsafe-inline' https://unpkg.com https://fonts.googleapis.com; img-src 'self' data: https://*.tile.openstreetmap.org https://unpkg.com https://*.gstatic.com; connect-src 'self' ws: wss: https://router.project-osrm.org;">
    
    <title>Motoboy Dash | Entrega Ativa</title>
    
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.css" />
    
    <script src="/socket.io/socket.io.js"></script>
    
    <style>
        :root {
            --primary: #FFD700;
            --dark: #1a1a1a;
            --card: #2d2d2d;
            --text: #ffffff;
            --success: #27ae60;
            --danger: #ff4444;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: var(--dark);
            color: var(--text);
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        /* Menu Lateral */
        .sidebar {
            height: 100%;
            width: 0;
            position: fixed;
            z-index: 2000;
            top: 0;
            left: 0;
            background-color: var(--card);
            overflow-x: hidden;
            transition: 0.5s;
            padding-top: 60px;
            box-shadow: 2px 0 10px rgba(0,0,0,0.5);
        }

        .sidebar a {
            padding: 15px 25px;
            text-decoration: none;
            font-size: 1.1rem;
            color: #ccc;
            display: block;
            transition: 0.3s;
        }

        .sidebar a:hover { color: var(--primary); }

        header {
            background: var(--card);
            padding: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .perfil-topo {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
        }

        .foto-perfil {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 2px solid var(--primary);
            object-fit: cover;
        }

        #map {
            width: 100%;
            height: 350px;
            background: #333;
            border-bottom: 3px solid var(--primary);
        }

        .container { padding: 15px; }

        .card-pedido {
            background: var(--card);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 15px;
            border-left: 5px solid var(--primary);
        }

        .btn-acao {
            width: 100%;
            padding: 15px;
            border: none;
            border-radius: 10px;
            font-weight: bold;
            font-size: 1rem;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
        }

        .btn-aceitar { background: var(--primary); color: var(--dark); }
        .btn-finalizar { background: var(--success); color: white; }
        
        /* Botão desativado */
        .btn-finalizar:disabled {
            background: #555;
            cursor: not-allowed;
            opacity: 0.6;
        }

        .status-badge {
            font-size: 0.8rem;
            padding: 5px 10px;
            border-radius: 20px;
            background: rgba(255,215,0,0.2);
            color: var(--primary);
        }

        .detalhes-entrega {
            margin-top: 15px;
            border-top: 1px solid #444;
            padding-top: 15px;
        }

        #input-foto { display: none; }

        /* Esconder controles de instrução do mapa para focar na rota */
        .leaflet-routing-container { display: none; }
    </style>
</head>
<body>

    <div id="mySidebar" class="sidebar">
        <a href="javascript:void(0)" onclick="closeNav()" style="font-size: 30px;">&times;</a>
        <div style="text-align: center; padding: 20px;">
            <label for="input-foto">
                <img src="<%= motoboy.foto || '/img/default-user.png' %>" class="foto-perfil user-photo-update" style="width: 80px; height: 80px; cursor: pointer;" title="Clique para mudar a foto">
            </label>
            <input type="file" id="input-foto" accept="image/*" onchange="uploadFoto(this)">
            <h4 id="display-nome"><%= motoboy.nome %></h4>
        </div>
        <a href="/motoboy/dashboard">🛵 Entregas Disponíveis</a>
        <a href="/motoboy/perfil">⚙️ Meu Perfil</a>
        <a href="/logout" style="color: var(--danger);">🚪 Sair</a>
    </div>

    <header>
        <div onclick="openNav()" style="font-size: 24px; cursor: pointer;">&#9776;</div>
        <div class="perfil-topo" onclick="openNav()">
            <div style="text-align: right;">
                <div style="font-weight: bold; font-size: 0.9rem;"><%= motoboy.nome %></div>
                <div style="font-size: 0.7rem; color: var(--success);">Online</div>
            </div>
            <img src="<%= motoboy.foto || '/img/default-user.png' %>" class="foto-perfil user-photo-update">
        </div>
    </header>

    <div id="map"></div>

    <div class="container" id="app-content">
        <% if (typeof pedidos !== 'undefined' && pedidos.length > 0) { %>
            <% pedidos.forEach(pedido => { %>
                <div class="card-pedido" id="pedido-<%= pedido.id %>">
                    <div style="display: flex; justify-content: space-between;">
                        <span class="status-badge"><%= pedido.status.toUpperCase() %></span>
                        <strong>#<%= pedido.id %></strong>
                    </div>
                    <h3><%= pedido.cliente %></h3>
                    <p id="destino-<%= pedido.id %>">📍 <%= pedido.endereco %></p>
                    
                    <div class="detalhes-entrega">
                        <strong>Itens:</strong>
                        <ul style="padding-left: 20px; font-size: 0.9rem; color: #ccc;">
                            <% pedido.itens.forEach(item => { %>
                                <li><%= item.quantidade %>x <%= item.nome %></li>
                            <% }) %>
                        </ul>
                    </div>

                    <% if (pedido.status === 'Pronto para Entrega') { %>
                        <button class="btn-acao btn-aceitar" onclick="iniciarRota('<%= pedido.id %>', '<%= pedido.endereco %>')">ACEITAR E INICIAR ROTA</button>
                    <% } else if (pedido.status === 'Em Rota') { %>
                        <button class="btn-acao btn-finalizar" id="btn-finish-<%= pedido.id %>" disabled onclick="finalizarEntrega('<%= pedido.id %>')">CHEGUE AO DESTINO PARA FINALIZAR</button>
                        <p style="font-size: 0.8rem; color: var(--primary); text-align: center; margin-top: 5px;">Aproxime-se do cliente para liberar o botão.</p>
                    <% } %>
                </div>
            <% }) %>
        <% } else { %>
            <div style="text-align: center; padding: 40px; color: #666;">
                <p>Nenhum pedido disponível para entrega no momento.</p>
            </div>
        <% } %>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.js"></script>

    <script>
        let map;
        let routingControl;
        let userMarker;
        const socket = io();

        // 1. ARRUMADO: Upload de Foto via Fetch (Não abre página branca)
        async function uploadFoto(input) {
            if (input.files && input.files[0]) {
                const formData = new FormData();
                formData.append('foto', input.files[0]);

                try {
                    const response = await fetch('/motoboy/update-perfil', {
                        method: 'POST',
                        body: formData // Envia como Multipart para o servidor processar o arquivo
                    });

                    const result = await response.json();
                    if (result.success) {
                        document.querySelectorAll('.user-photo-update').forEach(img => {
                            img.src = result.novaFotoUrl || URL.createObjectURL(input.files[0]);
                        });
                    }
                } catch (err) {
                    console.error("Erro no upload:", err);
                }
            }
        }

        // 2. ARRUMADO: Mapa com Rota em Tempo Real e Trava de Botão
        function initMap() {
            map = L.map('map').setView([-23.5505, -46.6333], 13);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
            
            // Tenta iniciar a localização se houver entrega ativa
            <% if (pedidos.some(p => p.status === 'Em Rota')) { %>
                const enderecoDestino = "<%= pedidos.find(p => p.status === 'Em Rota')?.endereco %>";
                const pedidoId = "<%= pedidos.find(p => p.status === 'Em Rota')?.id %>";
                trazarRota(enderecoDestino, pedidoId);
            <% } %>
        }

        async function trazarRota(endereco, pedidoId) {
            if (!navigator.geolocation) return alert("GPS não suportado.");

            // Pegar coordenadas do endereço via Nominatim (Geocoding)
            const geoRes = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(endereco)}`);
            const geoData = await geoRes.json();
            if (!geoData.length) return;

            const destCoords = L.latLng(geoData[0].lat, geoData[0].lon);

            navigator.geolocation.watchPosition(pos => {
                const userCoords = L.latLng(pos.coords.latitude, pos.coords.longitude);
                
                // Atualiza marcador do Motoboy
                if (!userMarker) {
                    userMarker = L.marker(userCoords).addTo(map);
                } else {
                    userMarker.setLatLng(userCoords);
                }

                // Cria/Atualiza a linha amarela de rota
                if (routingControl) map.removeControl(routingControl);

                routingControl = L.Routing.control({
                    waypoints: [userCoords, destCoords],
                    lineOptions: { styles: [{ color: '#FFD700', weight: 6 }] }, // LINHA AMARELA
                    createMarker: function() { return null; }, // Esconde marcadores padrão do routing
                    routeWhileDragging: false,
                    addWaypoints: false
                }).addTo(map);

                // Verifica distância para liberar botão (Menos de 100 metros)
                const dist = userCoords.distanceTo(destCoords);
                const btn = document.getElementById(`btn-finish-${pedidoId}`);
                if (btn && dist < 100) { 
                    btn.disabled = false;
                    btn.innerHTML = "FINALIZAR ENTREGA AGORA";
                    btn.style.background = "#27ae60";
                }
            }, err => console.error(err), { enableHighAccuracy: true });
        }

        async function iniciarRota(pedidoId, endereco) {
            socket.emit('update-status', { id: pedidoId, novoStatus: 'Em Rota' });
            setTimeout(() => location.reload(), 500);
        }

        function finalizarEntrega(pedidoId) {
            if(confirm("Deseja finalizar esta entrega?")) {
                socket.emit('update-status', { id: pedidoId, novoStatus: 'Concluído' });
                location.reload();
            }
        }

        function openNav() { document.getElementById("mySidebar").style.width = "250px"; }
        function closeNav() { document.getElementById("mySidebar").style.width = "0"; }

        window.onload = initMap;
    </script>
</body>
</html>