<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ELITE OPS | Kitchen Display System</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.0/firebase-database-compat.js"></script>
    <style>
        :root {
            --bg-deep: #020203;
            --bg-surface: #0a0a0c;
            --bg-card: #121217;
            --accent-primary: #8257e5;
            --accent-glow: rgba(130, 87, 229, 0.4);
            --text-main: #e1e1e6;
            --text-dim: #a8a8b3;
            --status-pending: #ffb86c;
            --status-preparing: #8be9fd;
            --status-ready: #50fa7b;
            --status-alert: #ff4b4b;
            --border-color: rgba(255, 255, 255, 0.06);
            --transition-smooth: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background-color: var(--bg-deep);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            overflow: hidden; 
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        body::before {
            content: '';
            position: absolute;
            top: -10%; left: -10%;
            width: 40%; height: 40%;
            background: var(--accent-glow);
            filter: blur(150px);
            z-index: -1;
            border-radius: 50%;
        }

        header {
            height: 70px;
            padding: 0 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(10, 10, 12, 0.9);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--border-color);
            z-index: 100;
        }

        .brand { font-size: 1.2rem; font-weight: 800; text-transform: uppercase; }
        .brand span { color: var(--accent-primary); }

        .slow-mode-container {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(255, 255, 255, 0.03);
            padding: 5px 15px;
            border-radius: 20px;
            border: 1px solid var(--border-color);
        }

        .slow-mode-label { font-size: 0.7rem; font-weight: 700; color: var(--text-dim); }

        .switch { position: relative; display: inline-block; width: 40px; height: 20px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider {
            position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0;
            background-color: #333; transition: .4s; border-radius: 20px;
        }
        .slider:before {
            position: absolute; content: ""; height: 14px; width: 14px;
            left: 3px; bottom: 3px; background-color: white; transition: .4s; border-radius: 50%;
        }
        input:checked + .slider { background-color: var(--status-alert); }
        input:checked + .slider:before { transform: translateX(20px); }

        .metrics-bar {
            background: rgba(255, 255, 255, 0.02);
            border-bottom: 1px solid var(--border-color);
            display: flex;
            justify-content: space-around;
            padding: 10px 0;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            color: var(--text-dim);
        }

        .metric-item span { color: var(--status-ready); font-weight: 700; margin-left: 5px; }

        nav.tab-bar {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            background: var(--bg-surface);
            border-bottom: 1px solid var(--border-color);
        }

        .tab-btn {
            background: transparent; border: none; color: var(--text-dim);
            padding: 15px 5px; font-weight: 600; font-size: 0.85rem;
            cursor: pointer; transition: var(--transition-smooth);
            display: flex; flex-direction: column; align-items: center;
            gap: 5px; position: relative; text-transform: uppercase;
        }

        .tab-btn.active { color: var(--text-main); }
        .tab-btn.active::after {
            content: ''; position: absolute; bottom: 0; width: 40%; height: 3px;
            background: var(--accent-primary); border-radius: 10px 10px 0 0;
            box-shadow: 0 -2px 10px var(--accent-primary);
        }

        .badge-tab {
            font-size: 0.7rem; background: rgba(255,255,255,0.05);
            padding: 2px 8px; border-radius: 10px; border: 1px solid var(--border-color);
        }

        .content-area { flex-grow: 1; position: relative; overflow: hidden; }

        .kanban-column {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            display: none; flex-direction: column; padding: 20px; align-items: center;
        }

        .kanban-column.active { display: flex; animation: fadeIn 0.3s ease; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateX(10px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .orders-scroll {
            overflow-y: auto; flex-grow: 1; width: 100%;
            display: flex; flex-direction: column; align-items: center; padding-bottom: 100px;
        }

        .order-card {
            background: var(--bg-card); border-radius: 18px; padding: 20px;
            margin-bottom: 15px; border: 1px solid var(--border-color);
            cursor: pointer; transition: var(--transition-smooth);
            width: 100%; max-width: 450px;
        }

        .order-card.delayed {
            border-color: var(--status-alert) !important;
            animation: alertPulse 2s infinite;
        }

        @keyframes alertPulse {
            0%, 100% { box-shadow: 0 0 0px rgba(255, 75, 75, 0); }
            50% { box-shadow: 0 0 20px rgba(255, 75, 75, 0.3); }
        }

        .order-card:hover { border-color: var(--accent-primary); transform: translateY(-2px); }
        .order-header { display: flex; justify-content: space-between; margin-bottom: 10px; }
        .order-id { font-family: 'JetBrains Mono', monospace; color: var(--accent-primary); font-weight: 700; }
        .customer-name { font-size: 1.2rem; font-weight: 700; margin-bottom: 5px; }

        #modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.95); display: none; justify-content: center;
            align-items: flex-start; overflow-y: auto; padding: 40px 0; z-index: 1000;
            backdrop-filter: blur(10px);
        }

        .comanda-digital {
            background: #fff; color: #1a1a1a; width: 90%; max-width: 380px;
            padding: 30px; border-radius: 4px; font-family: 'JetBrains Mono', monospace;
            position: relative;
        }

        .ticket-header { text-align: center; border-bottom: 2px dashed #333; padding-bottom: 15px; margin-bottom: 20px; }
        .ticket-item { display: flex; justify-content: space-between; margin: 8px 0; }
        .ticket-total { border-top: 2px solid #000; margin-top: 20px; padding-top: 10px; font-size: 1.4rem; font-weight: 800; text-align: right; }
        
        .actions-bar { margin-top: 30px; display: flex; flex-direction: column; gap: 10px; }
        .btn { padding: 18px; border-radius: 12px; border: none; font-weight: 800; cursor: pointer; text-transform: uppercase; }
        .btn-confirm { background: var(--accent-primary); color: white; }
        .btn-cancel { background: var(--status-alert); color: white; }
        .btn-close { background: #e0e0e0; color: #333; }

        .cancel-reason-box { display: none; flex-direction: column; gap: 10px; margin-top: 10px; }
        .cancel-reason-box textarea { padding: 10px; border-radius: 8px; border: 1px solid #ddd; resize: none; }
    </style>
</head>
<body>

    <header>
        <div class="brand">ELITE<span>OPS</span></div>
        
        <div class="slow-mode-container">
            <span class="slow-mode-label">MODO LENTO</span>
            <label class="switch">
                <input type="checkbox" id="slow-mode-toggle" onchange="toggleSlowMode()">
                <span class="slider"></span>
            </label>
        </div>

        <div id="clock" style="font-family: 'JetBrains Mono'; color: var(--accent-primary); font-weight: 700;">00:00:00</div>
        <div id="status-online" style="font-size: 0.7rem; color: var(--status-ready)">● SISTEMA ATIVO</div>
    </header>

    <div class="metrics-bar">
        <div class="metric-item">FATURAMENTO HOJE: <span id="m-revenue">R$ 0,00</span></div>
        <div class="metric-item">TOTAL PEDIDOS: <span id="m-total-count">0</span></div>
    </div>

    <nav class="tab-bar">
        <button class="tab-btn active" onclick="switchTab('pendente')">
            <span class="badge-tab" id="count-pendente">0</span> Pendentes
        </button>
        <button class="tab-btn" onclick="switchTab('preparo')">
            <span class="badge-tab" id="count-preparo">0</span> Preparo
        </button>
        <button class="tab-btn" onclick="switchTab('pronto')">
            <span class="badge-tab" id="count-pronto">0</span> Prontos
        </button>
        <button class="tab-btn" onclick="switchTab('finalizado')">
            <span class="badge-tab" id="count-finalizado">0</span> Histórico
        </button>
    </nav>

    <main class="content-area">
        <section id="tab-pendente" class="kanban-column active"><div class="orders-scroll" id="list-pendente"></div></section>
        <section id="tab-preparo" class="kanban-column"><div class="orders-scroll" id="list-preparo"></div></section>
        <section id="tab-pronto" class="kanban-column"><div class="orders-scroll" id="list-pronto"></div></section>
        <section id="tab-finalizado" class="kanban-column"><div class="orders-scroll" id="list-finalizado"></div></section>
    </main>

    <div id="modal-overlay">
        <div class="comanda-digital" id="comanda-target"></div>
    </div>

    <script>
        // Configuração Firebase (Injetada pelo backend)
        const firebaseConfig = {
            apiKey: "<%= firebaseConfig.apiKey %>",
            authDomain: "<%= firebaseConfig.authDomain %>",
            databaseURL: "<%= firebaseConfig.databaseURL %>",
            projectId: "<%= firebaseConfig.projectId %>",
            storageBucket: "<%= firebaseConfig.storageBucket %>",
            messagingSenderId: "<%= firebaseConfig.messagingSenderId %>",
            appId: "<%= firebaseConfig.appId %>"
        };
        firebase.initializeApp(firebaseConfig);
        const database = firebase.database();

        let allOrders = {};
        const notificationSound = new Audio('https://assets.mixkit.co/active_storage/sfx/2358/2358-preview.mp3');

        // Escuta pedidos em tempo real
        database.ref('pedidos').on('value', (snapshot) => {
            allOrders = snapshot.val() || {};
            render();
        });

        function render() {
            const lists = {
                pendente: document.getElementById('list-pendente'),
                preparo: document.getElementById('list-preparo'),
                pronto: document.getElementById('list-pronto'),
                finalizado: document.getElementById('list-finalizado')
            };

            const counts = { pendente: 0, preparo: 0, pronto: 0, finalizado: 0 };
            let revenue = 0;

            Object.values(lists).forEach(l => l.innerHTML = '');

            Object.keys(allOrders).forEach(id => {
                const order = allOrders[id];
                const status = order.status || 'pendente';
                
                if (status !== 'cancelado') {
                    counts[status]++;
                    if (status === 'finalizado') revenue += parseFloat(order.total || 0);

                    const card = document.createElement('div');
                    card.className = 'order-card';
                    card.onclick = () => showComanda(id, order);

                    // Lógica de Atraso (15 min)
                    const waitTime = (Date.now() - order.timestamp) / 1000 / 60;
                    if (waitTime > 15 && status !== 'pronto' && status !== 'finalizado') {
                        card.classList.add('delayed');
                    }

                    card.innerHTML = `
                        <div class="order-header">
                            <span class="order-id">#${id.slice(-4)}</span>
                            <span class="order-time">${order.hora}</span>
                        </div>
                        <div class="customer-name">${order.cliente.nome}</div>
                        <div style="font-size: 0.8rem; color: var(--text-dim)">
                            ${order.itens.length} itens • <strong>${order.pagamento}</strong>
                        </div>
                    `;
                    if (lists[status]) lists[status].appendChild(card);
                }
            });

            // Atualiza interface
            document.getElementById('m-revenue').innerText = `R$ ${revenue.toFixed(2)}`;
            document.getElementById('m-total-count').innerText = counts.finalizado;
            Object.keys(counts).forEach(s => {
                const el = document.getElementById(`count-${s}`);
                if (el) el.innerText = counts[s];
            });
        }

        function showComanda(id, order) {
            const target = document.getElementById('comanda-target');
            let actionBtn = "";

            if (order.status === 'pendente') 
                actionBtn = `<button class="btn btn-confirm" onclick="updateStatus('${id}', 'preparo')">INICIAR PRODUÇÃO</button>`;
            else if (order.status === 'preparo') 
                actionBtn = `<button class="btn btn-confirm" onclick="updateStatus('${id}', 'pronto')">MARCAR COMO PRONTO</button>`;
            else if (order.status === 'pronto')
                actionBtn = `<button class="btn btn-confirm" onclick="updateStatus('${id}', 'finalizado')">FINALIZAR PEDIDO</button>`;

            target.innerHTML = `
                <div class="ticket-header">
                    <p>ELITE OPS</p>
                    <h1>#${id.slice(-4)}</h1>
                    <p>${order.hora}</p>
                </div>
                <div style="margin-bottom:15px">
                    <strong>CLIENTE:</strong> ${order.cliente.nome}<br>
                    <strong>TEL:</strong> ${order.cliente.telefone}
                </div>
                ${order.itens.map(i => `
                    <div class="ticket-item">
                        <span>${i.quantidade}x ${i.nome}</span>
                        <span>R$ ${(i.quantidade * i.preco).toFixed(2)}</span>
                    </div>
                `).join('')}
                <div class="ticket-total">TOTAL R$ ${parseFloat(order.total).toFixed(2)}</div>
                
                <div class="actions-bar">
                    ${actionBtn}
                    <button class="btn btn-cancel" onclick="document.getElementById('cancel-box').style.display='flex'">CANCELAR</button>
                    <div id="cancel-box" class="cancel-reason-box">
                        <textarea id="reason-input" placeholder="Motivo..."></textarea>
                        <button class="btn btn-cancel" onclick="cancelOrder('${id}')">CONFIRMAR CANCELAR</button>
                    </div>
                    <button class="btn btn-close" onclick="closeModal()">VOLTAR</button>
                </div>
            `;
            document.getElementById('modal-overlay').style.display = 'flex';
        }

        function updateStatus(id, newStatus) {
            database.ref(`pedidos/${id}`).update({ status: newStatus })
                .then(() => { closeModal(); switchTab(newStatus); });
        }

        function cancelOrder(id) {
            const reason = document.getElementById('reason-input').value;
            if (!reason) return alert("Informe o motivo");
            database.ref(`pedidos/${id}`).update({ status: 'cancelado', motivoCancelamento: reason })
                .then(() => closeModal());
        }

        function switchTab(tabId) {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.kanban-column').forEach(c => c.classList.remove('active'));
            const btn = document.querySelector(`button[onclick="switchTab('${tabId}')"]`);
            if (btn) btn.classList.add('active');
            const col = document.getElementById(`tab-${tabId}`);
            if (col) col.classList.add('active');
        }

        function toggleSlowMode() {
            const isSlow = document.getElementById('slow-mode-toggle').checked;
            const status = document.getElementById('status-online');
            status.style.color = isSlow ? 'var(--status-alert)' : 'var(--status-ready)';
            status.innerText = isSlow ? '● ALERTA DE ALTA DEMANDA' : '● SISTEMA ATIVO';
        }

        function closeModal() { document.getElementById('modal-overlay').style.display = 'none'; }

        setInterval(() => {
            document.getElementById('clock').innerText = new Date().toLocaleTimeString('pt-BR');
        }, 1000);
    </script>
</body>
</html>