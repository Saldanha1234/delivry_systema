<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Farol da Operação | Painel Profissional</title>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        :root {
            --bg-page: #0f172a; /* Azul escuro profundo */
            --bg-col: #1e293b;
            --card-bg: #ffffff;
            --text-dark: #1e293b;
            --text-light: #64748b;
            --primary: #ef4444; /* Vermelho vibrante */
            --warning: #f59e0b; /* Laranja forte */
            --success: #10b981; /* Verde esmeralda */
            --info: #3b82f6;    /* Azul royal */
            --finalizado: #6b7280;
            --accent: #8b5cf6;  /* Roxo para destaque */
        }

        body {
            font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
            background-color: var(--bg-page);
            color: #f8fafc;
            margin: 0;
            padding: 10px;
            overflow-x: hidden;
        }

        /* HEADER */
        .header-painel {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            gap: 15px;
            background: #1e293b;
            padding: 15px 20px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            border: 1px solid #334155;
        }

        .header-left { 
            display: flex; 
            align-items: center; 
            gap: 20px; 
            flex: 1;
            min-width: 280px;
        }

        .header-title {
            display: flex;
            flex-direction: column;
            line-height: 1.2;
        }

        #real-time-clock {
            font-family: 'Courier New', monospace;
            font-size: 1.4rem;
            color: var(--success);
            font-weight: bold;
            text-shadow: 0 0 10px rgba(16, 185, 129, 0.3);
        }

        .search-container { flex-grow: 1; max-width: 400px; }

        .search-input {
            width: 100%;
            padding: 12px 18px;
            border-radius: 10px;
            border: 1px solid #334155;
            background: #0f172a;
            color: white;
            outline: none;
            font-size: 0.95rem;
        }

        .search-input:focus { border-color: var(--info); }

        .btn-sair {
            text-decoration: none; 
            color: #fff; 
            background: #475569;
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: bold;
            transition: 0.3s;
        }

        /* NAVEGAÇÃO POR ABAS (MOBILE APENAS) */
        .mobile-tabs {
            display: none;
            gap: 5px;
            overflow-x: auto;
            margin-bottom: 15px;
            padding-bottom: 5px;
        }

        .tab-btn {
            background: #334155;
            color: white;
            border: none;
            padding: 10px 15px;
            border-radius: 8px;
            white-space: nowrap;
            font-size: 0.8rem;
            font-weight: bold;
        }

        .tab-btn.active {
            background: var(--info);
        }

        /* KANBAN */
        .kanban {
            display: flex;
            gap: 15px;
            overflow-x: auto;
            height: calc(100vh - 180px);
            align-items: flex-start;
        }

        .col {
            background-color: var(--bg-col);
            border-radius: 12px;
            min-width: 300px;
            max-width: 300px;
            display: flex;
            flex-direction: column;
            max-height: 100%;
            border: 1px solid #334155;
        }

        .col-header {
            padding: 15px;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.85rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: #94a3b8;
            background: rgba(0,0,0,0.2);
            border-radius: 12px 12px 0 0;
        }

        .count-badge {
            background: var(--info);
            color: #fff;
            border-radius: 6px;
            padding: 2px 8px;
            font-size: 0.8rem;
        }

        .lista-pedidos { padding: 12px; overflow-y: auto; flex-grow: 1; }

        /* CARDS */
        .mini-card {
            background: var(--card-bg);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 15px;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.4);
            border-left: 5px solid var(--info);
            color: var(--text-dark);
            transition: transform 0.2s;
        }

        .mini-card:hover { transform: translateY(-2px); }

        .status-pendente { border-left-color: var(--primary); }
        .status-preparando { border-left-color: var(--warning); }
        .status-pronto { border-left-color: var(--success); }
        .status-rota { border-left-color: var(--info); }

        .waiting-text { font-size: 0.8rem; font-weight: 700; margin-bottom: 8px; display: block; }
        .mini-card-id { font-size: 1.6rem; font-weight: 900; color: #000; display: block; }
        .mini-card-cliente { font-size: 1rem; color: #475569; font-weight: 500; margin-bottom: 15px; display: block; }

        /* BOTÕES */
        .btn-main {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 8px;
            font-weight: 800;
            cursor: pointer;
            margin-bottom: 8px;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.5px;
        }

        .btn-aceitar { background: var(--primary); color: white; box-shadow: 0 4px 0 #b91c1c; }
        .btn-pronto { background: var(--success); color: white; box-shadow: 0 4px 0 #059669; }
        .btn-enviar { background: var(--info); color: white; box-shadow: 0 4px 0 #2563eb; }
        .btn-finalizar { background: var(--finalizado); color: white; }
        .btn-detalhe { background: #f1f5f9; color: #1e293b; border: 1px solid #cbd5e1; }
        .btn-cancelar { background: #fff1f2; color: #e11d48; margin-top: 5px; }

        /* MODAL */
        .modal {
            display: none; position: fixed; z-index: 1000;
            left: 0; top: 0; width: 100%; height: 100%;
            background: rgba(15, 23, 42, 0.9); justify-content: center; align-items: center;
            backdrop-filter: blur(8px);
        }
        .modal-content { 
            background: white; padding: 25px; border-radius: 15px; 
            width: 90%; max-width: 500px; color: var(--text-dark);
        }

        @media (max-width: 768px) {
            .mobile-tabs { display: flex; }
            .kanban { display: block; height: auto; }
            .col { 
                min-width: 100%; 
                max-width: 100%; 
                display: none; /* Escondido por padrão, controlado por JS */
                margin-bottom: 20px;
            }
            .col.active { display: flex; }
            .header-painel { text-align: center; }
            .header-left { justify-content: center; }
            #real-time-clock { font-size: 1.8rem; margin: 10px 0; }
        }
    </style>
</head>
<body>

    <header class="header-painel">
        <div class="header-left">
            <div class="header-title">
                <small style="color:var(--info); font-weight: bold;">SISTEMA OPERACIONAL</small>
                <strong>FAROL DA OPERAÇÃO</strong>
            </div>
            <div id="real-time-clock">00:00:00</div>
        </div>
        <div class="search-container">
            <input type="text" id="searchInput" class="search-input" placeholder="🔍 Buscar cliente ou pedido...">
        </div>
        <a href="/admin" class="btn-sair">SAIR</a>
    </header>

    <div class="mobile-tabs">
        <button class="tab-btn active" onclick="showTab(0)">Pendente</button>
        <button class="tab-btn" onclick="showTab(1)">Preparo</button>
        <button class="tab-btn" onclick="showTab(2)">Pronto</button>
        <button class="tab-btn" onclick="showTab(3)">Rota</button>
        <button class="tab-btn" onclick="showTab(4)">Concluído</button>
    </div>

    <div class="kanban">
        <div class="col active">
            <div class="col-header">PENDENTES <span class="count-badge"><%= pedidos.filter(p => p.status === 'Pendente').length %></span></div>
            <div class="lista-pedidos" id="pendentes">
                <% pedidos.filter(p => p.status === 'Pendente').forEach(p => { %>
                    <div class="mini-card status-pendente search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>" data-time="<%= p.createdAt %>">
                        <span class="waiting-text label-topo" id="label-topo-<%= p.id %>"></span>
                        <span class="mini-card-id">#<%= p.id.toString().slice(-4) %></span>
                        <span class="mini-card-cliente"><%= p.cliente %></span>
                        <div id="btn-area-<%= p.id %>">
                            <button class="btn-main btn-aceitar" onclick="atualizarStatus('<%= p.id %>', 'Preparando')">Aceitar Pedido</button>
                        </div>
                        <button class="btn-main btn-detalhe" onclick="abrirDetalhes('<%= p.id %>')">Ver Detalhes</button>
                        <button class="btn-main btn-cancelar" onclick="cancelarPedido('<%= p.id %>')">Cancelar</button>
                        <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="col">
            <div class="col-header">EM PREPARO <span class="count-badge"><%= pedidos.filter(p => p.status === 'Preparando').length %></span></div>
            <div class="lista-pedidos">
                <% pedidos.filter(p => p.status === 'Preparando').forEach(p => { %>
                    <div class="mini-card status-preparando search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>" data-time="<%= p.updatedAt %>">
                        <span class="waiting-text label-topo" id="label-topo-<%= p.id %>"></span>
                        <span class="mini-card-id">#<%= p.id.toString().slice(-4) %></span>
                        <span class="mini-card-cliente"><%= p.cliente %></span>
                        <div id="btn-area-<%= p.id %>"></div>
                        <button class="btn-main btn-detalhe" onclick="abrirDetalhes('<%= p.id %>')">Detalhes</button>
                        <button class="btn-main btn-cancelar" onclick="cancelarPedido('<%= p.id %>')">Cancelar</button>
                        <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="col">
            <div class="col-header">PRONTO <span class="count-badge"><%= pedidos.filter(p => p.status === 'Pronto').length %></span></div>
            <div class="lista-pedidos">
                <% pedidos.filter(p => p.status === 'Pronto').forEach(p => { %>
                    <div class="mini-card status-pronto search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>" data-time="<%= p.updatedAt %>">
                        <span class="waiting-text label-topo" id="label-topo-<%= p.id %>"></span>
                        <span class="mini-card-id">#<%= p.id.toString().slice(-4) %></span>
                        <span class="mini-card-cliente"><%= p.cliente %></span>
                        <div id="btn-area-<%= p.id %>">
                            <button class="btn-main btn-enviar" onclick="atualizarStatus('<%= p.id %>', 'Saiu para Entrega')">Enviar para Rota</button>
                        </div>
                        <button class="btn-main btn-detalhe" onclick="abrirDetalhes('<%= p.id %>')">Detalhes</button>
                        <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="col">
            <div class="col-header">EM ROTA <span class="count-badge"><%= pedidos.filter(p => p.status === 'Saiu para Entrega').length %></span></div>
            <div class="lista-pedidos">
                <% pedidos.filter(p => p.status === 'Saiu para Entrega').forEach(p => { %>
                    <div class="mini-card status-rota search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>">
                        <span class="waiting-text" style="color:var(--info)">🛵 EM ENTREGA</span>
                        <span class="mini-card-id">#<%= p.id.toString().slice(-4) %></span>
                        <span class="mini-card-cliente"><%= p.cliente %></span>
                        <button class="btn-main btn-finalizar" onclick="atualizarStatus('<%= p.id %>', 'Finalizado')">Finalizar</button>
                        <button class="btn-main btn-detalhe" onclick="abrirDetalhes('<%= p.id %>')">Detalhes</button>
                        <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="col">
            <div class="col-header">CONCLUÍDO <span class="count-badge"><%= pedidos.filter(p => p.status === 'Finalizado').length %></span></div>
            <div class="lista-pedidos">
                <% pedidos.filter(p => p.status === 'Finalizado').forEach(p => { %>
                    <div class="mini-card search-item" style="border-left-color:#cbd5e1" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>">
                        <span class="waiting-text" style="color:var(--finalizado)">✅ CONCLUÍDO</span>
                        <span class="mini-card-id">#<%= p.id.toString().slice(-4) %></span>
                        <span class="mini-card-cliente"><%= p.cliente %></span>
                        <button class="btn-main btn-detalhe" onclick="abrirDetalhes('<%= p.id %>')">Ver Comanda</button>
                        <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>

    <div id="modalDetalhes" class="modal">
        <div class="modal-content">
            <div id="comanda-interna"></div>
            <button class="btn-main" onclick="fecharModal()" style="margin-top:15px; background: #1e293b; color: #fff;">FECHAR</button>
        </div>
    </div>

    <audio id="audioNotificacao" src="/notificacao.mp3" preload="auto"></audio>

    <script>
        const socket = io();

        // RELÓGIO EM TEMPO REAL
        function startClock() {
            const clockElement = document.getElementById('real-time-clock');
            setInterval(() => {
                const now = new Date();
                clockElement.innerText = now.toLocaleTimeString('pt-BR');
            }, 1000);
        }
        startClock();

        // CONTROLE DE ABAS MOBILE
        function showTab(index) {
            const cols = document.querySelectorAll('.col');
            const btns = document.querySelectorAll('.tab-btn');
            cols.forEach((c, i) => c.classList.toggle('active', i === index));
            btns.forEach((b, i) => b.classList.toggle('active', i === index));
        }

        function updateFarol() {
            const now = new Date();
            const cards = document.querySelectorAll('.mini-card[data-time]');

            cards.forEach(card => {
                const id = card.getAttribute('data-id');
                const startTime = new Date(card.getAttribute('data-time'));
                const diffMin = Math.floor((now - startTime) / 60000);
                const labelTopo = card.querySelector('.label-topo');
                const btnArea = card.querySelector(`#btn-area-${id}`);
                const colHeader = card.closest('.col').querySelector('.col-header').innerText;

                if (colHeader.includes("PENDENTES")) {
                    if (diffMin >= 5) {
                        labelTopo.innerHTML = `<span style="color:var(--primary)">⚠️ ATRASADO: ${diffMin} MIN</span>`;
                        btnArea.innerHTML = `<button class="btn-main btn-aceitar" onclick="atualizarStatus('${id}', 'Preparando')">Aceitar Urgente</button>`;
                    } else {
                        labelTopo.innerHTML = `<span style="color:var(--text-light)">Recebido há ${diffMin} min</span>`;
                    }
                }

                if (colHeader.includes("PREPARO")) {
                    if (diffMin < 5) {
                        labelTopo.innerHTML = `<span style="color:var(--warning)">👨‍🍳 PREPARANDO... (${5 - diffMin} min)</span>`;
                        btnArea.innerHTML = `<button class="btn-main" style="background:#e2e8f0; color:#94a3b8; cursor:not-allowed">Em preparo</button>`;
                    } else {
                        labelTopo.innerHTML = `<span style="color:var(--success)">✅ PRONTO PARA SAIR</span>`;
                        btnArea.innerHTML = `<button class="btn-main btn-pronto" onclick="atualizarStatus('${id}', 'Pronto')">Marcar Pronto</button>`;
                    }
                }

                if (colHeader.includes("PRONTO")) {
                    labelTopo.innerHTML = diffMin >= 15 
                        ? `<span style="color:var(--primary)">⚠️ PARADO HÁ ${diffMin} MIN</span>` 
                        : `<span style="color:var(--success)">AGUARDANDO COLETA (${diffMin} MIN)</span>`;
                }
            });
        }

        setInterval(updateFarol, 5000);
        updateFarol();

        // BUSCA
        document.getElementById('searchInput').addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            document.querySelectorAll('.search-item').forEach(item => {
                const searchStr = item.getAttribute('data-cliente') + item.getAttribute('data-id');
                item.style.display = searchStr.includes(term) ? 'block' : 'none';
            });
        });

        async function atualizarStatus(id, novoStatus) {
            try {
                const res = await fetch('/update-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, novoStatus })
                });
                if (res.ok) window.location.reload();
            } catch (err) { console.error(err); }
        }

        async function cancelarPedido(id) {
            if (confirm("Deseja realmente CANCELAR este pedido?")) atualizarStatus(id, 'Cancelado');
        }

        function abrirDetalhes(id) {
            const wrapper = document.getElementById(`wrapper-${id}`);
            if(wrapper) {
                document.getElementById('comanda-interna').innerHTML = wrapper.innerHTML;
                document.getElementById('modalDetalhes').style.display = "flex";
            }
        }
        function fecharModal() { document.getElementById('modalDetalhes').style.display = "none"; }

        socket.on('novoPedido', () => { 
            document.getElementById('audioNotificacao').play();
            setTimeout(() => window.location.reload(), 1000); 
        });
        socket.on('statusAtualizado', () => window.location.reload());
    </script>
</body>
</html>