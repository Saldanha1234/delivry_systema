<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>KDS Profissional | Elite Design</title>
    <script src="/socket.io/socket.io.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&family=JetBrains+Mono:wght@700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-deep: #050507;
            --bg-surface: #0f0f12;
            --bg-card: #16161d;
            --accent-primary: #8257e5;
            --accent-glow: rgba(130, 87, 229, 0.3);
            --text-main: #f0f0f5;
            --text-dim: #a1a1aa;
            --status-ready: #00ff88;
            --status-alert: #ff4b4b;
            --border-color: rgba(255, 255, 255, 0.08);
            --transition-smooth: all 0.3s ease;
        }

        /* ESTILO DE ATRASO */
        .order-card.delayed {
            border-color: var(--status-alert) !important;
            animation: alertPulse 2s infinite;
        }
        
        .delay-tag {
            font-size: 9px;
            font-weight: 800;
            color: var(--status-alert);
            background: rgba(255, 75, 75, 0.1);
            padding: 2px 6px;
            border-radius: 4px;
            margin-left: 8px;
            font-family: 'JetBrains Mono', monospace;
            border: 1px solid rgba(255, 75, 75, 0.2);
        }

        @keyframes alertPulse {
            0% { box-shadow: 0 0 0px rgba(255, 75, 75, 0); }
            50% { box-shadow: 0 0 15px rgba(255, 75, 75, 0.2); }
            100% { box-shadow: 0 0 0px rgba(255, 75, 75, 0); }
        }

        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

        body {
            background-color: var(--bg-deep);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            line-height: 1.5;
            min-height: 100vh;
        }

        .top-bar {
            height: 60px; padding: 0 15px; display: flex; justify-content: space-between;
            align-items: center; background: var(--bg-surface); border-bottom: 1px solid var(--border-color);
            position: sticky; top: 0; z-index: 1100;
        }

        #clock { font-family: 'JetBrains Mono', monospace; color: var(--accent-primary); font-size: 0.9rem; }

        .search-container { padding: 12px 15px; background: var(--bg-deep); }
        .search-input {
            width: 100%; padding: 14px; border-radius: 12px; border: 1px solid var(--border-color);
            background: var(--bg-surface); color: white; font-size: 14px; outline: none;
        }

        .metrics-bar {
            display: flex;
            justify-content: space-around;
            padding: 10px 15px;
            background: rgba(255, 255, 255, 0.02);
            border-bottom: 1px solid var(--border-color);
            font-family: 'JetBrains Mono', monospace;
            font-size: 10px;
        }
        .metric-item { color: var(--text-dim); text-align: center; }
        .metric-item span { display: block; color: var(--status-ready); font-weight: 800; font-size: 12px; }

        .status-nav {
            display: flex; background: var(--bg-surface); position: sticky;
            top: 60px; z-index: 1000; border-bottom: 1px solid var(--border-color);
        }

        .nav-item {
            flex: 1; padding: 12px 0; text-align: center; cursor: pointer;
            display: flex; flex-direction: column; align-items: center; gap: 4px; color: var(--text-dim);
        }

        .nav-item.active {
            color: var(--accent-primary); background: rgba(130, 87, 229, 0.05);
            box-shadow: inset 0 -3px 0 var(--accent-primary);
        }

        .nav-item .count {
            font-size: 10px; background: rgba(255,255,255,0.1);
            padding: 1px 7px; border-radius: 10px; font-weight: 800;
        }

        .nav-item.active .count { background: var(--accent-primary); color: white; }
        .nav-item .label { font-size: 10px; font-weight: 800; text-transform: uppercase; }

        .container { padding: 15px; width: 100%; display: flex; flex-direction: column; gap: 15px; }
        .tab-content { display: none; width: 100%; flex-direction: column; gap: 12px; }
        .tab-content.active { display: flex; }

        .order-card {
            background: var(--bg-card); border-radius: 16px; padding: 18px;
            border: 1px solid var(--border-color); position: relative;
            cursor: pointer; transition: var(--transition-smooth);
        }
        .order-card:active { transform: scale(0.98); }

        .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
        .order-number { font-family: 'JetBrains Mono', monospace; color: var(--accent-primary); font-size: 14px; }
        .client-name { font-size: 1.15rem; font-weight: 800; text-transform: uppercase; margin: 5px 0; color: var(--text-main); }

        .status-badge {
            display: inline-block; padding: 4px 10px; border-radius: 6px;
            font-size: 10px; font-weight: 800; border: 1px solid var(--border-color);
            background: rgba(255,255,255,0.03); text-transform: uppercase;
        }

        #modalDetalhes {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.9); backdrop-filter: blur(8px);
            z-index: 2000; display: none; justify-content: center; align-items: center; padding: 20px;
        }

        .modal-body {
            background: var(--bg-card); width: 100%; max-width: 400px;
            padding: 25px; border-radius: 20px; border: 1px solid var(--border-color);
            max-height: 90vh; overflow-y: auto;
        }

        .modal-actions {
            display: flex; flex-direction: column; gap: 10px; margin-top: 20px;
        }

        .btn {
            padding: 14px; border-radius: 10px; border: none; font-weight: 800;
            font-size: 12px; cursor: pointer; text-transform: uppercase;
            transition: var(--transition-smooth); display: flex; justify-content: center; align-items: center;
        }
        .btn-primary { background: var(--accent-primary); color: white; width: 100%; }
        .btn-cancel { background: transparent; color: var(--status-alert); border: 1px solid rgba(255, 75, 75, 0.2); width: 100%; }
        .btn-dark { background: #2a2a35; color: white; width: 100%; margin-top: 5px; }

        @media (min-width: 1024px) {
            .container { flex-direction: row; align-items: flex-start; justify-content: center; }
            .status-nav { display: none; }
            .tab-content { display: flex !important; width: 24%; background: var(--bg-surface); padding: 15px; border-radius: 15px; min-height: 80vh; }
            .desktop-label { display: block; text-align: center; font-weight: 800; font-size: 11px; color: var(--accent-primary); margin-bottom: 10px; letter-spacing: 1px; }
        }
    </style>
</head>
<body>

    <div class="top-bar">
        <div style="font-weight:800; letter-spacing: -1px;">Açai<span style="color:var(--accent-primary)">Roxinho</span></div>
        <div id="clock">00:00:00</div>
        <div style="font-size: 9px; color: var(--status-ready); font-weight: 800;">ON-LINE</div>
    </div>

    <div class="search-container">
        <input type="text" id="searchInput" class="search-input" placeholder="Buscar por cliente ou ID...">
    </div>

    <div class="metrics-bar">
        <div class="metric-item">FATURAMENTO HOJE <span id="m-revenue">R$ 0,00</span></div>
        <div class="metric-item">TICKET MÉDIO <span id="m-average">R$ 0,00</span></div>
        <div class="metric-item">TOTAL CONCLUÍDOS <span id="m-total-count" style="color: var(--accent-primary)">0</span></div>
    </div>

    <nav class="status-nav">
        <div class="nav-item active" onclick="showTab('pendentes', 0)">
            <span class="count"><%= pedidos.filter(p => p.status === 'Pendente').length %></span>
            <span class="label">Pendentes</span>
        </div>
        <div class="nav-item" onclick="showTab('preparo', 1)">
            <span class="count"><%= pedidos.filter(p => p.status === 'Preparando').length %></span>
            <span class="label">Preparo</span>
        </div>
        <div class="nav-item" onclick="showTab('prontos', 2)">
            <span class="count"><%= pedidos.filter(p => p.status === 'Pronto').length %></span>
            <span class="label">Prontos</span>
        </div>
        <div class="nav-item" onclick="showTab('encerrados', 3)">
            <span class="count"><%= pedidos.filter(p => p.status === 'Saiu para Entrega' || p.status === 'Concluído').length %></span>
            <span class="label">Sairam</span>
        </div>
    </nav>

    <main class="container">
        
        <div id="pendentes" class="tab-content active">
            <div class="desktop-label">PENDENTES</div>
            <% pedidos.filter(p => p.status === 'Pendente').forEach(p => { %>
                <div class="order-card search-item sla-monitor" 
                     data-id="<%= p.id %>" 
                     data-status="Pendente"
                     data-time="<%= p.createdAt %>"
                     data-cliente="<%= p.cliente.toLowerCase() %>" 
                     onclick="abrirDetalhes('<%= p.id %>', 'Pendente')">
                    <div class="card-header">
                        <span class="order-number">#<%= p.id.toString().slice(-4) %></span>
                        <div style="display: flex; align-items: center;">
                            <span class="time-display" style="font-size: 10px; color: var(--text-dim);">
                                <%= new Date(p.createdAt).toLocaleTimeString('pt-BR', {hour: '2-digit', minute:'2-digit'}) %>
                            </span>
                            <span class="delay-info"></span>
                        </div>
                    </div>
                    <span class="client-name"><%= p.cliente %></span>
                    <div class="status-badge" style="color: var(--accent-primary)">Novo</div>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </div>

        <div id="preparo" class="tab-content">
            <div class="desktop-label">EM PREPARO</div>
            <% pedidos.filter(p => p.status === 'Preparando').forEach(p => { %>
                <div class="order-card search-item sla-monitor" 
                     data-id="<%= p.id %>" 
                     data-status="Preparando"
                     data-time="<%= p.updatedAt || p.createdAt %>"
                     data-cliente="<%= p.cliente.toLowerCase() %>" 
                     onclick="abrirDetalhes('<%= p.id %>', 'Preparando')">
                    <div class="card-header">
                        <span class="order-number">#<%= p.id.toString().slice(-4) %></span>
                        <span class="delay-info"></span>
                    </div>
                    <span class="client-name"><%= p.cliente %></span>
                    <div class="status-badge" style="color: #f1c40f">Preparando</div>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </div>

        <div id="prontos" class="tab-content">
            <div class="desktop-label">PRONTOS</div>
            <% pedidos.filter(p => p.status === 'Pronto').forEach(p => { %>
                <div class="order-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>" onclick="abrirDetalhes('<%= p.id %>', 'Pronto')">
                    <div class="card-header"><span class="order-number">#<%= p.id.toString().slice(-4) %></span></div>
                    <span class="client-name"><%= p.cliente %></span>
                    <div class="status-badge" style="color: var(--status-ready)">Pronto</div>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </div>

        <div id="encerrados" class="tab-content">
            <div class="desktop-label">ENCERRADOS</div>
            <% pedidos.filter(p => p.status === 'Saiu para Entrega' || p.status === 'Concluído').forEach(p => { %>
                <div class="order-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>" style="opacity: 0.6" onclick="abrirDetalhes('<%= p.id %>', '<%= p.status %>')">
                    <div class="card-header"><span class="order-number">#<%= p.id.toString().slice(-4) %></span></div>
                    <span class="client-name"><%= p.cliente %></span>
                    <div class="status-badge"><%= p.status === 'Concluído' ? 'Finalizado' : 'Em Rota' %></div>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </div>

    </main>

    <div id="modalDetalhes" onclick="fecharModal()">
        <div class="modal-body" onclick="event.stopPropagation()">
            <div id="comanda-interna"></div>
            <div id="modal-actions-container" class="modal-actions"></div>
            <button class="btn btn-dark" onclick="fecharModal()">VOLTAR</button>
        </div>
    </div>

    <audio id="audioNotificacao" src="/notificacao.mp3" preload="auto"></audio>

    <script>
        const socket = io();
        const listaPedidosRaw = <%- JSON.stringify(pedidos) %>;

        function calcularFaturamento() {
            const concluidos = listaPedidosRaw.filter(p => p.status === 'Concluído');
            let totalRev = 0;
            concluidos.forEach(p => {
                if (p.total) { totalRev += parseFloat(p.total); } 
                else if (p.itens) {
                    p.itens.forEach(item => { totalRev += (parseFloat(item.preco) * parseInt(item.quantidade)); });
                }
            });
            const count = concluidos.length;
            const media = count > 0 ? (totalRev / count) : 0;
            document.getElementById('m-revenue').innerText = `R$ ${totalRev.toLocaleString('pt-BR', {minimumFractionDigits: 2})}`;
            document.getElementById('m-total-count').innerText = count;
            document.getElementById('m-average').innerText = `R$ ${media.toLocaleString('pt-BR', {minimumFractionDigits: 2})}`;
        }

        // MOTOR DE MONITORAMENTO DE SLA (7min e 15min)
        function monitorarSLA() {
            const cards = document.querySelectorAll('.sla-monitor');
            const agora = Date.now();

            cards.forEach(card => {
                const status = card.getAttribute('data-status');
                const startTime = new Date(card.getAttribute('data-time')).getTime();
                const delayInfo = card.querySelector('.delay-info');
                
                const diffMin = Math.floor((agora - startTime) / 60000);
                let limite = status === 'Pendente' ? 7 : 15;
                
                if (diffMin >= limite) {
                    const extra = diffMin - limite;
                    card.classList.add('delayed');
                    delayInfo.innerHTML = `<span class="delay-tag">ATRASADO ${extra > 0 ? extra + 'm' : ''}</span>`;
                } else {
                    card.classList.remove('delayed');
                    delayInfo.innerHTML = '';
                }
            });
        }

        setInterval(() => {
            document.getElementById('clock').innerText = new Date().toLocaleTimeString('pt-BR');
            monitorarSLA(); // Atualiza os atrasos a cada segundo
        }, 1000);

        function showTab(tabId, index) {
            document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
            document.querySelectorAll('.nav-item')[index].classList.add('active');
            window.scrollTo(0, 0);
        }

        document.getElementById('searchInput').addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            document.querySelectorAll('.search-item').forEach(card => {
                const text = card.getAttribute('data-cliente') + card.getAttribute('data-id');
                card.style.display = text.includes(term) ? 'block' : 'none';
            });
        });

        async function atualizarStatus(id, novoStatus) {
            try {
                const res = await fetch('/update-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, novoStatus })
                });
                if (res.ok) window.location.reload();
            } catch (err) { console.error(err); }
        }

        function abrirDetalhes(id, status) {
            const wrap = document.getElementById(`wrapper-${id}`);
            const containerAcoes = document.getElementById('modal-actions-container');
            
            if(wrap) {
                document.getElementById('comanda-interna').innerHTML = wrap.innerHTML;
                containerAcoes.innerHTML = ''; 

                if (status === 'Pendente') {
                    containerAcoes.innerHTML = `
                        <button class="btn btn-primary" onclick="atualizarStatus('${id}', 'Preparando')">ACEITAR PEDIDO</button>
                        <button class="btn btn-cancel" onclick="atualizarStatus('${id}', 'Cancelado')">RECUSAR PEDIDO</button>
                    `;
                } else if (status === 'Preparando') {
                    containerAcoes.innerHTML = `
                        <button class="btn btn-primary" onclick="atualizarStatus('${id}', 'Pronto')">CONCLUIR PREPARO</button>
                    `;
                } else if (status === 'Pronto') {
                    containerAcoes.innerHTML = `
                        <button class="btn btn-primary" onclick="atualizarStatus('${id}', 'Saiu para Entrega')">ENVIAR / ENTREGAR</button>
                    `;
                } else if (status === 'Saiu para Entrega') {
                    containerAcoes.innerHTML = `
                        <button class="btn btn-primary" onclick="atualizarStatus('${id}', 'Concluído')">FINALIZAR E ENCERRAR</button>
                    `;
                }

                document.getElementById('modalDetalhes').style.display = "flex";
            }
        }

        function fecharModal() { document.getElementById('modalDetalhes').style.display = "none"; }

        socket.on('novoPedido', () => { 
            const audio = document.getElementById('audioNotificacao');
            if(audio) audio.play().catch(e => console.log("Audio block"));
            setTimeout(() => window.location.reload(), 1000); 
        });
        socket.on('statusAtualizado', () => window.location.reload());

        window.onload = () => {
            calcularFaturamento();
            monitorarSLA();
        };
    </script>
</body>
</html>