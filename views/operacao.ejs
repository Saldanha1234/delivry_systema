<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KDS Profissional | Sistema de Gerenciamento</title>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        :root {
            --bg-body: #111111;
            --bg-nav: #1a1a1a;
            --bg-card: #222222;
            --purple-main: #8a2be2;
            --purple-light: #a855f7;
            --text-gray: #bbbbbb;
            --text-white: #ffffff;
            --border-color: #333333;
            --green-status: #00ff88;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-body);
            color: var(--text-white);
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        /* BARRA SUPERIOR (CLOCK E TÍTULO) */
        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 20px;
            background-color: var(--bg-body);
        }

        #clock {
            font-size: 1.1rem;
            font-weight: bold;
            color: var(--purple-main);
        }

        .system-status {
            font-size: 0.75rem;
            color: var(--green-status);
            text-transform: uppercase;
            font-weight: bold;
        }

        /* NAVEGAÇÃO POR ABAS (IGUAL AO VÍDEO) */
        .status-nav {
            display: flex;
            background-color: var(--bg-nav);
            border-bottom: 2px solid var(--border-color);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .nav-item {
            flex: 1;
            padding: 15px 5px;
            text-align: center;
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            border-bottom: 4px solid transparent;
        }

        .nav-item.active {
            border-bottom-color: var(--purple-main);
            background: linear-gradient(to bottom, transparent, rgba(138, 43, 226, 0.1));
        }

        .nav-item .count {
            background: #333;
            padding: 2px 10px;
            border-radius: 12px;
            font-size: 0.7rem;
            font-weight: bold;
        }

        .nav-item.active .count {
            background: var(--purple-main);
        }

        .nav-item .label {
            font-size: 0.7rem;
            font-weight: 800;
            text-transform: uppercase;
            color: var(--text-gray);
        }

        .nav-item.active .label {
            color: var(--text-white);
        }

        /* CONTEÚDO DOS PEDIDOS */
        .container {
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            align-items: center;
        }

        .tab-content {
            display: none; /* Escondido por padrão */
            width: 100%;
            max-width: 500px;
            flex-direction: column;
            gap: 15px;
        }

        .tab-content.active {
            display: flex; /* Só mostra a aba ativa */
        }

        /* CARDS DO PEDIDO (ESTILO DO VÍDEO) */
        .order-card {
            background-color: var(--bg-card);
            border-radius: 15px;
            padding: 20px;
            position: relative;
            box-shadow: 0 4px 20px rgba(0,0,0,0.4);
            border: 1px solid #2d2d2d;
            width: 100%;
            box-sizing: border-box;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .order-number {
            color: var(--purple-light);
            font-weight: 900;
            font-size: 1rem;
        }

        .order-time {
            font-size: 0.75rem;
            color: var(--text-gray);
        }

        .client-name {
            font-size: 1.3rem;
            font-weight: 700;
            text-transform: uppercase;
            margin: 10px 0;
            display: block;
        }

        .order-info {
            font-size: 0.85rem;
            color: var(--text-gray);
        }

        .status-badge {
            position: absolute;
            top: 20px;
            right: 20px;
            background: rgba(0, 255, 136, 0.1);
            color: var(--green-status);
            padding: 4px 12px;
            border-radius: 5px;
            font-size: 0.65rem;
            font-weight: bold;
            text-transform: uppercase;
            border: 1px solid var(--green-status);
        }

        /* BOTÕES DE AÇÃO */
        .card-actions {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }

        .btn {
            flex: 1;
            padding: 12px;
            border-radius: 8px;
            border: none;
            font-weight: bold;
            font-size: 0.8rem;
            cursor: pointer;
            text-transform: uppercase;
            transition: 0.2s;
        }

        .btn-primary { background-color: var(--purple-main); color: white; }
        .btn-dark { background-color: #333; color: white; }
        .btn-cancel { background: transparent; color: #ff4444; border: 1px solid #444; font-size: 0.7rem; }

        /* BUSCA */
        .search-bar {
            padding: 15px 20px;
            background: var(--bg-body);
        }
        .search-input {
            width: 100%;
            padding: 12px;
            border-radius: 10px;
            border: 1px solid var(--border-color);
            background: var(--bg-nav);
            color: white;
            outline: none;
        }

        /* RESPONSIVIDADE DESKTOP */
        @media (min-width: 1024px) {
            .container {
                flex-direction: row;
                justify-content: space-around;
                align-items: flex-start;
            }
            .tab-content {
                display: flex !important;
                background: #0f0f0f;
                padding: 15px;
                border-radius: 10px;
                min-height: 80vh;
            }
            .status-nav { display: none; }
            .desktop-label {
                display: block;
                text-align: center;
                font-weight: bold;
                color: var(--text-gray);
                margin-bottom: 15px;
                border-bottom: 1px solid #333;
                padding-bottom: 10px;
            }
        }
        @media (max-width: 1023px) {
            .desktop-label { display: none; }
        }
    </style>
</head>
<body>

    <div class="top-bar">
        <div id="clock">00:00:00</div>
        <div class="system-status">• SISTEMA ATIVO</div>
        <a href="/admin" style="text-decoration:none; color:var(--text-gray); font-size:0.7rem;">ADMIN</a>
    </div>

    <div class="search-bar">
        <input type="text" id="searchInput" class="search-input" placeholder="Buscar cliente ou pedido...">
    </div>

    <nav class="status-nav">
        <div class="nav-item active" onclick="showTab('pendentes', 0)">
            <span class="count"><%= pedidos.filter(p => p.status === 'Pendente').length %></span>
            <span class="label">Pendentes</span>
        </div>
        <div class="nav-item" onclick="showTab('preparo', 1)">
            <span class="count"><%= pedidos.filter(p => p.status === 'Preparando').length %></span>
            <span class="label">Preparo</span>
        </div>
        <div class="nav-item" onclick="showTab('prontos', 2)">
            <span class="count"><%= pedidos.filter(p => p.status === 'Pronto').length %></span>
            <span class="label">Prontos</span>
        </div>
        <div class="nav-item" onclick="showTab('encerrados', 3)">
            <span class="count"><%= pedidos.filter(p => p.status === 'Saiu para Entrega' || p.status === 'Finalizado').length %></span>
            <span class="label">Encerrados</span>
        </div>
    </nav>

    <main class="container">
        
        <div id="pendentes" class="tab-content active">
            <div class="desktop-label">PENDENTES</div>
            <% pedidos.filter(p => p.status === 'Pendente').forEach(p => { %>
                <div class="order-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>">
                    <div class="card-header">
                        <span class="order-number">#<%= p.id.toString().slice(-4) %></span>
                        <span class="order-time"><%= new Date(p.createdAt).toLocaleTimeString('pt-BR', {hour: '2-digit', minute:'2-digit'}) %></span>
                    </div>
                    <span class="client-name"><%= p.cliente %></span>
                    <span class="order-info">1 Itens • Pix</span>
                    
                    <div class="card-actions">
                        <button class="btn btn-primary" onclick="atualizarStatus('<%= p.id %>', 'Preparando')">Aceitar</button>
                    </div>
                    <div class="card-actions">
                        <button class="btn btn-dark" onclick="abrirDetalhes('<%= p.id %>')">Ver Detalhes</button>
                        <button class="btn btn-cancel" onclick="cancelarPedido('<%= p.id %>')">Cancelar</button>
                    </div>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </div>

        <div id="preparo" class="tab-content">
            <div class="desktop-label">EM PREPARO</div>
            <% pedidos.filter(p => p.status === 'Preparando').forEach(p => { %>
                <div class="order-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>">
                    <div class="card-header">
                        <span class="order-number">#<%= p.id.toString().slice(-4) %></span>
                        <span class="order-time">Em produção</span>
                    </div>
                    <span class="client-name"><%= p.cliente %></span>
                    <div class="card-actions">
                        <button class="btn btn-primary" onclick="atualizarStatus('<%= p.id %>', 'Pronto')">Marcar Pronto</button>
                    </div>
                    <button class="btn btn-dark" style="width:100%; margin-top:10px;" onclick="abrirDetalhes('<%= p.id %>')">Comanda</button>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </div>

        <div id="prontos" class="tab-content">
            <div class="desktop-label">PRONTOS</div>
            <% pedidos.filter(p => p.status === 'Pronto').forEach(p => { %>
                <div class="order-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>">
                    <div class="card-header">
                        <span class="order-number">#<%= p.id.toString().slice(-4) %></span>
                        <span class="status-badge">PRONTO</span>
                    </div>
                    <span class="client-name"><%= p.cliente %></span>
                    <div class="card-actions">
                        <button class="btn btn-primary" onclick="atualizarStatus('<%= p.id %>', 'Saiu para Entrega')">Despachar</button>
                    </div>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </div>

        <div id="encerrados" class="tab-content">
            <div class="desktop-label">ENCERRADOS</div>
            <% pedidos.filter(p => p.status === 'Saiu para Entrega' || p.status === 'Finalizado').forEach(p => { %>
                <div class="order-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>">
                    <span class="status-badge" style="<%= p.status === 'Finalizado' ? 'color: #999; border-color: #444' : '' %>">
                        <%= p.status %>
                    </span>
                    <span class="order-number">#<%= p.id.toString().slice(-4) %></span>
                    <span class="client-name"><%= p.cliente %></span>
                    <span class="order-info">Total: R$ <%= p.total %></span>
                    <% if(p.status === 'Saiu para Entrega') { %>
                        <button class="btn btn-primary" style="width:100%; margin-top:10px" onclick="atualizarStatus('<%= p.id %>', 'Finalizado')">Concluir</button>
                    <% } %>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </div>

    </main>

    <div id="modalDetalhes" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.9); z-index:9999; justify-content:center; align-items:center;">
        <div style="background:var(--bg-card); width:90%; max-width:450px; padding:25px; border-radius:15px; border:1px solid var(--border-color);">
            <div id="comanda-interna"></div>
            <button class="btn btn-primary" style="width:100%; margin-top:20px" onclick="fecharModal()">VOLTAR</button>
        </div>
    </div>

    <audio id="audioNotificacao" src="/notificacao.mp3" preload="auto"></audio>

    <script>
        const socket = io();

        // RELÓGIO
        setInterval(() => {
            document.getElementById('clock').innerText = new Date().toLocaleTimeString('pt-BR');
        }, 1000);

        // TROCA DE ABAS MOBILE (ISOLAMENTO TOTAL)
        function showTab(tabId, index) {
            document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
            
            document.getElementById(tabId).classList.add('active');
            document.querySelectorAll('.nav-item')[index].classList.add('active');
        }

        // BUSCA FILTRADA
        document.getElementById('searchInput').addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            document.querySelectorAll('.search-item').forEach(card => {
                const text = card.getAttribute('data-cliente') + card.getAttribute('data-id');
                card.style.display = text.includes(term) ? 'block' : 'none';
            });
        });

        // LÓGICA DE ROTAS
        async function atualizarStatus(id, novoStatus) {
            try {
                const res = await fetch('/update-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, novoStatus })
                });
                if (res.ok) window.location.reload();
            } catch (err) { console.error(err); }
        }

        async function cancelarPedido(id) {
            if (confirm("Deseja realmente CANCELAR este pedido?")) {
                atualizarStatus(id, 'Cancelado');
            }
        }

        function abrirDetalhes(id) {
            const wrap = document.getElementById(`wrapper-${id}`);
            if(wrap) {
                document.getElementById('comanda-interna').innerHTML = wrap.innerHTML;
                document.getElementById('modalDetalhes').style.display = "flex";
            }
        }
        function fecharModal() { document.getElementById('modalDetalhes').style.display = "none"; }

        // SOCKET.IO
        socket.on('novoPedido', () => { 
            document.getElementById('audioNotificacao').play();
            setTimeout(() => window.location.reload(), 800); 
        });
        socket.on('statusAtualizado', () => window.location.reload());
    </script>
</body>
</html>