<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KDS Profissional | Farol</title>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        :root {
            --bg-site: #0a0a0c;
            --bg-card: #16161e;
            --primary: #7c3aed; /* Roxo vibrante profissional */
            --accent: #9f67ff;
            --text-main: #e2e8f0;
            --text-dim: #94a3b8;
            --danger: #ef4444;
            --success: #10b981;
            --border: #2d2d39;
        }

        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background-color: var(--bg-site);
            color: var(--text-main);
            margin: 0;
            padding: 0;
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* HEADER LIMPO E PROFISSIONAL */
        .top-header {
            background: #111118;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border);
        }

        .brand {
            font-weight: 800;
            letter-spacing: -0.5px;
            font-size: 1.1rem;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        #real-time-clock {
            font-family: 'JetBrains Mono', monospace;
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--text-main);
        }

        /* SISTEMA DE ABAS - CADA UMA ISOLADA */
        .tab-navigation {
            display: flex;
            background: #111118;
            border-bottom: 1px solid var(--border);
            width: 100%;
        }

        .tab-item {
            flex: 1;
            padding: 15px 5px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s ease;
            border-bottom: 3px solid transparent;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--text-dim);
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .tab-item.active {
            color: var(--primary);
            border-bottom-color: var(--primary);
            background: rgba(124, 58, 237, 0.05);
        }

        .tab-item .badge {
            font-size: 0.8rem;
            color: var(--text-main);
        }

        /* CONTEÚDO DAS ABAS - ISOLAMENTO TOTAL */
        .main-content {
            flex: 1;
            overflow-y: auto;
            padding: 15px;
            position: relative;
        }

        .status-section {
            display: none; /* Esconde todas as categorias */
            flex-direction: column;
            gap: 12px;
            width: 100%;
            max-width: 600px;
            margin: 0 auto;
        }

        .status-section.active {
            display: flex; /* Mostra apenas a ativa */
        }

        /* CARDS ESTILO PREMIUM */
        .pedido-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 16px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.5);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 10px;
        }

        .order-id {
            background: #2d2d39;
            color: var(--accent);
            padding: 4px 8px;
            border-radius: 6px;
            font-weight: 800;
            font-size: 0.9rem;
        }

        .order-timer {
            font-size: 0.8rem;
            color: var(--text-dim);
            font-weight: 600;
        }

        .client-name {
            font-size: 1.2rem;
            font-weight: 700;
            margin: 5px 0;
            color: #fff;
            text-transform: uppercase;
        }

        /* BOTÕES DE INTERAÇÃO */
        .actions {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }

        .btn {
            flex: 1;
            padding: 12px;
            border-radius: 8px;
            border: none;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.75rem;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .btn-main { background: var(--primary); color: #fff; }
        .btn-sec { background: #2d2d39; color: var(--text-main); }
        .btn-del { background: rgba(239, 68, 68, 0.1); color: var(--danger); border: 1px solid rgba(239, 68, 68, 0.2); }

        .search-area {
            padding: 10px 15px;
            background: #0a0a0c;
        }

        .search-input {
            width: 100%;
            padding: 12px;
            background: #16161e;
            border: 1px solid var(--border);
            border-radius: 8px;
            color: #fff;
            outline: none;
        }

        /* DESKTOP */
        @media (min-width: 1024px) {
            .tab-navigation { display: none; }
            .main-content {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 15px;
                overflow-x: auto;
            }
            .status-section {
                display: flex !important;
                max-width: none;
                background: #0f0f13;
                padding: 10px;
                border-radius: 12px;
                height: fit-content;
                min-height: 80vh;
            }
            .section-title-desktop {
                display: block;
                padding: 10px;
                font-weight: 800;
                color: var(--text-dim);
                border-bottom: 1px solid var(--border);
                margin-bottom: 10px;
            }
        }
        @media (max-width: 1023px) {
            .section-title-desktop { display: none; }
        }
    </style>
</head>
<body>

    <header class="top-header">
        <div class="brand">
            <div style="width:12px; height:12px; background:var(--success); border-radius:3px;"></div>
            FAROL KDS
        </div>
        <div id="real-time-clock">00:00:00</div>
        <a href="/admin" style="color:var(--text-dim); text-decoration:none; font-size:0.8rem; font-weight:700;">SAIR</a>
    </header>

    <div class="search-area">
        <input type="text" id="searchInput" class="search-input" placeholder="🔍 Buscar cliente ou pedido...">
    </div>

    <nav class="tab-navigation">
        <div class="tab-item active" onclick="changeTab(0)">
            <span class="badge"><%= pedidos.filter(p => p.status === 'Pendente').length %></span>
            <span>Pendentes</span>
        </div>
        <div class="tab-item" onclick="changeTab(1)">
            <span class="badge"><%= pedidos.filter(p => p.status === 'Preparando').length %></span>
            <span>Preparo</span>
        </div>
        <div class="tab-item" onclick="changeTab(2)">
            <span class="badge"><%= pedidos.filter(p => p.status === 'Pronto').length %></span>
            <span>Prontos</span>
        </div>
        <div class="tab-item" onclick="changeTab(3)">
            <span class="badge"><%= pedidos.filter(p => p.status === 'Saiu para Entrega' || p.status === 'Finalizado').length %></span>
            <span>Encerrados</span>
        </div>
    </nav>

    <main class="main-content">
        
        <section class="status-section active" id="sec-0">
            <div class="section-title-desktop">PENDENTES</div>
            <% pedidos.filter(p => p.status === 'Pendente').forEach(p => { %>
                <div class="pedido-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>" data-time="<%= p.createdAt %>">
                    <div class="card-header">
                        <span class="order-id">#<%= p.id.toString().slice(-4) %></span>
                        <span class="order-timer label-topo" id="label-topo-<%= p.id %>">--:--</span>
                    </div>
                    <div class="client-name"><%= p.cliente %></div>
                    <div class="actions" id="btn-area-<%= p.id %>">
                        <button class="btn btn-main" onclick="atualizarStatus('<%= p.id %>', 'Preparando')">Aceitar</button>
                    </div>
                    <div class="actions">
                        <button class="btn btn-sec" onclick="abrirDetalhes('<%= p.id %>')">Ver Itens</button>
                        <button class="btn btn-del" onclick="cancelarPedido('<%= p.id %>')">Cancelar</button>
                    </div>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </section>

        <section class="status-section" id="sec-1">
            <div class="section-title-desktop">EM PREPARO</div>
            <% pedidos.filter(p => p.status === 'Preparando').forEach(p => { %>
                <div class="pedido-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>" data-time="<%= p.updatedAt %>">
                    <div class="card-header">
                        <span class="order-id">#<%= p.id.toString().slice(-4) %></span>
                        <span class="order-timer label-topo" id="label-topo-<%= p.id %>">--:--</span>
                    </div>
                    <div class="client-name"><%= p.cliente %></div>
                    <div class="actions" id="btn-area-<%= p.id %>"></div>
                    <button class="btn btn-sec" style="width:100%; margin-top:10px" onclick="abrirDetalhes('<%= p.id %>')">Detalhes</button>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </section>

        <section class="status-section" id="sec-2">
            <div class="section-title-desktop">PRONTOS</div>
            <% pedidos.filter(p => p.status === 'Pronto').forEach(p => { %>
                <div class="pedido-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>" data-time="<%= p.updatedAt %>">
                    <div class="card-header">
                        <span class="order-id">#<%= p.id.toString().slice(-4) %></span>
                        <span class="order-timer label-topo" id="label-topo-<%= p.id %>">--:--</span>
                    </div>
                    <div class="client-name"><%= p.cliente %></div>
                    <div class="actions">
                        <button class="btn btn-main" onclick="atualizarStatus('<%= p.id %>', 'Saiu para Entrega')">Despachar</button>
                    </div>
                    <button class="btn btn-sec" style="width:100%; margin-top:10px" onclick="abrirDetalhes('<%= p.id %>')">Comanda</button>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </section>

        <section class="status-section" id="sec-3">
            <div class="section-title-desktop">ENCERRADOS</div>
            <% pedidos.filter(p => p.status === 'Saiu para Entrega' || p.status === 'Finalizado').forEach(p => { %>
                <div class="pedido-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>">
                    <div class="card-header">
                        <span class="order-id">#<%= p.id.toString().slice(-4) %></span>
                        <span class="order-timer" style="color:var(--success)"><%= p.status %></span>
                    </div>
                    <div class="client-name"><%= p.cliente %></div>
                    <% if(p.status === 'Saiu para Entrega') { %>
                        <button class="btn btn-main" style="width:100%" onclick="atualizarStatus('<%= p.id %>', 'Finalizado')">Finalizar</button>
                    <% } %>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </section>
    </main>

    <div id="modalDetalhes" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.95); z-index:9999; justify-content:center; align-items:center;">
        <div style="background:var(--bg-card); width:90%; max-width:450px; padding:25px; border-radius:15px; border:1px solid var(--border);">
            <div id="comanda-interna"></div>
            <button class="btn btn-main" style="width:100%; margin-top:20px" onclick="fecharModal()">FECHAR</button>
        </div>
    </div>

    <audio id="audioNotificacao" src="/notificacao.mp3" preload="auto"></audio>

    <script>
        const socket = io();

        // RELÓGIO ATUALIZADO
        setInterval(() => {
            document.getElementById('real-time-clock').innerText = new Date().toLocaleTimeString('pt-BR');
        }, 1000);

        // NAVEGAÇÃO ENTRE ABAS ISOLADAS
        function changeTab(idx) {
            if(window.innerWidth < 1024) {
                document.querySelectorAll('.tab-item').forEach((t, i) => t.classList.toggle('active', i === idx));
                document.querySelectorAll('.status-section').forEach((s, i) => s.classList.toggle('active', i === idx));
            }
        }

        // FAROL DE TEMPO PROFISSIONAL
        function updateTimes() {
            const now = new Date();
            document.querySelectorAll('.pedido-card[data-time]').forEach(card => {
                const id = card.getAttribute('data-id');
                const start = new Date(card.getAttribute('data-time'));
                const diff = Math.floor((now - start) / 60000);
                const label = card.querySelector('.label-topo');
                const btnArea = card.querySelector(`#btn-area-${id}`);
                
                if(label) label.innerText = diff + " MIN";

                // Se estiver no preparo (sec-1)
                if(card.closest('#sec-1')) {
                    if(diff >= 5) {
                        if(btnArea) btnArea.innerHTML = `<button class="btn btn-main" onclick="atualizarStatus('${id}', 'Pronto')">Marcar Pronto</button>`;
                    } else {
                        if(btnArea) btnArea.innerHTML = `<button class="btn btn-sec" style="opacity:0.4" disabled>Preparando...</button>`;
                    }
                }
            });
        }
        setInterval(updateTimes, 5000);
        updateTimes();

        // BUSCA
        document.getElementById('searchInput').addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            document.querySelectorAll('.search-item').forEach(item => {
                const searchStr = item.getAttribute('data-cliente') + item.getAttribute('data-id');
                item.style.display = searchStr.includes(term) ? 'block' : 'none';
            });
        });

        // REQUISIÇÕES AO SERVIDOR
        async function atualizarStatus(id, novoStatus) {
            try {
                const res = await fetch('/update-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, novoStatus })
                });
                if (res.ok) window.location.reload();
            } catch (err) { console.error(err); }
        }

        async function cancelarPedido(id) {
            if (confirm("CONFIRMAR CANCELAMENTO?")) atualizarStatus(id, 'Cancelado');
        }

        function abrirDetalhes(id) {
            const wrap = document.getElementById(`wrapper-${id}`);
            if(wrap) {
                document.getElementById('comanda-interna').innerHTML = wrap.innerHTML;
                document.getElementById('modalDetalhes').style.display = "flex";
            }
        }
        function fecharModal() { document.getElementById('modalDetalhes').style.display = "none"; }

        socket.on('novoPedido', () => { 
            document.getElementById('audioNotificacao').play();
            setTimeout(() => window.location.reload(), 800); 
        });
        socket.on('statusAtualizado', () => window.location.reload());
    </script>
</body>
</html>