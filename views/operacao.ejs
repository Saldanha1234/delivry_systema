<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KDS Profissional | Elite Design</title>
    <script src="/socket.io/socket.io.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-deep: #020203;
            --bg-surface: #0a0a0c;
            --bg-card: #121217;
            --accent-primary: #8257e5;
            --accent-glow: rgba(130, 87, 229, 0.4);
            --text-main: #e1e1e6;
            --text-dim: #a8a8b3;
            --status-ready: #50fa7b;
            --status-alert: #ff4b4b;
            --border-color: rgba(255, 255, 255, 0.06);
            --transition-smooth: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background-color: var(--bg-deep);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
            min-height: 100vh;
        }

        /* EFEITO DE BRILHO AO FUNDO */
        body::before {
            content: '';
            position: fixed;
            top: -10%; left: -10%;
            width: 40%; height: 40%;
            background: var(--accent-glow);
            filter: blur(150px);
            z-index: -1;
            border-radius: 50%;
        }

        /* TOP BAR */
        .top-bar {
            height: 70px;
            padding: 0 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(10, 10, 12, 0.9);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--border-color);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        #clock {
            font-family: 'JetBrains Mono', monospace;
            color: var(--accent-primary);
            font-weight: 700;
            letter-spacing: 1px;
        }

        .system-status {
            font-size: 0.7rem;
            color: var(--status-ready);
            font-weight: 800;
            text-transform: uppercase;
        }

        /* BUSCA */
        .search-bar {
            padding: 15px 20px;
            background: transparent;
        }
        .search-input {
            width: 100%;
            padding: 12px 20px;
            border-radius: 12px;
            border: 1px solid var(--border-color);
            background: var(--bg-surface);
            color: white;
            outline: none;
            transition: var(--transition-smooth);
        }
        .search-input:focus {
            border-color: var(--accent-primary);
            box-shadow: 0 0 15px var(--accent-glow);
        }

        /* NAVEGAÇÃO MOBILE */
        .status-nav {
            display: flex;
            background: var(--bg-surface);
            border-bottom: 1px solid var(--border-color);
        }

        .nav-item {
            flex: 1;
            padding: 15px 5px;
            text-align: center;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            transition: var(--transition-smooth);
            color: var(--text-dim);
            text-transform: uppercase;
            font-size: 0.7rem;
            font-weight: 700;
            position: relative;
        }

        .nav-item.active {
            color: var(--text-main);
        }

        .nav-item.active::after {
            content: '';
            position: absolute;
            bottom: 0;
            width: 40%;
            height: 3px;
            background: var(--accent-primary);
            border-radius: 10px 10px 0 0;
            box-shadow: 0 -2px 10px var(--accent-primary);
        }

        .nav-item .count {
            background: rgba(255,255,255,0.05);
            padding: 2px 10px;
            border-radius: 10px;
            border: 1px solid var(--border-color);
        }

        .nav-item.active .count {
            background: var(--accent-primary);
            border-color: transparent;
        }

        /* CONTEÚDO E CARDS */
        .container {
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            align-items: center;
        }

        .tab-content {
            display: none;
            width: 100%;
            max-width: 500px;
            flex-direction: column;
            gap: 15px;
            animation: fadeIn 0.4s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .tab-content.active { display: flex; }

        .order-card {
            background: var(--bg-card);
            border-radius: 18px;
            padding: 20px;
            border: 1px solid var(--border-color);
            transition: var(--transition-smooth);
            position: relative;
            width: 100%;
        }

        .order-card:hover {
            border-color: var(--accent-primary);
            background: linear-gradient(145deg, #121217, #1a1a24);
            transform: translateY(-2px);
        }

        /* ANIMAÇÃO PARA PEDIDOS ANTIGOS (DELAY) */
        .order-card.delayed {
            border-color: var(--status-alert);
            animation: alertPulse 2s infinite;
        }

        @keyframes alertPulse {
            0% { box-shadow: 0 0 0px rgba(255, 75, 75, 0); }
            50% { box-shadow: 0 0 15px rgba(255, 75, 75, 0.3); }
            100% { box-shadow: 0 0 0px rgba(255, 75, 75, 0); }
        }

        .order-number {
            font-family: 'JetBrains Mono', monospace;
            color: var(--accent-primary);
            font-weight: 700;
        }

        .client-name {
            font-size: 1.2rem;
            font-weight: 800;
            margin: 10px 0;
            display: block;
            letter-spacing: -0.5px;
        }

        .status-badge {
            background: rgba(255,255,255,0.05);
            color: var(--text-dim);
            padding: 4px 12px;
            border-radius: 8px;
            font-size: 0.65rem;
            font-weight: bold;
            border: 1px solid var(--border-color);
        }

        /* BOTÕES */
        .card-actions { display: flex; gap: 10px; margin-top: 15px; }

        .btn {
            flex: 1;
            padding: 14px;
            border-radius: 12px;
            border: none;
            font-weight: 800;
            font-size: 0.75rem;
            cursor: pointer;
            text-transform: uppercase;
            transition: var(--transition-smooth);
        }

        .btn-primary { 
            background: var(--accent-primary); 
            color: white; 
            box-shadow: 0 4px 15px rgba(130, 87, 229, 0.3);
        }
        .btn-primary:hover { opacity: 0.9; transform: scale(1.02); }

        .btn-dark { background: rgba(255,255,255,0.05); color: white; border: 1px solid var(--border-color); }
        .btn-dark:hover { background: rgba(255,255,255,0.1); }

        .btn-cancel { background: transparent; color: var(--status-alert); border: 1px solid rgba(255, 75, 75, 0.2); }

        /* RESPONSIVIDADE DESKTOP */
        @media (min-width: 1024px) {
            .container {
                flex-direction: row;
                justify-content: center;
                align-items: flex-start;
                max-width: 100%;
                gap: 15px;
            }
            .tab-content {
                display: flex !important;
                background: rgba(255,255,255,0.02);
                padding: 20px;
                border-radius: 20px;
                min-height: 85vh;
                border: 1px solid var(--border-color);
            }
            .status-nav { display: none; }
            .desktop-label {
                text-align: center;
                font-weight: 800;
                font-size: 0.8rem;
                color: var(--accent-primary);
                margin-bottom: 20px;
                letter-spacing: 2px;
            }
        }
    </style>
</head>
<body>

    <div class="top-bar">
        <div class="brand" style="font-weight:800; font-size: 1.1rem;">ELITE<span style="color:var(--accent-primary)">OPS</span></div>
        <div id="clock">00:00:00</div>
        <div class="system-status">• SISTEMA ATIVO</div>
        <a href="/admin" style="text-decoration:none; color:var(--text-dim); font-size:0.6rem; font-weight:700">PAINEL ADMIN</a>
    </div>

    <div class="search-bar">
        <input type="text" id="searchInput" class="search-input" placeholder="Pesquisar cliente ou número do pedido...">
    </div>

    <nav class="status-nav">
        <div class="nav-item active" onclick="showTab('pendentes', 0)">
            <span class="count"><%= pedidos.filter(p => p.status === 'Pendente').length %></span>
            <span class="label">Pendentes</span>
        </div>
        <div class="nav-item" onclick="showTab('preparo', 1)">
            <span class="count"><%= pedidos.filter(p => p.status === 'Preparando').length %></span>
            <span class="label">Preparo</span>
        </div>
        <div class="nav-item" onclick="showTab('prontos', 2)">
            <span class="count"><%= pedidos.filter(p => p.status === 'Pronto').length %></span>
            <span class="label">Prontos</span>
        </div>
        <div class="nav-item" onclick="showTab('encerrados', 3)">
            <span class="count"><%= pedidos.filter(p => p.status === 'Saiu para Entrega' || p.status === 'Finalizado').length %></span>
            <span class="label">Histórico</span>
        </div>
    </nav>

    <main class="container">
        
        <div id="pendentes" class="tab-content active">
            <div class="desktop-label">PENDENTES</div>
            <% pedidos.filter(p => p.status === 'Pendente').forEach(p => { %>
                <div class="order-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>">
                    <div class="card-header" style="display:flex; justify-content:space-between">
                        <span class="order-number">#<%= p.id.toString().slice(-4) %></span>
                        <span class="order-time" style="font-size:0.7rem; color:var(--text-dim)">
                            <%= new Date(p.createdAt).toLocaleTimeString('pt-BR', {hour: '2-digit', minute:'2-digit'}) %>
                        </span>
                    </div>
                    <span class="client-name"><%= p.cliente %></span>
                    <span class="status-badge">AGUARDANDO ACEITE</span>
                    
                    <div class="card-actions">
                        <button class="btn btn-primary" onclick="atualizarStatus('<%= p.id %>', 'Preparando')">Aceitar Pedido</button>
                    </div>
                    <div class="card-actions">
                        <button class="btn btn-dark" onclick="abrirDetalhes('<%= p.id %>')">Detalhes</button>
                        <button class="btn btn-cancel" onclick="cancelarPedido('<%= p.id %>')">Cancelar</button>
                    </div>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </div>

        <div id="preparo" class="tab-content">
            <div class="desktop-label">EM PRODUÇÃO</div>
            <% pedidos.filter(p => p.status === 'Preparando').forEach(p => { %>
                <div class="order-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>">
                    <div class="card-header">
                        <span class="order-number">#<%= p.id.toString().slice(-4) %></span>
                    </div>
                    <span class="client-name"><%= p.cliente %></span>
                    <div class="card-actions">
                        <button class="btn btn-primary" onclick="atualizarStatus('<%= p.id %>', 'Pronto')">Concluir Preparo</button>
                    </div>
                    <button class="btn btn-dark" style="width:100%; margin-top:10px;" onclick="abrirDetalhes('<%= p.id %>')">Ver Comanda</button>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </div>

        <div id="prontos" class="tab-content">
            <div class="desktop-label">PRONTOS</div>
            <% pedidos.filter(p => p.status === 'Pronto').forEach(p => { %>
                <div class="order-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>">
                    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center">
                        <span class="order-number">#<%= p.id.toString().slice(-4) %></span>
                        <span class="status-badge" style="color:var(--status-ready); border-color:var(--status-ready)">PRONTO</span>
                    </div>
                    <span class="client-name"><%= p.cliente %></span>
                    <div class="card-actions">
                        <button class="btn btn-primary" onclick="atualizarStatus('<%= p.id %>', 'Saiu para Entrega')">Despachar Pedido</button>
                    </div>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </div>

        <div id="encerrados" class="tab-content">
            <div class="desktop-label">HISTÓRICO</div>
            <% pedidos.filter(p => p.status === 'Saiu para Entrega' || p.status === 'Finalizado').forEach(p => { %>
                <div class="order-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>" style="opacity: 0.6">
                    <span class="order-number">#<%= p.id.toString().slice(-4) %></span>
                    <span class="client-name"><%= p.cliente %></span>
                    <span class="status-badge"><%= p.status %></span>
                    <% if(p.status === 'Saiu para Entrega') { %>
                        <button class="btn btn-primary" style="width:100%; margin-top:10px" onclick="atualizarStatus('<%= p.id %>', 'Finalizado')">Finalizar</button>
                    <% } %>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </div>

    </main>

    <div id="modalDetalhes" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.95); z-index:9999; justify-content:center; align-items:center; backdrop-filter: blur(10px);">
        <div style="background:var(--bg-card); width:95%; max-width:400px; padding:30px; border-radius:20px; border:1px solid var(--border-color); position:relative">
            <div id="comanda-interna" style="max-height: 70vh; overflow-y: auto;"></div>
            <button class="btn btn-primary" style="width:100%; margin-top:20px" onclick="fecharModal()">FECHAR</button>
        </div>
    </div>

    <audio id="audioNotificacao" src="/notificacao.mp3" preload="auto"></audio>

    <script>
        const socket = io();

        // RELÓGIO ATUALIZADO
        setInterval(() => {
            document.getElementById('clock').innerText = new Date().toLocaleTimeString('pt-BR');
        }, 1000);

        // ABAS MOBILE
        function showTab(tabId, index) {
            document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
            
            document.getElementById(tabId).classList.add('active');
            document.querySelectorAll('.nav-item')[index].classList.add('active');
        }

        // BUSCA
        document.getElementById('searchInput').addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            document.querySelectorAll('.search-item').forEach(card => {
                const text = card.getAttribute('data-cliente') + card.getAttribute('data-id');
                card.style.display = text.includes(term) ? 'block' : 'none';
            });
        });

        // ROTAS DE ATUALIZAÇÃO
        async function atualizarStatus(id, novoStatus) {
            try {
                const res = await fetch('/update-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, novoStatus })
                });
                if (res.ok) window.location.reload();
            } catch (err) { console.error("Erro ao atualizar status:", err); }
        }

        function cancelarPedido(id) {
            if (confirm("Deseja realmente CANCELAR este pedido?")) {
                atualizarStatus(id, 'Cancelado');
            }
        }

        function abrirDetalhes(id) {
            const wrap = document.getElementById(`wrapper-${id}`);
            if(wrap) {
                document.getElementById('comanda-interna').innerHTML = wrap.innerHTML;
                document.getElementById('modalDetalhes').style.display = "flex";
            }
        }
        
        function fecharModal() { document.getElementById('modalDetalhes').style.display = "none"; }

        // SOCKET EVENTOS
        socket.on('novoPedido', () => { 
            const audio = document.getElementById('audioNotificacao');
            if(audio) audio.play().catch(() => {});
            setTimeout(() => window.location.reload(), 1000); 
        });

        socket.on('statusAtualizado', () => window.location.reload());
    </script>
</body>
</html>