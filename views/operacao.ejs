<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Farol da Operação | KDS</title>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        :root {
            --bg-body: #121212;
            --bg-card: #2a2a2a;
            --primary-purple: #8b5cf6;
            --text-main: #ffffff;
            --text-dim: #a0a0a0;
            --success-green: #00ff88;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        /* HEADER & DASHBOARD INFO */
        .header-top {
            background: linear-gradient(to bottom, #1e1e2e, #121212);
            padding: 10px 20px;
            border-bottom: 1px solid #333;
        }

        .stats-bar {
            display: flex;
            justify-content: space-around;
            font-size: 0.75rem;
            font-weight: bold;
            color: var(--primary-purple);
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .stats-bar span b { color: var(--success-green); }

        .header-main {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        #real-time-clock {
            font-size: 1.2rem;
            color: var(--primary-purple);
            font-weight: bold;
            font-family: monospace;
        }

        /* CATEGORIAS POR ABAS (IGUAL A FOTO) */
        .status-tabs {
            display: flex;
            background: #1a1a1a;
            border-bottom: 2px solid #333;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .tab-item {
            flex: 1;
            padding: 12px 5px;
            text-align: center;
            cursor: pointer;
            transition: 0.3s;
            border-bottom: 3px solid transparent;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2px;
        }

        .tab-item.active {
            border-bottom: 3px solid var(--primary-purple);
            background: rgba(139, 92, 246, 0.1);
        }

        .tab-item .count {
            background: #333;
            color: #fff;
            font-size: 0.7rem;
            padding: 2px 8px;
            border-radius: 10px;
        }

        .tab-item.active .count { background: var(--primary-purple); }

        .tab-item .label {
            font-size: 0.65rem;
            font-weight: 800;
            text-transform: uppercase;
            color: var(--text-dim);
        }

        .tab-item.active .label { color: #white; }

        /* LISTA DE PEDIDOS */
        .kanban-container {
            padding: 15px;
        }

        .col-content {
            display: none; /* Escondido por padrão no mobile */
            flex-direction: column;
            gap: 12px;
            align-items: center;
        }

        .col-content.active { display: flex; }

        /* CARDS (ESTILO DA FOTO) */
        .mini-card {
            background: var(--bg-card);
            border-radius: 12px;
            width: 100%;
            max-width: 400px;
            padding: 15px;
            position: relative;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
            border: 1px solid #3d3d3d;
        }

        .card-header-info {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
        }

        .card-id {
            color: var(--primary-purple);
            font-weight: bold;
            font-size: 0.9rem;
        }

        .card-time {
            font-size: 0.7rem;
            color: var(--text-dim);
        }

        .card-cliente {
            font-size: 1.1rem;
            font-weight: 700;
            text-transform: uppercase;
            display: block;
            margin-bottom: 5px;
        }

        .card-details-summary {
            font-size: 0.8rem;
            color: var(--text-dim);
        }

        /* BOTÕES DE AÇÃO */
        .btn-group {
            display: flex;
            gap: 8px;
            margin-top: 15px;
        }

        .btn-action {
            flex: 1;
            padding: 10px;
            border-radius: 6px;
            border: none;
            font-weight: bold;
            font-size: 0.75rem;
            cursor: pointer;
            text-transform: uppercase;
        }

        .btn-primary { background: var(--primary-purple); color: white; }
        .btn-outline { background: #3d3d3d; color: white; }
        .btn-cancel { background: transparent; color: #ff4444; border: 1px solid #444; font-size: 0.65rem; }

        /* BUSCA */
        .search-box {
            padding: 10px 15px;
            background: #121212;
        }
        .search-input {
            width: 100%;
            padding: 10px;
            border-radius: 8px;
            border: 1px solid #333;
            background: #1a1a1a;
            color: white;
        }

        /* DESKTOP */
        @media (min-width: 900px) {
            .status-tabs { display: none; }
            .kanban-container {
                display: flex;
                gap: 15px;
                overflow-x: auto;
                align-items: flex-start;
            }
            .col-content {
                display: flex !important;
                min-width: 300px;
                background: #1a1a1a;
                border-radius: 10px;
                padding: 10px;
                height: 80vh;
                overflow-y: auto;
            }
        }
    </style>
</head>
<body>

    <header class="header-top">
        <div class="stats-bar">
            <span>Faturamento: <b>R$ 0,00</b></span>
            <span>Ticket Médio: <b>R$ 0,00</b></span>
            <span>Total: <b><%= pedidos.length %></b></span>
        </div>
        <div class="header-main">
            <div style="display:flex; align-items:center; gap:10px;">
                <div style="width:10px; height:10px; background:var(--success-green); border-radius:50%"></div>
                <strong style="font-size: 0.9rem;">OPERACIONAL KDS</strong>
            </div>
            <div id="real-time-clock">00:00:00</div>
            <a href="/admin" style="color:var(--text-dim); text-decoration:none; font-size:0.7rem;">SAIR</a>
        </div>
    </header>

    <div class="search-box">
        <input type="text" id="searchInput" class="search-input" placeholder="Buscar cliente ou ID...">
    </div>

    <nav class="status-tabs">
        <div class="tab-item active" onclick="switchTab(0)">
            <span class="count"><%= pedidos.filter(p => p.status === 'Pendente').length %></span>
            <span class="label">Pendentes</span>
        </div>
        <div class="tab-item" onclick="switchTab(1)">
            <span class="count"><%= pedidos.filter(p => p.status === 'Preparando').length %></span>
            <span class="label">Preparo</span>
        </div>
        <div class="tab-item" onclick="switchTab(2)">
            <span class="count"><%= pedidos.filter(p => p.status === 'Pronto').length %></span>
            <span class="label">Prontos</span>
        </div>
        <div class="tab-item" onclick="switchTab(3)">
            <span class="count"><%= pedidos.filter(p => p.status === 'Saiu para Entrega' || p.status === 'Finalizado').length %></span>
            <span class="label">Encerrado</span>
        </div>
    </nav>

    <div class="kanban-container">
        
        <div class="col-content active" id="col-0">
            <% pedidos.filter(p => p.status === 'Pendente').forEach(p => { %>
                <div class="mini-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>" data-time="<%= p.createdAt %>">
                    <div class="card-header-info">
                        <span class="card-id">#<%= p.id.toString().slice(-4) %></span>
                        <span class="card-time label-topo" id="label-topo-<%= p.id %>">--:--</span>
                    </div>
                    <span class="card-cliente"><%= p.cliente %></span>
                    <span class="card-details-summary">Itens do pedido • Pix</span>
                    
                    <div class="btn-group" id="btn-area-<%= p.id %>">
                        <button class="btn-action btn-primary" onclick="atualizarStatus('<%= p.id %>', 'Preparando')">Aceitar</button>
                    </div>
                    <div class="btn-group">
                        <button class="btn-action btn-outline" onclick="abrirDetalhes('<%= p.id %>')">Ver Pedido</button>
                        <button class="btn-action btn-cancel" onclick="cancelarPedido('<%= p.id %>')">Cancelar</button>
                    </div>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </div>

        <div class="col-content" id="col-1">
            <% pedidos.filter(p => p.status === 'Preparando').forEach(p => { %>
                <div class="mini-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>" data-time="<%= p.updatedAt %>">
                    <div class="card-header-info">
                        <span class="card-id">#<%= p.id.toString().slice(-4) %></span>
                        <span class="card-time label-topo" id="label-topo-<%= p.id %>">--:--</span>
                    </div>
                    <span class="card-cliente"><%= p.cliente %></span>
                    
                    <div class="btn-group" id="btn-area-<%= p.id %>">
                        </div>
                    <button class="btn-action btn-outline" style="width:100%; margin-top:10px;" onclick="abrirDetalhes('<%= p.id %>')">Detalhes</button>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </div>

        <div class="col-content" id="col-2">
            <% pedidos.filter(p => p.status === 'Pronto').forEach(p => { %>
                <div class="mini-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>" data-time="<%= p.updatedAt %>">
                    <div class="card-header-info">
                        <span class="card-id">#<%= p.id.toString().slice(-4) %></span>
                        <span class="card-time label-topo" id="label-topo-<%= p.id %>">--:--</span>
                    </div>
                    <span class="card-cliente"><%= p.cliente %></span>
                    
                    <div class="btn-group" id="btn-area-<%= p.id %>">
                        <button class="btn-action btn-primary" onclick="atualizarStatus('<%= p.id %>', 'Saiu para Entrega')">Despachar</button>
                    </div>
                    <button class="btn-action btn-outline" style="width:100%; margin-top:10px;" onclick="abrirDetalhes('<%= p.id %>')">Detalhes</button>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </div>

        <div class="col-content" id="col-3">
            <% pedidos.filter(p => p.status === 'Saiu para Entrega' || p.status === 'Finalizado').forEach(p => { %>
                <div class="mini-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>">
                    <div class="card-header-info">
                        <span class="card-id">#<%= p.id.toString().slice(-4) %></span>
                        <span class="card-time"><%= p.status %></span>
                    </div>
                    <span class="card-cliente"><%= p.cliente %></span>
                    <% if(p.status === 'Saiu para Entrega') { %>
                        <button class="btn-action btn-primary" style="width:100%;" onclick="atualizarStatus('<%= p.id %>', 'Finalizado')">Concluir</button>
                    <% } else { %>
                        <span style="color:var(--success-green); font-size:0.7rem; font-weight:bold;">PEDIDO FINALIZADO</span>
                    <% } %>
                    <div id="wrapper-<%= p.id %>" style="display:none"><%- include('partials/card-comanda', {p: p}) %></div>
                </div>
            <% }) %>
        </div>

    </div>

    <div id="modalDetalhes" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.9); z-index:1000; justify-content:center; align-items:center;">
        <div style="background:#2a2a2a; width:90%; max-width:500px; padding:20px; border-radius:15px; max-height:80vh; overflow-y:auto;">
            <div id="comanda-interna" style="color:white;"></div>
            <button class="btn-action btn-primary" style="width:100%; margin-top:20px;" onclick="fecharModal()">FECHAR</button>
        </div>
    </div>

    <audio id="audioNotificacao" src="/notificacao.mp3" preload="auto"></audio>

    <script>
        const socket = io();

        // RELÓGIO
        setInterval(() => {
            document.getElementById('real-time-clock').innerText = new Date().toLocaleTimeString('pt-BR');
        }, 1000);

        // TROCA DE ABAS (MOBILE)
        function switchTab(index) {
            document.querySelectorAll('.tab-item').forEach((t, i) => {
                t.classList.toggle('active', i === index);
            });
            document.querySelectorAll('.col-content').forEach((c, i) => {
                c.classList.toggle('active', i === index);
            });
        }

        // LÓGICA DE TEMPO E CORES DOS BOTÕES (FAROL)
        function updateFarol() {
            const now = new Date();
            const cards = document.querySelectorAll('.mini-card[data-time]');

            cards.forEach(card => {
                const id = card.getAttribute('data-id');
                const startTime = new Date(card.getAttribute('data-time'));
                const diffMin = Math.floor((now - startTime) / 60000);
                const labelTopo = card.querySelector('.label-topo');
                const btnArea = card.querySelector(`#btn-area-${id}`);
                
                if(!labelTopo) return;
                labelTopo.innerText = diffMin + " min";

                // Se estiver na coluna de Preparo
                if(card.parentElement.id === 'col-1') {
                    if (diffMin < 5) {
                        labelTopo.style.color = "#f39c12";
                        if(btnArea) btnArea.innerHTML = `<button class="btn-action btn-outline" style="opacity:0.5" disabled>Em preparo...</button>`;
                    } else {
                        labelTopo.style.color = "#00ff88";
                        if(btnArea) btnArea.innerHTML = `<button class="btn-action btn-primary" onclick="atualizarStatus('${id}', 'Pronto')">Marcar Pronto</button>`;
                    }
                }
            });
        }

        setInterval(updateFarol, 5000);
        updateFarol();

        // BUSCA
        document.getElementById('searchInput').addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            document.querySelectorAll('.search-item').forEach(item => {
                const searchStr = item.getAttribute('data-cliente') + item.getAttribute('data-id');
                item.style.display = searchStr.includes(term) ? 'block' : 'none';
            });
        });

        // FUNÇÕES ORIGINAIS DE ROTA
        async function atualizarStatus(id, novoStatus) {
            try {
                const res = await fetch('/update-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, novoStatus })
                });
                if (res.ok) window.location.reload();
            } catch (err) { console.error(err); }
        }

        async function cancelarPedido(id) {
            if (confirm("Deseja realmente CANCELAR?")) atualizarStatus(id, 'Cancelado');
        }

        function abrirDetalhes(id) {
            const wrapper = document.getElementById(`wrapper-${id}`);
            if(wrapper) {
                document.getElementById('comanda-interna').innerHTML = wrapper.innerHTML;
                document.getElementById('modalDetalhes').style.display = "flex";
            }
        }
        function fecharModal() { document.getElementById('modalDetalhes').style.display = "none"; }

        socket.on('novoPedido', () => { 
            document.getElementById('audioNotificacao').play();
            setTimeout(() => window.location.reload(), 1000); 
        });
        socket.on('statusAtualizado', () => window.location.reload());
    </script>
</body>
</html>