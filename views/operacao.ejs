<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel de Operações | Comandas</title>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        :root {
            --bg-body: #121212;
            --col-bg: #1e1e1e;
            --text-main: #ffffff;
            --accent: #f1c40f;
            --pendente: #e74c3c;
            --preparando: #3498db;
            --entrega: #2ecc71;
            --card-inner: #252525;
            --primary: #FF385C; /* Cor do novo estilo */
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            margin: 0;
            padding: 20px;
            overflow-x: hidden;
        }

        .header-painel {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 2px solid #333;
        }

        .header-painel h1 { margin: 0; font-size: 1.5rem; display: flex; align-items: center; gap: 10px; }

        .status-badge {
            background: rgba(46, 204, 113, 0.1);
            color: var(--entrega);
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            border: 1px solid var(--entrega);
            transition: 0.3s;
        }

        .btn-voltar {
            background: #333;
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: bold;
            transition: 0.3s;
            border: 1px solid #444;
        }

        .btn-voltar:hover { background: var(--primary); border-color: var(--primary); }

        /* Estrutura Kanban */
        .kanban {
            display: flex;
            gap: 20px;
            overflow-x: auto;
            align-items: flex-start;
            padding-bottom: 30px;
            height: calc(100vh - 140px);
        }

        .col {
            background-color: var(--col-bg);
            border-radius: 12px;
            min-width: 350px;
            max-width: 380px;
            display: flex;
            flex-direction: column;
            max-height: 100%;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            border: 1px solid #333;
        }

        .col-header {
            padding: 20px;
            text-align: center;
            font-weight: 800;
            text-transform: uppercase;
            border-radius: 12px 12px 0 0;
            letter-spacing: 1px;
            font-size: 0.9rem;
        }

        .col-pendente { border-top: 6px solid var(--pendente); background: rgba(231, 76, 60, 0.1); color: var(--pendente); }
        .col-preparando { border-top: 6px solid var(--preparando); background: rgba(52, 152, 219, 0.1); color: var(--preparando); }
        .col-entrega { border-top: 6px solid var(--entrega); background: rgba(46, 204, 113, 0.1); color: var(--entrega); }

        .lista-pedidos {
            padding: 15px;
            overflow-y: auto;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        /* Estilização da Barra de Rolagem */
        .lista-pedidos::-webkit-scrollbar { width: 6px; }
        .lista-pedidos::-webkit-scrollbar-thumb { background: #444; border-radius: 10px; }

        @media (max-width: 768px) {
            .kanban {
                flex-direction: column;
                height: auto;
                overflow-x: hidden;
            }
            .col {
                min-width: 100%;
                max-width: 100%;
                min-height: 300px;
                margin-bottom: 20px;
            }
        }
    </style>
</head>
<body>

    <header class="header-painel">
        <div>
            <h1>📦 Gerenciamento de Pedidos</h1>
            <div style="margin-top: 8px; display: flex; align-items: center; gap: 10px;">
                <span id="socket-status" class="status-badge">● Sistema Online</span>
                <small style="color: #888;">Monitorando novos pedidos com adicionais em tempo real.</small>
            </div>
        </div>
        <a href="/admin" class="btn-voltar">🏠 Painel Administrativo</a>
    </header>

    <div class="kanban">
        <div class="col">
            <div class="col-header col-pendente">🟡 Novos Pedidos (<span id="count-pendente"><%= pedidos.filter(p => p.status === 'Pendente').length %></span>)</div>
            <div class="lista-pedidos" id="pendentes">
                <% pedidos.filter(p => p.status === 'Pendente').forEach(p => { %>
                    <%- include('partials/card-comanda', {p: p}) %>
                <% }) %>
            </div>
        </div>

        <div class="col">
            <div class="col-header col-preparando">🔥 Em Preparação (<span id="count-preparando"><%= pedidos.filter(p => p.status === 'Preparando').length %></span>)</div>
            <div class="lista-pedidos" id="preparando">
                <% pedidos.filter(p => p.status === 'Preparando').forEach(p => { %>
                    <%- include('partials/card-comanda', {p: p}) %>
                <% }) %>
            </div>
        </div>

        <div class="col">
            <div class="col-header col-entrega">🛵 Entrega / Retirada (<span id="count-entrega"><%= pedidos.filter(p => p.status === 'Saiu para Entrega').length %></span>)</div>
            <div class="lista-pedidos" id="entrega">
                <% pedidos.filter(p => p.status === 'Saiu para Entrega').forEach(p => { %>
                    <%- include('partials/card-comanda', {p: p}) %>
                <% }) %>
            </div>
        </div>
    </div>

    <audio id="audioNotificacao" src="/notificacao.mp3" preload="auto"></audio>

    <script>
        const socket = io();
        const audio = document.getElementById('audioNotificacao');

        // Função principal para atualizar status (chamada pelos botões no card-comanda)
        async function atualizarStatus(id, novoStatus) {
            try {
                // Desabilita o botão temporariamente no front para evitar múltiplos cliques
                const btn = event?.target;
                if(btn) btn.style.opacity = "0.5";

                const response = await fetch('/update-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, novoStatus })
                });
                
                if (response.ok) {
                    // O recarregamento será disparado pelo evento de socket 'statusAtualizado'
                    // ou por aqui caso o socket falhe por um instante.
                    console.log(`Pedido ${id} movido para ${novoStatus}`);
                } else {
                    alert("Erro ao processar mudança de status.");
                    if(btn) btn.style.opacity = "1";
                }
            } catch (err) {
                console.error("Erro na comunicação com o servidor:", err);
            }
        }

        // SOCKET: Receber novo pedido
        socket.on('novoPedido', (pedido) => {
            console.log("Novo pedido detectado:", pedido);
            
            // Tenta tocar o som
            audio.play().catch(e => console.log("Áudio aguardando interação."));
            
            // Recarrega a página para processar o novo formato de objeto enviado
            setTimeout(() => {
                window.location.reload();
            }, 500);
        });

        // SOCKET: Atualização de status em tempo real (Sync entre abas)
        socket.on('statusAtualizado', (data) => {
            window.location.reload();
        });

        // Feedback visual do Socket
        socket.on('connect', () => {
            const badge = document.getElementById('socket-status');
            badge.style.color = "var(--entrega)";
            badge.style.borderColor = "var(--entrega)";
            badge.innerText = "● Sistema Online";
        });

        socket.on('disconnect', () => {
            const badge = document.getElementById('socket-status');
            badge.style.color = "var(--pendente)";
            badge.style.borderColor = "var(--pendente)";
            badge.innerText = "○ Reconectando...";
        });
    </script>
</body>
</html>