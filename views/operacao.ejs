<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ELITE OPS | Kitchen Display System</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://cdn.socket.io/4.7.2/socket.io.min.js"></script>
    <style>
        :root {
            --bg-deep: #020203;
            --bg-surface: #0a0a0c;
            --bg-card: #121217;
            --accent-primary: #8257e5;
            --accent-glow: rgba(130, 87, 229, 0.4);
            --text-main: #e1e1e6;
            --text-dim: #a8a8b3;
            --status-pending: #ffb86c;
            --status-preparing: #8be9fd;
            --status-ready: #50fa7b;
            --status-alert: #ff4b4b;
            --border-color: rgba(255, 255, 255, 0.06);
            --transition-smooth: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background-color: var(--bg-deep);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            overflow: hidden; 
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        body::before {
            content: '';
            position: absolute;
            top: -10%; left: -10%;
            width: 40%; height: 40%;
            background: var(--accent-glow);
            filter: blur(150px);
            z-index: -1;
            border-radius: 50%;
        }

        header {
            height: 70px;
            padding: 0 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(10, 10, 12, 0.9);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--border-color);
            z-index: 100;
        }

        .slow-mode-container {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(255, 255, 255, 0.03);
            padding: 5px 15px;
            border-radius: 20px;
            border: 1px solid var(--border-color);
        }

        .slow-mode-label {
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--text-dim);
        }

        .switch {
            position: relative;
            display: inline-block;
            width: 40px;
            height: 20px;
        }

        .switch input { opacity: 0; width: 0; height: 0; }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: #333;
            transition: .4s;
            border-radius: 20px;
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 14px; width: 14px;
            left: 3px; bottom: 3px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

        input:checked + .slider { background-color: var(--status-alert); }
        input:checked + .slider:before { transform: translateX(20px); }

        .metrics-bar {
            background: rgba(255, 255, 255, 0.02);
            border-bottom: 1px solid var(--border-color);
            display: flex;
            justify-content: space-around;
            padding: 10px 0;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            color: var(--text-dim);
        }

        .metric-item span {
            color: var(--status-ready);
            font-weight: 700;
            margin-left: 5px;
        }

        .brand {
            font-size: 1.2rem;
            font-weight: 800;
            text-transform: uppercase;
        }
        .brand span { color: var(--accent-primary); }

        nav.tab-bar {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            background: var(--bg-surface);
            border-bottom: 1px solid var(--border-color);
            padding: 5px;
        }

        .tab-btn {
            background: transparent;
            border: none;
            color: var(--text-dim);
            padding: 15px 5px;
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            transition: var(--transition-smooth);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 5px;
            position: relative;
            text-transform: uppercase;
        }

        .tab-btn.active { color: var(--text-main); }
        .tab-btn.active::after {
            content: '';
            position: absolute;
            bottom: 0;
            width: 40%;
            height: 3px;
            background: var(--accent-primary);
            border-radius: 10px 10px 0 0;
            box-shadow: 0 -2px 10px var(--accent-primary);
        }

        .badge-tab {
            font-size: 0.7rem;
            background: rgba(255,255,255,0.05);
            padding: 2px 8px;
            border-radius: 10px;
            border: 1px solid var(--border-color);
        }

        .content-area {
            flex-grow: 1;
            position: relative;
            overflow: hidden;
        }

        .kanban-column {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            display: none;
            flex-direction: column;
            padding: 20px;
            align-items: center;
            animation: fadeIn 0.3s ease;
        }

        .kanban-column.active { display: flex; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateX(10px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .orders-scroll {
            overflow-y: auto;
            flex-grow: 1;
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-bottom: 100px;
        }

        .orders-scroll::-webkit-scrollbar { width: 4px; }
        .orders-scroll::-webkit-scrollbar-thumb { background: var(--accent-primary); }

        .order-card {
            background: var(--bg-card);
            border-radius: 18px;
            padding: 20px;
            margin-bottom: 15px;
            border: 1px solid var(--border-color);
            cursor: pointer;
            transition: var(--transition-smooth);
            position: relative;
            width: 100%;
            max-width: 450px;
        }

        .order-card.delayed {
            border-color: var(--status-alert) !important;
            box-shadow: 0 0 15px rgba(255, 75, 75, 0.2);
            animation: alertPulse 2s infinite;
        }

        @keyframes alertPulse {
            0% { box-shadow: 0 0 0px rgba(255, 75, 75, 0); }
            50% { box-shadow: 0 0 20px rgba(255, 75, 75, 0.3); }
            100% { box-shadow: 0 0 0px rgba(255, 75, 75, 0); }
        }

        .order-card:hover {
            border-color: var(--accent-primary);
            background: linear-gradient(145deg, #121217, #1a1a24);
            transform: translateY(-2px);
        }

        .order-header { display: flex; justify-content: space-between; margin-bottom: 10px; }
        .order-id { font-family: 'JetBrains Mono', monospace; color: var(--accent-primary); font-weight: 700; }
        .order-time { font-size: 0.8rem; color: var(--text-dim); }
        .customer-name { font-size: 1.2rem; font-weight: 700; margin-bottom: 5px; }
        .order-details { font-size: 0.9rem; color: var(--text-dim); }

        #modal-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.95);
            display: none;
            justify-content: center;
            align-items: flex-start;
            overflow-y: auto;
            padding: 20px 0;
            z-index: 1000;
            backdrop-filter: blur(10px);
        }

        .comanda-digital {
            background: #fff;
            color: #1a1a1a;
            width: 90%;
            max-width: 380px;
            padding: 30px;
            border-radius: 4px;
            box-shadow: 0 0 50px rgba(0,0,0,0.5);
            font-family: 'JetBrains Mono', monospace;
            position: relative;
        }

        .comanda-digital::after {
            content: '';
            position: absolute;
            bottom: -15px; left: 0; width: 100%; height: 15px;
            background: linear-gradient(-45deg, transparent 10px, #fff 0), linear-gradient(45deg, transparent 10px, #fff 0);
            background-size: 15px 30px;
            transform: rotate(180deg);
        }

        .ticket-header { text-align: center; border-bottom: 2px dashed #333; padding-bottom: 15px; margin-bottom: 20px; }
        .ticket-header h1 { font-size: 2rem; }
        .ticket-item { display: flex; justify-content: space-between; margin: 8px 0; font-size: 0.9rem; }
        .ticket-total { border-top: 2px solid #000; margin-top: 20px; padding-top: 10px; font-size: 1.4rem; font-weight: 800; text-align: right; }
        .actions-bar { margin-top: 30px; display: flex; flex-direction: column; gap: 10px; }
        .btn { padding: 18px; border-radius: 12px; border: none; font-weight: 800; font-size: 1rem; cursor: pointer; text-transform: uppercase; }
        .btn-confirm { background: var(--accent-primary); color: white; }
        .btn-cancel { background: var(--status-alert); color: white; margin-top: 10px; }
        .btn-close { background: #e0e0e0; color: #333; }
        
        .cancel-reason-box {
            margin-top: 15px;
            display: none;
            flex-direction: column;
            gap: 10px;
        }
        .cancel-reason-box textarea {
            width: 100%; padding: 10px; font-family: 'Inter';
            border: 1px solid #ddd; border-radius: 8px; resize: none;
        }
    </style>
</head>
<body>

    <header>
        <div class="brand">ELITE<span>OPS</span></div>
        
        <div class="slow-mode-container">
            <span class="slow-mode-label">MODO LENTO</span>
            <label class="switch">
                <input type="checkbox" id="slow-mode-toggle" onchange="toggleSlowMode()">
                <span class="slider"></span>
            </label>
        </div>

        <div id="clock" style="font-family: 'JetBrains Mono'; color: var(--accent-primary); font-weight: 700; letter-spacing: 1px;">00:00:00</div>
        <div id="status-online" style="font-size: 0.7rem; color: var(--status-ready)">● SISTEMA ATIVO</div>
    </header>

    <div class="metrics-bar">
        <div class="metric-item">FATURAMENTO HOJE: <span id="m-revenue">R$ 0,00</span></div>
        <div class="metric-item">TICKET MÉDIO: <span id="m-average">R$ 0,00</span></div>
        <div class="metric-item">TOTAL PEDIDOS: <span id="m-total-count" style="color: var(--accent-primary)">0</span></div>
    </div>

    <nav class="tab-bar">
        <button class="tab-btn active" onclick="switchTab('pending')">
            <span class="badge-tab" id="count-pending">0</span>
            Pendentes
        </button>
        <button class="tab-btn" onclick="switchTab('preparing')">
            <span class="badge-tab" id="count-preparing">0</span>
            Preparo
        </button>
        <button class="tab-btn" onclick="switchTab('ready')">
            <span class="badge-tab" id="count-ready">0</span>
            Prontos
        </button>
        <button class="tab-btn" onclick="switchTab('archived')">
            <span class="badge-tab" id="count-archived">0</span>
            Encerrados
        </button>
    </nav>

    <main class="content-area">
        <section id="tab-pending" class="kanban-column active"><div class="orders-scroll" id="list-pending"></div></section>
        <section id="tab-preparing" class="kanban-column"><div class="orders-scroll" id="list-preparing"></div></section>
        <section id="tab-ready" class="kanban-column"><div class="orders-scroll" id="list-ready"></div></section>
        <section id="tab-archived" class="kanban-column"><div class="orders-scroll" id="list-archived"></div></section>
    </main>

    <div id="modal-overlay">
        <div class="comanda-digital" id="comanda-target"></div>
    </div>

    <script>
        // CONFIGURAÇÃO DO SOCKET (CONECTANDO AO SEU SERVIDOR)
        const socket = io(); 
        
        let orders = [];
        let archivedOrders = [];
        let historicalRevenue = 0;
        let totalProcessedOrders = 0;
        let isSlowMode = false;

        // ÁUDIO DE NOTIFICAÇÃO (O NOVO MP3 QUE CRIAMOS)
        const notificationSound = new Audio('/static/audio/notificacao_v2.mp3'); 

        // BUSCAR PEDIDOS INICIAIS DO SERVIDOR/BANCO
        async function fetchOrders() {
            try {
                const response = await fetch('/api/get-orders');
                const data = await response.json();
                orders = data.active || [];
                archivedOrders = data.archived || [];
                render();
            } catch (e) { console.error("Erro ao carregar banco:", e); }
        }

        // ESCUTAR NOVOS PEDIDOS VIA SOCKET
        socket.on('novoPedido', (novoPedido) => {
            orders.push(novoPedido);
            notificationSound.play().catch(n => console.log("Som aguardando interação"));
            render();
        });

        function toggleSlowMode() {
            isSlowMode = document.getElementById('slow-mode-toggle').checked;
            const statusIndicator = document.getElementById('status-online');
            statusIndicator.style.color = isSlowMode ? 'var(--status-alert)' : 'var(--status-ready)';
            statusIndicator.innerText = isSlowMode ? '● ALERTA DE ALTA DEMANDA' : '● SISTEMA ATIVO';
        }

        function switchTab(tabId) {
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.kanban-column').forEach(col => col.classList.remove('active'));
            const selectedBtn = document.querySelector(`button[onclick="switchTab('${tabId}')"]`);
            if(selectedBtn) selectedBtn.classList.add('active');
            document.getElementById(`tab-${tabId}`).classList.add('active');
        }

        function render() {
            const containers = {
                pending: document.getElementById('list-pending'),
                preparing: document.getElementById('list-preparing'),
                ready: document.getElementById('list-ready'),
                archived: document.getElementById('list-archived')
            };
            
            const counts = { pending: 0, preparing: 0, ready: 0, archived: archivedOrders.length };
            Object.values(containers).forEach(c => c.innerHTML = '');

            const now = Date.now();

            orders.forEach(order => {
                counts[order.status]++;
                const card = document.createElement('div');
                
                // LÓGICA DO FAROL (15 MINUTOS = 900.000ms)
                const isDelayed = (now - new Date(order.timestamp).getTime()) > 900000 && order.status !== 'ready';
                
                card.className = `order-card ${isDelayed ? 'delayed' : ''}`;
                card.onclick = () => showComanda(order.id);
                card.innerHTML = `
                    <div class="order-header">
                        <span class="order-id">#${order.id}</span>
                        <span class="order-time">${order.time}</span>
                    </div>
                    <div class="customer-name">${order.customer}</div>
                    <div class="order-details">
                        ${order.items.length} itens • <strong>${order.payment}</strong>
                    </div>
                `;
                containers[order.status].appendChild(card);
            });

            // RENDERIZAR ARQUIVADOS
            archivedOrders.forEach(order => {
                const card = document.createElement('div');
                card.className = 'order-card';
                card.style.opacity = '0.7';
                const total = order.items.reduce((acc, i) => acc + (i.price * i.qty), 0);
                const statusTag = order.canceled ? 
                    `<span style="color: var(--status-alert)">CANCELADO</span>` : 
                    `<span style="color: var(--status-ready)">FINALIZADO</span>`;

                card.innerHTML = `
                    <div class="order-header"><span class="order-id">#${order.id}</span><span>${statusTag}</span></div>
                    <div class="customer-name">${order.customer}</div>
                    <div class="order-details">Total: R$ ${total.toFixed(2)}</div>
                `;
                containers['archived'].appendChild(card);
            });

            document.getElementById('count-pending').innerText = counts.pending;
            document.getElementById('count-preparing').innerText = counts.preparing;
            document.getElementById('count-ready').innerText = counts.ready;
            document.getElementById('count-archived').innerText = counts.archived;
            
            // MÉTRICAS REAIS
            const revenue = archivedOrders.filter(o => !o.canceled).reduce((acc, o) => acc + o.total, 0);
            document.getElementById('m-revenue').innerText = `R$ ${revenue.toFixed(2)}`;
            document.getElementById('m-total-count').innerText = archivedOrders.length;
        }

        function showComanda(id) {
            const order = orders.find(o => o.id === id);
            if(!order) return;
            const target = document.getElementById('comanda-target');
            const total = order.items.reduce((acc, i) => acc + (i.price * i.qty), 0);

            let actionText = "";
            if(order.status === 'pending') actionText = `<button class="btn btn-confirm" onclick="updateOrderStatus('${order.id}', 'preparing')">INICIAR PRODUÇÃO</button>`;
            else if(order.status === 'preparing') actionText = `<button class="btn btn-confirm" onclick="updateOrderStatus('${order.id}', 'ready')">PRONTO PARA ENTREGA</button>`;
            else actionText = `<button class="btn btn-confirm" onclick="updateOrderStatus('${order.id}', 'archive')">FINALIZAR / ARQUIVAR</button>`;

            target.innerHTML = `
                <div class="ticket-header"><p>ELITE OPS</p><h1>#${order.id}</h1><p>${order.time}</p></div>
                <div><strong>CLIENTE:</strong> ${order.customer}<br><strong>ENDEREÇO:</strong> ${order.address}</div>
                <hr style="margin: 15px 0; border: 1px dashed #000;">
                ${order.items.map(i => `<div class="ticket-item"><span>${i.qty}x ${i.name}</span><span>R$ ${(i.qty * i.price).toFixed(2)}</span></div>`).join('')}
                <div class="ticket-total">TOTAL R$ ${total.toFixed(2)}</div>
                <div class="actions-bar">
                    ${actionText}
                    <button class="btn btn-cancel" onclick="toggleCancelReason()">CANCELAR PEDIDO</button>
                    <div id="cancel-box" class="cancel-reason-box">
                        <textarea id="reason-input" placeholder="Motivo..."></textarea>
                        <button class="btn btn-cancel" onclick="confirmCancel('${order.id}')">CONFIRMAR</button>
                    </div>
                    <button class="btn btn-close" onclick="closeModal()">VOLTAR</button>
                </div>
            `;
            document.getElementById('modal-overlay').style.display = 'flex';
        }

        // FUNÇÃO QUE CONECTA COM O BACKEND (MESMA LÓGICA DO ANTIGO)
        async function updateOrderStatus(id, newStatus) {
            try {
                const response = await fetch('/api/update-status', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({id, status: newStatus})
                });
                
                if(response.ok) {
                    // Atualiza localmente para resposta instantânea
                    if(newStatus === 'archive') {
                        const order = orders.find(o => o.id === id);
                        archivedOrders.unshift(order);
                        orders = orders.filter(o => o.id !== id);
                    } else {
                        orders.find(o => o.id === id).status = newStatus;
                    }
                    closeModal();
                    render();
                    if(newStatus !== 'archive') switchTab(newStatus);
                }
            } catch (e) { alert("Erro ao atualizar no banco de dados."); }
        }

        function toggleCancelReason() {
            const box = document.getElementById('cancel-box');
            box.style.display = box.style.display === 'flex' ? 'none' : 'flex';
        }

        function closeModal() { document.getElementById('modal-overlay').style.display = 'none'; }

        setInterval(() => {
            document.getElementById('clock').innerText = new Date().toLocaleTimeString('pt-BR');
            render(); // Re-renderiza para atualizar os brilhos de atraso em tempo real
        }, 1000);

        window.onload = fetchOrders;
    </script>
</body>
</html>