<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Farol da Operação | Painel</title>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        :root {
            --bg-page: #f4f7f9;
            --bg-col: #ebedef;
            --card-bg: #ffffff;
            --text-dark: #333;
            --text-light: #666;
            --primary: #e61e1e; 
            --warning: #f39c12;
            --success: #27ae60;
            --info: #2980b9;
            --finalizado: #95a5a6;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-page);
            color: var(--text-dark);
            margin: 0;
            padding: 20px;
            overflow: hidden;
        }

        .header-painel {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            gap: 20px;
        }

        .header-left { display: flex; align-items: center; gap: 15px; }

        .header-title {
            display: flex;
            align-items: center;
            gap: 10px;
            background: white;
            padding: 8px 20px;
            border-radius: 30px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        .search-container { flex-grow: 1; max-width: 400px; }
        .search-input {
            width: 100%;
            padding: 10px 15px;
            border-radius: 20px;
            border: 1px solid #ddd;
            outline: none;
            font-size: 0.9rem;
        }

        .kanban {
            display: flex;
            gap: 15px;
            overflow-x: auto;
            align-items: flex-start;
            height: calc(100vh - 110px);
            padding-bottom: 20px;
        }

        .col {
            background-color: var(--bg-col);
            border-radius: 15px;
            min-width: 280px;
            max-width: 280px;
            display: flex;
            flex-direction: column;
            max-height: 100%;
        }

        .col-header {
            padding: 15px;
            font-weight: bold;
            font-size: 0.9rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: #555;
        }

        .count-badge {
            background: #ccc;
            color: #fff;
            border-radius: 50%;
            width: 22px;
            height: 22px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 0.7rem;
        }

        .lista-pedidos { padding: 10px; overflow-y: auto; flex-grow: 1; }

        .mini-card {
            background: var(--card-bg);
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
            border: 1px solid #eee;
        }

        .waiting-text {
            font-size: 0.75rem;
            font-weight: bold;
            margin-bottom: 5px;
            display: block;
        }
        .text-danger { color: var(--primary); }
        .text-warning { color: var(--warning); }
        .text-success { color: var(--success); }
        .text-muted { color: var(--finalizado); }

        .mini-card-id { font-size: 1.4rem; font-weight: 800; margin: 2px 0; display: block; }
        .mini-card-cliente { font-size: 0.9rem; color: var(--text-light); margin-bottom: 12px; display: block; }

        .btn-main {
            width: 100%;
            padding: 10px;
            border: none;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.2s;
            margin-bottom: 5px;
            font-size: 0.85rem;
        }

        .btn-aceitar { background: var(--primary); color: white; }
        .btn-preparando { background: #ddd; color: #777; cursor: not-allowed; }
        .btn-pronto { background: var(--success); color: white; }
        .btn-enviar { background: var(--info); color: white; }
        .btn-finalizar { background: var(--finalizado); color: white; }
        .btn-detalhe { background: #eee; color: #555; }
        .btn-cancelar { background: #fdf2f2; color: var(--primary); font-size: 0.75rem; }

        .modal {
            display: none; position: fixed; z-index: 1000;
            left: 0; top: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5); justify-content: center; align-items: center;
        }
        .modal-content { background: white; padding: 20px; border-radius: 15px; width: 90%; max-width: 400px; }
        .original-card-wrapper { display: none; }
    </style>
</head>
<body>

    <header class="header-painel">
        <div class="header-left">
            <div class="header-title">
                <span style="color:var(--success)">●</span> 
                <strong>Farol da Operação</strong>
            </div>
            <div class="search-container">
                <input type="text" id="searchInput" class="search-input" placeholder="Buscar por nome ou pedido...">
            </div>
        </div>
        <a href="/admin" style="text-decoration: none; color: #666; font-weight: bold;">Sair</a>
    </header>

    <div class="kanban">
        <div class="col">
            <div class="col-header">Aceitar <span class="count-badge"><%= pedidos.filter(p => p.status === 'Pendente').length %></span></div>
            <div class="lista-pedidos" id="pendentes">
                <% pedidos.filter(p => p.status === 'Pendente').forEach(p => { %>
                    <div class="mini-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>" data-time="<%= p.createdAt %>">
                        <span class="waiting-text label-topo" id="label-topo-<%= p.id %>"></span>
                        <span class="mini-card-id"><%= p.id.toString().slice(-4) %></span>
                        <span class="mini-card-cliente"><%= p.cliente %></span>
                        <div id="btn-area-<%= p.id %>">
                            <button class="btn-main btn-aceitar" onclick="atualizarStatus('<%= p.id %>', 'Preparando')">Aceitar em até 5min</button>
                        </div>
                        <button class="btn-main btn-detalhe" onclick="abrirDetalhes('<%= p.id %>')">Detalhes</button>
                        <button class="btn-main btn-cancelar" onclick="cancelarPedido('<%= p.id %>')">Cancelar</button>
                        <div id="wrapper-<%= p.id %>" class="original-card-wrapper"><%- include('partials/card-comanda', {p: p}) %></div>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="col">
            <div class="col-header">Em preparo <span class="count-badge"><%= pedidos.filter(p => p.status === 'Preparando').length %></span></div>
            <div class="lista-pedidos">
                <% pedidos.filter(p => p.status === 'Preparando').forEach(p => { %>
                    <div class="mini-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>" data-time="<%= p.updatedAt %>">
                        <span class="waiting-text label-topo" id="label-topo-<%= p.id %>"></span>
                        <span class="mini-card-id"><%= p.id.toString().slice(-4) %></span>
                        <span class="mini-card-cliente"><%= p.cliente %></span>
                        <div id="btn-area-<%= p.id %>"></div>
                        <button class="btn-main btn-detalhe" onclick="abrirDetalhes('<%= p.id %>')">Detalhes</button>
                        <button class="btn-main btn-cancelar" onclick="cancelarPedido('<%= p.id %>')">Cancelar</button>
                        <div id="wrapper-<%= p.id %>" class="original-card-wrapper"><%- include('partials/card-comanda', {p: p}) %></div>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="col">
            <div class="col-header">Pronto <span class="count-badge"><%= pedidos.filter(p => p.status === 'Pronto').length %></span></div>
            <div class="lista-pedidos">
                <% pedidos.filter(p => p.status === 'Pronto').forEach(p => { %>
                    <div class="mini-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>" data-time="<%= p.updatedAt %>">
                        <span class="waiting-text label-topo" id="label-topo-<%= p.id %>"></span>
                        <span class="mini-card-id"><%= p.id.toString().slice(-4) %></span>
                        <span class="mini-card-cliente"><%= p.cliente %></span>
                        <div id="btn-area-<%= p.id %>">
                            <button class="btn-main btn-enviar" onclick="atualizarStatus('<%= p.id %>', 'Saiu para Entrega')">Enviar para rota</button>
                        </div>
                        <button class="btn-main btn-detalhe" onclick="abrirDetalhes('<%= p.id %>')">Detalhes</button>
                        <button class="btn-main btn-cancelar" onclick="cancelarPedido('<%= p.id %>')">Cancelar</button>
                        <div id="wrapper-<%= p.id %>" class="original-card-wrapper"><%- include('partials/card-comanda', {p: p}) %></div>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="col">
            <div class="col-header">Em rota <span class="count-badge"><%= pedidos.filter(p => p.status === 'Saiu para Entrega').length %></span></div>
            <div class="lista-pedidos">
                <% pedidos.filter(p => p.status === 'Saiu para Entrega').forEach(p => { %>
                    <div class="mini-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>">
                        <span class="waiting-text text-warning">🛵 Em rota de entrega</span>
                        <span class="mini-card-id"><%= p.id.toString().slice(-4) %></span>
                        <span class="mini-card-cliente"><%= p.cliente %></span>
                        <button class="btn-main btn-finalizar" onclick="atualizarStatus('<%= p.id %>', 'Finalizado')">Finalizar Pedido</button>
                        <button class="btn-main btn-detalhe" onclick="abrirDetalhes('<%= p.id %>')">Detalhes</button>
                        <div id="wrapper-<%= p.id %>" class="original-card-wrapper"><%- include('partials/card-comanda', {p: p}) %></div>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="col">
            <div class="col-header">Finalizados <span class="count-badge"><%= pedidos.filter(p => p.status === 'Finalizado').length %></span></div>
            <div class="lista-pedidos">
                <% pedidos.filter(p => p.status === 'Finalizado').forEach(p => { %>
                    <div class="mini-card search-item" data-id="<%= p.id %>" data-cliente="<%= p.cliente.toLowerCase() %>">
                        <span class="waiting-text text-muted">✅ Pedido Concluído</span>
                        <span class="mini-card-id"><%= p.id.toString().slice(-4) %></span>
                        <span class="mini-card-cliente"><%= p.cliente %></span>
                        <button class="btn-main btn-detalhe" onclick="abrirDetalhes('<%= p.id %>')">Ver Detalhes</button>
                        <div id="wrapper-<%= p.id %>" class="original-card-wrapper"><%- include('partials/card-comanda', {p: p}) %></div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>

    <div id="modalDetalhes" class="modal">
        <div class="modal-content">
            <div id="comanda-interna"></div>
            <button class="btn-main" onclick="fecharModal()">Fechar</button>
        </div>
    </div>

    <audio id="audioNotificacao" src="/notificacao.mp3" preload="auto"></audio>

    <script>
        const socket = io();

        function updateFarol() {
            const now = new Date();
            const cards = document.querySelectorAll('.mini-card[data-time]');

            cards.forEach(card => {
                const id = card.getAttribute('data-id');
                const cliente = card.querySelector('.mini-card-cliente').innerText;
                const startTime = new Date(card.getAttribute('data-time'));
                const diffMin = Math.floor((now - startTime) / 60000);
                
                const labelTopo = card.querySelector('.label-topo');
                const btnArea = card.querySelector(`#btn-area-${id}`);
                const statusColElement = card.closest('.col').querySelector('.col-header');
                if(!statusColElement) return;

                const statusCol = statusColElement.innerText;

                // LOGICA COLUNA ACEITAR
                if (statusCol.includes("Aceitar")) {
                    if (diffMin >= 5) {
                        labelTopo.innerHTML = `<span class="text-danger">${cliente} aguardando a ${diffMin} min</span>`;
                        btnArea.innerHTML = `<button class="btn-main btn-aceitar" onclick="atualizarStatus('${id}', 'Preparando')">Pedido em atraso a ${diffMin} min</button>`;
                    } else {
                        labelTopo.innerHTML = `<span class="text-light">Novo pedido</span>`;
                    }
                }

                // LOGICA COLUNA EM PREPARO
                if (statusCol.includes("Em preparo")) {
                    if (diffMin < 5) {
                        labelTopo.innerHTML = `<span class="text-warning">Em preparo... ${5 - diffMin} min restantes</span>`;
                        btnArea.innerHTML = `<button class="btn-main btn-preparando">Em preparo</button>`;
                    } else {
                        const atraso = diffMin - 5;
                        labelTopo.innerHTML = atraso > 0 ? `<span class="text-danger">⚠️ ${cliente} aguardando a ${diffMin} min</span>` : `<span class="text-success">Pronto para finalizar</span>`;
                        btnArea.innerHTML = `<button class="btn-main btn-pronto" onclick="atualizarStatus('${id}', 'Pronto')">Pronto</button>`;
                    }
                }

                // LOGICA COLUNA PRONTO (Atraso 15 min)
                if (statusCol.includes("Pronto")) {
                    if (diffMin >= 15) {
                        labelTopo.innerHTML = `<span class="text-danger">⚠️ Pedido pronto em atraso a ${diffMin} min</span>`;
                    } else {
                        labelTopo.innerHTML = `<span class="text-success">Pedido pronto há ${diffMin} min</span>`;
                    }
                }
            });
        }

        setInterval(updateFarol, 5000);
        updateFarol();

        // BUSCA
        document.getElementById('searchInput').addEventListener('input', (e) => {
            const term = e.target.value.toLowerCase();
            document.querySelectorAll('.search-item').forEach(item => {
                const searchStr = item.getAttribute('data-cliente') + item.getAttribute('data-id');
                item.style.display = searchStr.includes(term) ? 'block' : 'none';
            });
        });

        async function atualizarStatus(id, novoStatus) {
            try {
                const res = await fetch('/update-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, novoStatus })
                });
                if (res.ok) window.location.reload();
            } catch (err) { console.error(err); }
        }

        async function cancelarPedido(id) {
            if (confirm("Cancelar pedido?")) atualizarStatus(id, 'Cancelado');
        }

        function abrirDetalhes(id) {
            const wrapper = document.getElementById(`wrapper-${id}`);
            if(wrapper) {
                document.getElementById('comanda-interna').innerHTML = wrapper.innerHTML;
                document.getElementById('modalDetalhes').style.display = "flex";
            }
        }
        function fecharModal() { document.getElementById('modalDetalhes').style.display = "none"; }

        socket.on('novoPedido', () => { 
            document.getElementById('audioNotificacao').play();
            setTimeout(() => window.location.reload(), 1000); 
        });
        socket.on('statusAtualizado', () => window.location.reload());
    </script>
</body>
</html>