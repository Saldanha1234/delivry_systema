<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Farol da Operação | Painel</title>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        :root {
            --bg-page: #f4f7f9;
            --bg-col: #ebedef;
            --card-bg: #ffffff;
            --text-dark: #333;
            --text-light: #666;
            --primary: #e61e1e; /* Vermelho iFood Style */
            --warning: #f39c12;
            --success: #27ae60;
            --info: #2980b9;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-page);
            color: var(--text-dark);
            margin: 0;
            padding: 20px;
        }

        /* Header Estilizado */
        .header-painel {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .header-title {
            display: flex;
            align-items: center;
            gap: 10px;
            background: white;
            padding: 5px 20px;
            border-radius: 30px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        /* Kanban Layout */
        .kanban {
            display: flex;
            gap: 20px;
            overflow-x: auto;
            align-items: flex-start;
            height: calc(100vh - 120px);
        }

        .col {
            background-color: var(--bg-col);
            border-radius: 15px;
            min-width: 300px;
            max-width: 300px;
            display: flex;
            flex-direction: column;
            max-height: 100%;
        }

        .col-header {
            padding: 15px;
            font-weight: bold;
            font-size: 0.9rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: #555;
        }

        .count-badge {
            background: #ccc;
            color: #fff;
            border-radius: 50%;
            width: 22px;
            height: 22px;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 0.7rem;
        }

        .lista-pedidos {
            padding: 10px;
            overflow-y: auto;
            flex-grow: 1;
        }

        /* Cards Estilo Imagem */
        .mini-card {
            background: var(--card-bg);
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
            border: 1px solid #eee;
            position: relative;
        }

        /* Tags de Tempo/Status */
        .status-tag {
            font-size: 0.75rem;
            font-weight: bold;
            margin-bottom: 8px;
            display: block;
        }
        .tag-atraso { color: var(--primary); }
        .tag-alerta { color: var(--warning); }
        .tag-sucesso { color: var(--success); }

        .mini-card-id { font-size: 1.4rem; font-weight: 800; margin: 5px 0; display: block; }
        .mini-card-cliente { font-size: 0.9rem; color: var(--text-light); margin-bottom: 15px; display: block; }

        /* Botões Estilizados */
        .btn-main {
            width: 100%;
            padding: 10px;
            border: none;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.2s;
            margin-bottom: 5px;
        }

        .btn-aceitar { background: var(--primary); color: white; }
        .btn-preparar { background: var(--warning); color: white; }
        .btn-detalhe { background: #eee; color: #555; }
        .btn-cancelar { background: #fdf2f2; color: var(--primary); border: 1px solid #fee2e2; }
        .btn-enviar { background: var(--success); color: white; }

        .original-card-wrapper { display: none; }

        /* Modal */
        .modal {
            display: none; position: fixed; z-index: 1000;
            left: 0; top: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.5); justify-content: center; align-items: center;
        }
        .modal-content { background: white; padding: 20px; border-radius: 15px; width: 90%; max-width: 400px; }
    </style>
</head>
<body>

    <header class="header-painel">
        <div class="header-title">
            <span style="color:var(--success)">●</span> 
            <strong>Farol da Operação</strong>
        </div>
        <a href="/admin" style="text-decoration: none; color: #666; font-weight: bold;">Sair</a>
    </header>

    <div class="kanban">
        <div class="col">
            <div class="col-header">Aceitar <span class="count-badge"><%= pedidos.filter(p => p.status === 'Pendente').length %></span></div>
            <div class="lista-pedidos" id="pendentes">
                <% pedidos.filter(p => p.status === 'Pendente').forEach(p => { %>
                    <div class="mini-card" data-id="<%= p.id %>" data-time="<%= p.createdAt %>">
                        <span class="status-tag timer-label" id="timer-<%= p.id %>">Carregando...</span>
                        <span class="mini-card-id"><%= p.id.toString().slice(-4) %></span>
                        <span class="mini-card-cliente"><%= p.cliente %></span>
                        
                        <button class="btn-main btn-aceitar" onclick="atualizarStatus('<%= p.id %>', 'Preparando')">Aceite em até 5min</button>
                        <button class="btn-main btn-detalhe" onclick="abrirDetalhes('<%= p.id %>')">Detalhes</button>
                        <button class="btn-main btn-cancelar" onclick="cancelarPedido('<%= p.id %>')">Cancelar</button>

                        <div id="wrapper-<%= p.id %>" class="original-card-wrapper">
                            <%- include('partials/card-comanda', {p: p}) %>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="col">
            <div class="col-header">Em preparo <span class="count-badge"><%= pedidos.filter(p => p.status === 'Preparando').length %></span></div>
            <div class="lista-pedidos">
                <% pedidos.filter(p => p.status === 'Preparando').forEach(p => { %>
                    <div class="mini-card" data-id="<%= p.id %>" data-time="<%= p.updatedAt %>">
                        <span class="status-tag timer-label" id="timer-preparo-<%= p.id %>">Preparar em até 5min</span>
                        <span class="mini-card-id"><%= p.id.toString().slice(-4) %></span>
                        <span class="mini-card-cliente"><%= p.cliente %></span>
                        
                        <div id="ctrl-preparo-<%= p.id %>">
                            <button class="btn-main btn-preparar" onclick="iniciarCronometroPreparo('<%= p.id %>')">Iniciar Preparo</button>
                        </div>
                        
                        <button class="btn-main btn-detalhe" onclick="abrirDetalhes('<%= p.id %>')">Detalhes</button>
                        <button class="btn-main btn-cancelar" onclick="cancelarPedido('<%= p.id %>')">Cancelar</button>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="col">
            <div class="col-header">Pronto <span class="count-badge"><%= pedidos.filter(p => p.status === 'Pronto').length %></span></div>
            <div class="lista-pedidos">
                <% pedidos.filter(p => p.status === 'Pronto').forEach(p => { %>
                    <div class="mini-card">
                        <span class="status-tag tag-sucesso">Pronto para entrega</span>
                        <span class="mini-card-id"><%= p.id.toString().slice(-4) %></span>
                        <span class="mini-card-cliente"><%= p.cliente %></span>
                        
                        <button class="btn-main btn-enviar" onclick="atualizarStatus('<%= p.id %>', 'Saiu para Entrega')">Enviar Entrega</button>
                        <button class="btn-main btn-detalhe" onclick="abrirDetalhes('<%= p.id %>')">Detalhes</button>
                        <button class="btn-main btn-cancelar" onclick="cancelarPedido('<%= p.id %>')">Cancelar</button>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="col">
            <div class="col-header">Em rota <span class="count-badge"><%= pedidos.filter(p => p.status === 'Saiu para Entrega').length %></span></div>
            <div class="lista-pedidos">
                <% pedidos.filter(p => p.status === 'Saiu para Entrega').forEach(p => { %>
                    <div class="mini-card">
                        <span class="status-tag tag-alerta">🛵 Chega em até 15min</span>
                        <span class="mini-card-id"><%= p.id.toString().slice(-4) %></span>
                        <span class="mini-card-cliente"><%= p.cliente %></span>
                        
                        <button class="btn-main btn-detalhe" onclick="abrirDetalhes('<%= p.id %>')">Detalhes</button>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>

    <div id="modalDetalhes" class="modal">
        <div class="modal-content">
            <div id="comanda-interna"></div>
            <button class="btn-main" onclick="fecharModal()">Fechar</button>
        </div>
    </div>

    <audio id="audioNotificacao" src="/notificacao.mp3" preload="auto"></audio>

    <script>
        const socket = io();

        // 1. Lógica de Tempo Real para Atrasos (Colunas Iniciais)
        function checkTimers() {
            const cards = document.querySelectorAll('.mini-card[data-time]');
            cards.forEach(card => {
                const createdAt = new Date(card.getAttribute('data-time'));
                const now = new Date();
                const diffMs = now - createdAt;
                const diffMin = Math.floor(diffMs / 60000);
                const timerEl = card.querySelector('.timer-label');

                if (diffMin >= 5) {
                    timerEl.innerHTML = `⚠️ Pedido em atraso há ${diffMin} min`;
                    timerEl.className = "status-tag tag-atraso";
                } else {
                    timerEl.innerHTML = `Aguardando há ${diffMin} min`;
                    timerEl.className = "status-tag";
                }
            });
        }
        setInterval(checkTimers, 10000);
        checkTimers();

        // 2. Lógica Específica do Preparo (5 minutos fixos)
        function iniciarCronometroPreparo(id) {
            const container = document.getElementById(`ctrl-preparo-${id}`);
            const label = document.getElementById(`timer-preparo-${id}`);
            
            let tempoRestante = 5; // minutos
            container.innerHTML = `<p style="text-align:center; font-weight:bold; color:var(--warning)">Cozinhando... </p>`;
            
            const interval = setInterval(() => {
                tempoRestante--;
                label.innerHTML = `Pronto em ${tempoRestante} min`;
                label.className = "status-tag tag-alerta";

                if (tempoRestante <= 0) {
                    clearInterval(interval);
                    atualizarStatus(id, 'Pronto');
                }
            }, 60000); // Roda a cada 1 minuto

            label.innerHTML = `Pronto em 5 min`;
        }

        // 3. Funções de Status
        async function atualizarStatus(id, novoStatus) {
            try {
                const response = await fetch('/update-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, novoStatus })
                });
                if (response.ok) { window.location.reload(); }
            } catch (err) { console.error(err); }
        }

        async function cancelarPedido(id) {
            if (confirm("Cancelar este pedido?")) {
                atualizarStatus(id, 'Cancelado');
            }
        }

        // Modal e Socket (Mantidos da sua lógica original)
        function abrirDetalhes(id) {
            const wrapper = document.getElementById(`wrapper-${id}`);
            if(wrapper) {
                document.getElementById('comanda-interna').innerHTML = wrapper.innerHTML;
                document.getElementById('modalDetalhes').style.display = "flex";
            }
        }
        function fecharModal() { document.getElementById('modalDetalhes').style.display = "none"; }

        socket.on('novoPedido', () => { 
            document.getElementById('audioNotificacao').play();
            setTimeout(() => window.location.reload(), 1000); 
        });
        socket.on('statusAtualizado', () => window.location.reload());
    </script>
</body>
</html>