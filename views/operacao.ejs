<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel de Operações | Comandas</title>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        :root {
            --bg-body: #121212;
            --col-bg: #1e1e1e;
            --text-main: #ffffff;
            --accent: #f1c40f;
            --pendente: #e74c3c;
            --preparando: #3498db;
            --entrega: #2ecc71;
            --card-inner: #252525;
            --primary: #FF385C;
            --cancelar: #555;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            margin: 0;
            padding: 10px;
            overflow-x: hidden;
        }

        .header-painel {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #333;
        }

        .header-painel h1 { margin: 0; font-size: 1.2rem; display: flex; align-items: center; gap: 10px; }

        .status-badge {
            background: rgba(46, 204, 113, 0.1);
            color: var(--entrega);
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.7rem;
            border: 1px solid var(--entrega);
        }

        .btn-voltar {
            background: #333; color: white; text-decoration: none;
            padding: 8px 15px; border-radius: 8px; font-weight: bold;
            transition: 0.3s; border: 1px solid #444; font-size: 0.8rem;
        }

        .kanban {
            display: flex; gap: 15px; overflow-x: auto;
            align-items: flex-start; padding-bottom: 30px;
            height: calc(100vh - 120px);
        }

        .col {
            background-color: var(--col-bg); border-radius: 12px;
            min-width: 280px; max-width: 320px; display: flex;
            flex-direction: column; max-height: 100%;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3); border: 1px solid #333;
        }

        .col-header {
            padding: 12px; text-align: center; font-weight: 800;
            text-transform: uppercase; border-radius: 12px 12px 0 0;
            font-size: 0.75rem;
        }

        .col-pendente { border-top: 5px solid var(--pendente); background: rgba(231, 76, 60, 0.1); color: var(--pendente); }
        .col-preparando { border-top: 5px solid var(--preparando); background: rgba(52, 152, 219, 0.1); color: var(--preparando); }
        .col-entrega { border-top: 5px solid var(--entrega); background: rgba(46, 204, 113, 0.1); color: var(--entrega); }

        .lista-pedidos {
            padding: 10px; overflow-y: auto; flex-grow: 1;
            display: grid; grid-template-columns: 1fr; gap: 10px;
        }

        .mini-card {
            background: var(--card-inner); border-radius: 8px;
            padding: 10px; border: 1px solid #333;
            display: flex; flex-direction: column; gap: 8px;
        }

        .mini-card-info { display: flex; justify-content: space-between; align-items: center; }
        .mini-card-id { font-weight: bold; color: var(--accent); font-size: 0.8rem; }
        .mini-card-cliente { font-size: 0.8rem; color: #bbb; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 130px; }

        /* Estilo dos Botões Pequenos */
        .btn-group { display: flex; gap: 4px; flex-wrap: wrap; }
        .btn-acao {
            flex: 1; padding: 6px 4px; border: none; border-radius: 4px;
            font-size: 0.65rem; font-weight: bold; cursor: pointer;
            text-transform: uppercase; transition: 0.2s;
            min-width: 60px;
        }
        .btn-detalhes { background: #444; color: white; }
        .btn-proximo { background: var(--primary); color: white; }
        .btn-cancelar { background: #333; color: #e74c3c; border: 1px solid #444; }
        .btn-cancelar:hover { background: #e74c3c; color: white; }

        .modal {
            display: none; position: fixed; z-index: 999;
            left: 0; top: 0; width: 100%; height: 100%;
            background-color: rgba(0,0,0,0.85); backdrop-filter: blur(5px);
            justify-content: center; align-items: center;
        }
        .modal-content {
            width: 95%; max-width: 400px; position: relative;
            animation: fadeIn 0.3s ease;
        }
        @keyframes fadeIn { from { opacity: 0; transform: scale(0.9); } to { opacity: 1; transform: scale(1); } }
        
        .close-modal-btn { 
            position: absolute; top: -35px; right: 0; color: white; 
            font-size: 30px; cursor: pointer; background: none; border: none;
        }

        .original-card-wrapper { display: none; }

        @media (max-width: 768px) {
            .kanban { flex-direction: column; height: auto; }
            .col { min-width: 100%; margin-bottom: 15px; }
        }
    </style>
</head>
<body>

    <header class="header-painel">
        <div>
            <h1>📦 Operações</h1>
            <div style="margin-top: 4px; display: flex; align-items: center; gap: 8px;">
                <span id="socket-status" class="status-badge">● Online</span>
            </div>
        </div>
        <a href="/admin" class="btn-voltar">🏠 Sair</a>
    </header>

    <div class="kanban">
        <div class="col">
            <div class="col-header col-pendente">🟡 Novos (<%= pedidos.filter(p => p.status === 'Pendente').length %>)</div>
            <div class="lista-pedidos" id="pendentes">
                <% pedidos.filter(p => p.status === 'Pendente').forEach(p => { %>
                    <div class="mini-card">
                        <div class="mini-card-info">
                            <span class="mini-card-id">#<%= p.id.toString().slice(-4) %></span>
                            <span class="mini-card-cliente"><%= p.cliente %></span>
                        </div>
                        <div class="btn-group">
                            <button class="btn-acao btn-detalhes" onclick="abrirDetalhes('<%= p.id %>')">Ver</button>
                            <button class="btn-acao btn-proximo" onclick="atualizarStatus('<%= p.id %>', 'Preparando')">Iniciar</button>
                            <button class="btn-acao btn-cancelar" onclick="cancelarPedido('<%= p.id %>')">X</button>
                        </div>
                        <div id="wrapper-<%= p.id %>" class="original-card-wrapper">
                            <%- include('partials/card-comanda', {p: p}) %>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="col">
            <div class="col-header col-preparando">🔥 Preparo (<%= pedidos.filter(p => p.status === 'Preparando').length %>)</div>
            <div class="lista-pedidos" id="preparando">
                <% pedidos.filter(p => p.status === 'Preparando').forEach(p => { %>
                    <div class="mini-card">
                        <div class="mini-card-info">
                            <span class="mini-card-id">#<%= p.id.toString().slice(-4) %></span>
                            <span class="mini-card-cliente"><%= p.cliente %></span>
                        </div>
                        <div class="btn-group">
                            <button class="btn-acao btn-detalhes" onclick="abrirDetalhes('<%= p.id %>')">Ver</button>
                            <button class="btn-acao btn-proximo" style="background:var(--preparando)" onclick="atualizarStatus('<%= p.id %>', 'Saiu para Entrega')">Enviar</button>
                            <button class="btn-acao btn-cancelar" onclick="cancelarPedido('<%= p.id %>')">X</button>
                        </div>
                        <div id="wrapper-<%= p.id %>" class="original-card-wrapper">
                            <%- include('partials/card-comanda', {p: p}) %>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <div class="col">
            <div class="col-header col-entrega">🛵 Entrega (<%= pedidos.filter(p => p.status === 'Saiu para Entrega').length %>)</div>
            <div class="lista-pedidos" id="entrega">
                <% pedidos.filter(p => p.status === 'Saiu para Entrega').forEach(p => { %>
                    <div class="mini-card">
                        <div class="mini-card-info">
                            <span class="mini-card-id">#<%= p.id.toString().slice(-4) %></span>
                            <span class="mini-card-cliente"><%= p.cliente %></span>
                        </div>
                        <div class="btn-group">
                            <button class="btn-acao btn-detalhes" onclick="abrirDetalhes('<%= p.id %>')">Ver</button>
                            <button class="btn-acao btn-proximo" style="background:var(--entrega)" onclick="atualizarStatus('<%= p.id %>', 'Concluído')">Fim</button>
                            <button class="btn-acao btn-cancelar" onclick="cancelarPedido('<%= p.id %>')">X</button>
                        </div>
                        <div id="wrapper-<%= p.id %>" class="original-card-wrapper">
                            <%- include('partials/card-comanda', {p: p}) %>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>

    <div id="modalDetalhes" class="modal">
        <div class="modal-content">
            <button class="close-modal-btn" onclick="fecharModal()">&times;</button>
            <div id="comanda-interna"></div>
        </div>
    </div>

    <audio id="audioNotificacao" src="/notificacao.mp3" preload="auto"></audio>

    <script>
        const socket = io();
        const audio = document.getElementById('audioNotificacao');

        function abrirDetalhes(id) {
            const originalCardHtml = document.getElementById(`wrapper-${id}`).innerHTML;
            document.getElementById('comanda-interna').innerHTML = originalCardHtml;
            document.getElementById('modalDetalhes').style.display = "flex";
        }

        function fecharModal() {
            document.getElementById('modalDetalhes').style.display = "none";
            document.getElementById('comanda-interna').innerHTML = "";
        }

        async function atualizarStatus(id, novoStatus) {
            try {
                const response = await fetch('/update-status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, novoStatus })
                });
                if (response.ok) { window.location.reload(); }
            } catch (err) { console.error("Erro:", err); }
        }

        async function cancelarPedido(id) {
            if (confirm("Deseja realmente CANCELAR este pedido? Ele não constará no faturamento.")) {
                try {
                    // Aqui você pode usar a mesma rota de status mudando para 'Cancelado'
                    // Ou uma rota específica /cancel-order que você configurou no backend
                    const response = await fetch('/update-status', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id, novoStatus: 'Cancelado' })
                    });
                    if (response.ok) { window.location.reload(); }
                } catch (err) { console.error("Erro ao cancelar:", err); }
            }
        }

        socket.on('novoPedido', (pedido) => {
            audio.play().catch(e => console.log("Áudio pendente."));
            setTimeout(() => { window.location.reload(); }, 500);
        });

        socket.on('statusAtualizado', () => { window.location.reload(); });

        window.onclick = function(event) {
            const modal = document.getElementById('modalDetalhes');
            if (event.target == modal) fecharModal();
        }
    </script>
</body>
</html>