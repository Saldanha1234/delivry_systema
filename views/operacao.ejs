<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>ELITE OPS | Kitchen Display System</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <script src="/socket.io/socket.io.js"></script>
    <style>
        :root {
            --bg-deep: #020203;
            --bg-surface: #0a0a0c;
            --bg-card: #121217;
            --accent-primary: #8257e5;
            --accent-glow: rgba(130, 87, 229, 0.4);
            --text-main: #e1e1e6;
            --text-dim: #a8a8b3;
            --status-pending: #ffb86c;
            --status-preparing: #8be9fd;
            --status-ready: #50fa7b;
            --status-alert: #ff4b4b;
            --border-color: rgba(255, 255, 255, 0.06);
            --transition-smooth: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background-color: var(--bg-deep);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            overflow: hidden; 
            height: 100vh;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        body::before {
            content: '';
            position: absolute;
            top: -5%; left: -5%;
            width: 150px; height: 150px;
            background: var(--accent-glow);
            filter: blur(80px);
            z-index: -1;
            border-radius: 50%;
        }

        header {
            height: 60px;
            padding: 0 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(10, 10, 12, 0.95);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--border-color);
            z-index: 100;
            flex-shrink: 0;
        }

        .brand {
            font-size: 1rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .brand span { color: var(--accent-primary); }

        .header-info {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 2px;
        }

        #clock {
            font-family: 'JetBrains Mono';
            color: var(--accent-primary);
            font-size: 0.85rem;
            font-weight: 700;
        }

        #status-online {
            font-size: 0.6rem;
            color: var(--status-ready);
            text-transform: uppercase;
        }

        .metrics-bar {
            background: rgba(255, 255, 255, 0.02);
            border-bottom: 1px solid var(--border-color);
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            padding: 8px 5px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.65rem;
            color: var(--text-dim);
            text-align: center;
        }

        .metric-item span {
            display: block;
            color: var(--status-ready);
            font-weight: 700;
            margin-top: 2px;
        }

        nav.tab-bar {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            background: var(--bg-surface);
            border-bottom: 1px solid var(--border-color);
            flex-shrink: 0;
        }

        .tab-btn {
            background: transparent;
            border: none;
            color: var(--text-dim);
            padding: 12px 2px;
            font-weight: 600;
            font-size: 0.7rem;
            cursor: pointer;
            transition: var(--transition-smooth);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            position: relative;
            text-transform: uppercase;
        }

        .tab-btn.active { color: var(--text-main); }
        .tab-btn.active::after {
            content: '';
            position: absolute;
            bottom: 0;
            width: 60%;
            height: 2px;
            background: var(--accent-primary);
            box-shadow: 0 -2px 8px var(--accent-primary);
        }

        .badge-tab {
            font-size: 0.65rem;
            background: rgba(255,255,255,0.08);
            padding: 1px 6px;
            border-radius: 8px;
            border: 1px solid var(--border-color);
        }

        .content-area {
            flex-grow: 1;
            position: relative;
            overflow: hidden;
            width: 100%;
        }

        .kanban-column {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            display: none;
            flex-direction: column;
            animation: fadeIn 0.3s ease;
        }

        .kanban-column.active { display: flex; }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(5px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .orders-scroll {
            overflow-y: auto;
            flex-grow: 1;
            padding: 15px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            -webkit-overflow-scrolling: touch;
        }

        .order-card {
            background: var(--bg-card);
            border-radius: 12px;
            padding: 15px;
            border: 1px solid var(--border-color);
            transition: var(--transition-smooth);
            width: 100%;
            flex-shrink: 0;
        }

        .order-card.delayed {
            border-color: var(--status-alert);
            animation: alertPulse 2s infinite;
        }

        @keyframes alertPulse {
            0% { box-shadow: 0 0 0px rgba(255, 75, 75, 0); }
            50% { box-shadow: 0 0 12px rgba(255, 75, 75, 0.2); }
            100% { box-shadow: 0 0 0px rgba(255, 75, 75, 0); }
        }

        .order-header { 
            display: flex; 
            justify-content: space-between; 
            margin-bottom: 8px; 
            font-size: 0.8rem;
        }
        .order-id { font-family: 'JetBrains Mono', monospace; color: var(--accent-primary); font-weight: 700; }
        .order-time { color: var(--text-dim); }
        .customer-name { font-size: 1.1rem; font-weight: 700; margin-bottom: 4px; }
        .order-details { font-size: 0.85rem; color: var(--text-dim); }

        #modal-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.9);
            display: none;
            justify-content: center;
            align-items: flex-start;
            overflow-y: auto;
            padding: 20px 10px;
            z-index: 1000;
            backdrop-filter: blur(8px);
        }

        .comanda-digital {
            background: #fff;
            color: #1a1a1a;
            width: 100%;
            max-width: 360px;
            padding: 25px;
            border-radius: 2px;
            font-family: 'JetBrains Mono', monospace;
            position: relative;
            margin-bottom: 50px;
        }

        .ticket-header { text-align: center; border-bottom: 2px dashed #333; padding-bottom: 12px; margin-bottom: 15px; }
        .ticket-item { display: flex; justify-content: space-between; margin: 6px 0; font-size: 0.85rem; }
        .ticket-total { border-top: 2px solid #000; margin-top: 15px; padding-top: 8px; font-size: 1.2rem; font-weight: 800; text-align: right; }
        
        .actions-bar { margin-top: 25px; display: flex; flex-direction: column; gap: 8px; }
        .btn { 
            padding: 15px; 
            border-radius: 8px; 
            border: none; 
            font-weight: 800; 
            font-size: 0.9rem; 
            cursor: pointer; 
            text-transform: uppercase;
            width: 100%;
        }
        .btn-confirm { background: var(--accent-primary); color: white; }
        .btn-cancel { background: #ff4b4b; color: white; }
        .btn-close { background: #eee; color: #333; }

        .cancel-reason-box {
            margin-top: 10px;
            display: none;
            flex-direction: column;
            gap: 8px;
        }
        .cancel-reason-box textarea {
            width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 4px; resize: none; font-family: sans-serif;
        }

        .slow-mode-toggle-container {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 99;
            background: var(--bg-card);
            padding: 10px;
            border-radius: 50px;
            border: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
        }

        .switch { position: relative; display: inline-block; width: 34px; height: 18px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider {
            position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0;
            background-color: #333; transition: .4s; border-radius: 34px;
        }
        .slider:before {
            position: absolute; content: ""; height: 12px; width: 12px;
            left: 3px; bottom: 3px; background-color: white; transition: .4s; border-radius: 50%;
        }
        input:checked + .slider { background-color: var(--status-alert); }
        input:checked + .slider:before { transform: translateX(16px); }
    </style>
</head>
<body>

    <header>
        <div class="brand">ELITE<span>OPS</span></div>
        <div class="header-info">
            <div id="clock">00:00:00</div>
            <div id="status-online">● SISTEMA ATIVO</div>
        </div>
    </header>

    <div class="metrics-bar">
        <div class="metric-item">VENDAS<span id="m-revenue">R$ 0,00</span></div>
        <div class="metric-item">TICKET MÉDIO<span id="m-average">R$ 0,00</span></div>
        <div class="metric-item">PEDIDOS<span id="m-total-count">0</span></div>
    </div>

    <nav class="tab-bar">
        <button class="tab-btn active" onclick="switchTab('pending')">
            <span class="badge-tab" id="count-pending">0</span>
            Pendentes
        </button>
        <button class="tab-btn" onclick="switchTab('preparing')">
            <span class="badge-tab" id="count-preparing">0</span>
            Preparo
        </button>
        <button class="tab-btn" onclick="switchTab('ready')">
            <span class="badge-tab" id="count-ready">0</span>
            Prontos
        </button>
        <button class="tab-btn" onclick="switchTab('archived')">
            <span class="badge-tab" id="count-archived">0</span>
            Histórico
        </button>
    </nav>

    <main class="content-area">
        <section id="tab-pending" class="kanban-column active"><div class="orders-scroll" id="list-pending"></div></section>
        <section id="tab-preparing" class="kanban-column"><div class="orders-scroll" id="list-preparing"></div></section>
        <section id="tab-ready" class="kanban-column"><div class="orders-scroll" id="list-ready"></div></section>
        <section id="tab-archived" class="kanban-column"><div class="orders-scroll" id="list-archived"></div></section>
    </main>

    <div class="slow-mode-toggle-container">
        <span style="font-size: 0.6rem; font-weight: 800; color: var(--text-dim)">MODO LENTO</span>
        <label class="switch">
            <input type="checkbox" id="slow-mode-toggle" onchange="toggleSlowMode()">
            <span class="slider"></span>
        </label>
    </div>

    <div id="modal-overlay" onclick="handleOverlayClick(event)">
        <div class="comanda-digital" id="comanda-target" onclick="event.stopPropagation()"></div>
    </div>

    <script>
        const socket = io(); 
        // Inicializa com os pedidos enviados pelo servidor via EJS
        let orders = <%- JSON.stringify(pedidos) %>;
        let archivedOrders = [];
        let isSlowMode = false;

        function switchTab(tabId) {
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.kanban-column').forEach(col => col.classList.remove('active'));
            
            const btn = document.querySelector(`button[onclick="switchTab('${tabId}')"]`);
            if(btn) btn.classList.add('active');
            document.getElementById(`tab-${tabId}`).classList.add('active');
        }

        function render() {
            const listPending = document.getElementById('list-pending');
            const listPreparing = document.getElementById('list-preparing');
            const listReady = document.getElementById('list-ready');
            const listArchived = document.getElementById('list-archived');

            const containers = { 
                'Pendente': listPending, 
                'Preparando': listPreparing, 
                'Em entrega': listReady, 
                'Finalizado': listArchived,
                'Cancelado': listArchived,
                'Concluído': listArchived
            };
            
            // Limpa as colunas base
            [listPending, listPreparing, listReady, listArchived].forEach(c => c.innerHTML = '');

            const counts = { pending: 0, preparing: 0, ready: 0, archived: 0 };
            
            orders.forEach(order => {
                // Lógica de contagem simplificada para as badges
                if(order.status === 'Pendente') counts.pending++;
                else if(order.status === 'Preparando') counts.preparing++;
                else if(order.status === 'Em entrega') counts.ready++;
                else counts.archived++;

                const card = document.createElement('div');
                card.className = `order-card`;
                card.onclick = () => showComanda(order.id);
                card.innerHTML = `
                    <div class="order-header">
                        <span class="order-id">#${order.id}</span>
                        <span class="order-time">${order.hora}</span>
                    </div>
                    <div class="customer-name">${order.cliente}</div>
                    <div class="order-details">
                        ${order.itens ? order.itens.length : 0} itens • <strong>${order.pagamento}</strong>
                    </div>
                `;
                
                // Distribui o card na coluna correta
                const targetContainer = containers[order.status] || listPending;
                targetContainer.appendChild(card);
            });

            // Atualiza Badges
            document.getElementById('count-pending').innerText = counts.pending;
            document.getElementById('count-preparing').innerText = counts.preparing;
            document.getElementById('count-ready').innerText = counts.ready;
            document.getElementById('count-archived').innerText = counts.archived;

            // Atualiza Métricas (Somente Finalizados/Concluídos)
            const finalizados = orders.filter(o => ['Finalizado', 'Concluído'].includes(o.status));
            const revenue = finalizados.reduce((acc, o) => acc + (o.total || 0), 0);
            document.getElementById('m-revenue').innerText = `R$ ${revenue.toFixed(2)}`;
            document.getElementById('m-total-count').innerText = finalizados.length;
            document.getElementById('m-average').innerText = finalizados.length > 0 ? `R$ ${(revenue / finalizados.length).toFixed(2)}` : 'R$ 0,00';
        }

        function showComanda(id) {
            const order = orders.find(o => o.id == id);
            if(!order) return;

            const target = document.getElementById('comanda-target');
            let actionBtn = '';

            if(order.status === 'Pendente') {
                actionBtn = `<button class="btn btn-confirm" onclick="updateStatus('${order.id}', 'Preparando')">INICIAR PREPARO</button>`;
            } else if(order.status === 'Preparando') {
                actionBtn = `<button class="btn btn-confirm" onclick="updateStatus('${order.id}', 'Em entrega')">SAIU PARA ENTREGA</button>`;
            } else if(order.status === 'Em entrega') {
                actionBtn = `<button class="btn btn-confirm" onclick="updateStatus('${order.id}', 'Finalizado')">FINALIZAR PEDIDO</button>`;
            }

            target.innerHTML = `
                <div class="ticket-header"><p>ELITE OPS</p><h1>#${order.id}</h1><p>${order.hora}</p></div>
                <div style="font-size:0.8rem"><strong>CLIENTE:</strong> ${order.cliente}<br><strong>ENDEREÇO:</strong> ${order.endereco}</div>
                <hr style="margin: 12px 0; border: 1px dashed #ccc;">
                ${order.itens ? order.itens.map(i => `<div class="ticket-item"><span>${i.qtd}x ${i.nome}</span><span>R$ ${(i.qtd * i.preco).toFixed(2)}</span></div>`).join('') : ''}
                <div class="ticket-total">TOTAL R$ ${order.total ? order.total.toFixed(2) : '0.00'}</div>
                <div class="actions-bar">
                    ${actionBtn}
                    <button class="btn btn-cancel" onclick="document.getElementById('cancel-box').style.display='flex'">CANCELAR</button>
                    <div id="cancel-box" class="cancel-reason-box">
                        <textarea id="reason-input" placeholder="Motivo do cancelamento..."></textarea>
                        <button class="btn btn-cancel" style="background:#222" onclick="updateStatus('${order.id}', 'Cancelado')">CONFIRMAR CANCELAMENTO</button>
                    </div>
                    <button class="btn btn-close" onclick="closeModal()">VOLTAR</button>
                </div>
            `;
            document.getElementById('modal-overlay').style.display = 'flex';
        }

        async function updateStatus(id, novoStatus) {
            try {
                const res = await fetch('/update-status', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({id: id, novoStatus: novoStatus})
                });
                if(res.ok) {
                    closeModal();
                    // O Socket.io vai disparar o statusAtualizado e o render() será chamado
                }
            } catch (e) { alert("Erro de conexão"); }
        }

        // --- SOCKET.IO EVENTOS ---
        socket.on('novoPedido', (pedido) => {
            orders.push(pedido);
            render();
            new Audio('https://www.soundjay.com/buttons/sounds/beep-01a.mp3').play().catch(()=>{});
        });

        socket.on('statusAtualizado', (data) => {
            const index = orders.findIndex(o => o.id == data.id);
            if(index !== -1) {
                orders[index].status = data.novoStatus;
                render();
            }
        });

        socket.on('pedidoEncerrado', (data) => {
            // Se o status for de encerramento, o server.js emite este evento.
            // Mantemos no histórico local ou removemos conforme a necessidade.
            render();
        });

        function toggleSlowMode() {
            isSlowMode = document.getElementById('slow-mode-toggle').checked;
            const status = document.getElementById('status-online');
            status.style.color = isSlowMode ? 'var(--status-alert)' : 'var(--status-ready)';
            status.innerText = isSlowMode ? '● ALTA DEMANDA' : '● SISTEMA ATIVO';
        }

        function closeModal() { document.getElementById('modal-overlay').style.display = 'none'; }
        function handleOverlayClick(e) { if(e.target.id === 'modal-overlay') closeModal(); }

        setInterval(() => {
            document.getElementById('clock').innerText = new Date().toLocaleTimeString('pt-BR');
        }, 1000);

        window.onload = render;
    </script>
</body>
</html>